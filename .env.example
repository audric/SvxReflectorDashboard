# Domain for Caddy TLS (e.g. dashboard.example.com)
# Set to localhost for local development (self-signed)
DOMAIN=localhost

BRAND_NAME=your-reflector-dashboard-name
REFLECTOR_EXT_HOST=your-reflector-hostname-or-ip
REFLECTOR_STATUS_URL=http://your-reflector-ip:8080/status
SECRET_KEY_BASE=run_openssl_rand_-hex_64_to_generate


# Bridge types to enable in the admin UI (comma-separated)
# Available: reflector, echolink, xlx, dmr, ysf, allstar, zello, iax, sip
# Default: reflector only
# BRIDGE_TYPES=reflector,xlx,dmr,ysf,allstar,zello,iax,sip

# MQTT broker credentials (used by the bundled Mosquitto container)
MQTT_USERNAME=svxreflector
MQTT_PASSWORD=changeme

# SMTP / Mailgun (optional — sends approval notification emails)
# SMTP_ADDRESS=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_USERNAME=postmaster@mg.yourdomain.com
# SMTP_PASSWORD=your-mailgun-password
# SMTP_DOMAIN=mg.yourdomain.com
# SMTP_FROM=noreply@yourdomain.com

# Google OAuth (optional — enables "Sign in with Google" on login/register)
# Create credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# Audio bridge (optional — for live TG audio monitoring)
REFLECTOR_HOST=your-reflector-ip
REFLECTOR_PORT=5300
