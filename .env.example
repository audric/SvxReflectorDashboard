BRAND_NAME=your-reflector-dashboard-name
REFLECTOR_STATUS_URL=http://your-reflector-ip:8080/status
SECRET_KEY_BASE=run_openssl_rand_-hex_64_to_generate

# Allowed WebSocket origins (optional — comma-separated)
# Only needed if accessing the dashboard through a reverse proxy on a different domain.
# Example: ALLOWED_CABLE_ORIGINS=https://dashboard.example.com,https://svx.local
# ALLOWED_CABLE_ORIGINS=

# Audio bridge (optional — for live TG audio monitoring)
REFLECTOR_HOST=your-reflector-ip
REFLECTOR_PORT=5300
