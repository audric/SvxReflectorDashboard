!!!
%html{lang: "en"}
  :javascript
    (function(){var t=localStorage.getItem('theme')||'auto';var r=(t==='auto'?(window.matchMedia('(prefers-color-scheme:light)').matches?'light':'auto'):t);document.documentElement.setAttribute('data-theme',r);})();
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title= "SVXReflector #{@reflector_host} · Map"
    %script{src: "/vendor/tailwind/tailwind.js"}
    :javascript
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ghbg: '#0d1117',
              ghcard: '#161b22',
              ghborder: '#30363d',
              ghborder2: '#21262d',
              ghtext: '#c9d1d9',
              ghmuted: '#8b949e',
              ghdim: '#6e7681',
            }
          }
        }
      }
    %link{rel: "stylesheet", href: "/vendor/bootstrap-icons/font/bootstrap-icons.min.css"}
    %link{rel: "stylesheet", href: "/vendor/leaflet/leaflet.css"}
    :css
      body { background: #0d1117; margin: 0; }
      #map { height: calc(100vh - 72px); width: 100%; position: relative; z-index: 0; }
      @media (min-width: 1024px) {
        body { padding-top: 0 !important; }
        #map { height: 100vh; }
      }

      .ws-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; vertical-align: middle; }
      .ws-connected    { background: #3fb950; }
      .ws-disconnected { background: #f85149; }
      .ws-connecting   { background: #d29922; animation: blink 1s step-start infinite; }
      @keyframes blink { 50% { opacity: .2; } }

      /* ── Dark Leaflet popup ─────────────────────────────────────────────────── */
      .leaflet-popup-content-wrapper {
        background: #161b22;
        border: 1px solid #30363d;
        color: #c9d1d9;
        border-radius: .4rem;
      }
      .leaflet-popup-tip { background: #161b22; }
      .leaflet-popup-content { margin: .6rem .8rem; font-size: .82rem; }
      .popup-callsign { font-family: monospace; font-weight: 700; font-size: 1rem; color: #e6edf3; }
      .popup-row { margin-top: .25rem; color: #8b949e; }
      .popup-row span { color: #c9d1d9; }
      .tone-table { width: 100%; border-collapse: collapse; margin-top: .4rem; font-size: .75rem; }
      .tone-table th { color: #6e7681; font-weight: 600; text-transform: uppercase; font-size: .65rem; letter-spacing: .04em; padding: .1rem .3rem; border-bottom: 1px solid #30363d; text-align: left; }
      .tone-table td { padding: .15rem .3rem; color: #c9d1d9; font-family: monospace; border-bottom: 1px solid #21262d; }
      .tone-table tr:last-child td { border-bottom: none; }
      .tone-tg-idle { color: #6e7681 !important; }
      .tone-table tr.tone-active { background: rgba(63,185,80,.15); }
      .tone-table tr.tone-active td { color: #3fb950; font-weight: 700; }
      .badge-talking { background: #1a4a25; color: #3fb950; border: 1px solid #3fb950; border-radius: .25em; padding: .1em .45em; font-size: .72rem; font-weight: 600; }
      .badge-active  { background: #1f3a5f; color: #79c0ff; border: 1px solid #1f6feb; border-radius: .25em; padding: .1em .45em; font-size: .72rem; font-weight: 600; }
      .badge-idle    { background: #21262d; color: #8b949e; border: 1px solid #30363d; border-radius: .25em; padding: .1em .45em; font-size: .72rem; }


      /* ── Layer control dark skin ────────────────────────────────────────────── */
      .leaflet-control-layers {
        background: #161b22 !important;
        border: 1px solid #30363d !important;
        border-radius: .4rem !important;
        color: #c9d1d9 !important;
      }
      .leaflet-control-layers-toggle {
        background-color: #161b22 !important;
      }
      .leaflet-control-layers label { color: #c9d1d9 !important; font-size: .82rem; }
      .leaflet-control-layers-separator { border-top-color: #30363d !important; }

      /* ── Zoom control dark skin ─────────────────────────────────────────────── */
      .leaflet-bar a {
        background-color: #161b22 !important;
        border-color: #30363d !important;
        color: #c9d1d9 !important;
      }
      .leaflet-bar a:hover { background-color: #21262d !important; }

      /* ── Map filters ──────────────────────────────────────────────────────── */
      .map-filters {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: .4rem;
        padding: .5rem .6rem;
        font-size: .78rem;
        color: #8b949e;
        max-width: 360px;
      }
      .map-filters .filter-title {
        font-size: .62rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        font-weight: 600;
        color: #6e7681;
        margin-bottom: .3rem;
      }
      .map-filters .filter-title:not(:first-child) { margin-top: .5rem; }
      .map-filters .filter-toggle {
        display: flex; align-items: center; justify-content: space-between;
        cursor: pointer; user-select: none; margin-bottom: .3rem;
      }
      .map-filters .filter-toggle-label {
        font-size: .72rem; font-weight: 700; color: #c9d1d9;
        letter-spacing: .04em;
      }
      .map-filters .filter-toggle i { color: #6e7681; transition: transform .2s; font-size: .7rem; }
      .map-filters .filter-toggle-icon { display: none; font-size: 1rem; color: #c9d1d9; }
      .map-filters .filter-toggle i.open { transform: rotate(180deg); }
      .map-filters .filter-body { overflow: hidden; transition: max-height .2s ease; }
      .map-filters .filter-body.collapsed { max-height: 0 !important; }
      .map-filter-btn {
        display: inline-block;
        padding: .15rem .45rem;
        font-size: .7rem;
        border-radius: .25rem;
        cursor: pointer;
        color: #8b949e;
        border: 1px solid #30363d;
        background: transparent;
        margin: .1rem .1rem;
        transition: background .15s, color .15s;
      }
      .map-filter-btn:hover { color: #c9d1d9; border-color: #6e7681; }
      .map-filter-btn.active { background: #1f3a5f; color: #79c0ff; border-color: #1f6feb; }

      /* ── Icon markers ─────────────────────────────────────────────────────── */
      .map-marker {
        display: flex; align-items: center; justify-content: center;
        width: 36px; height: 36px; border-radius: 50%;
        border: 2px solid rgba(255,255,255,.3);
        font-size: 16px; color: #fff;
        box-shadow: 0 1px 4px rgba(0,0,0,.4);
        transition: transform .15s;
      }
      .map-marker:hover { transform: scale(1.2); }
      .map-marker-ext {
        width: 28px; height: 28px; font-size: 13px;
        border-style: dashed; opacity: .9;
      }
      .map-marker-talking { animation: marker-pulse 1s ease infinite; }
      @keyframes marker-pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(63,185,80,.5); } 50% { box-shadow: 0 0 0 8px rgba(63,185,80,0); } }

      @media (max-width: 767px) {
        .map-filters .filter-toggle-label { display: none; }
        .map-filters .filter-toggle-icon { display: block; }
        .map-filters #filter-chevron { display: none; }
        .map-filters .filter-body { display: none; }
        .map-filters.expanded .filter-toggle-label { display: inline; }
        .map-filters.expanded .filter-toggle-icon { display: none; }
        .map-filters.expanded #filter-chevron { display: inline; }
        .map-filters.expanded .filter-body { display: block; }
      }

      /* ── Legend ─────────────────────────────────────────────────────────────── */
      .map-legend {
        background: #161b22;
        border: 1px solid #30363d;
        border-radius: .4rem;
        padding: .5rem .75rem;
        font-size: .78rem;
        color: #8b949e;
        line-height: 1.6;
        min-width: 120px;
      }
      .map-legend .legend-title {
        font-size: .68rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        font-weight: 600;
        color: #6e7681;
        margin-bottom: .35rem;
      }
      .map-legend .legend-row { display: flex; align-items: center; gap: .5rem; color: #c9d1d9; }
      .legend-dot {
        width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0;
        border: 2px solid rgba(255,255,255,.25);
      }

  %body.text-ghtext

    = render 'shared/navbar', active: 'map', ws_indicator: true

    - if @fetch_error
      .flex.items-center.p-3.rounded-lg.m-3{class: "bg-yellow-900/30 border border-yellow-700 text-yellow-400", role: "alert"}
        %i.bi.bi-exclamation-triangle-fill.mr-2
        = @fetch_error

    %div{style: "position:relative"}
      #map

    %script{src: "/vendor/leaflet/leaflet.js"}
    - nodes_json = @nodes.to_json.html_safe
    -# external nodes are now merged into @nodes server-side
    :javascript
      (function () {
        'use strict';

        var nodes = #{nodes_json};

        // ── Tile layers ────────────────────────────────────────────────────────────
        var tileLayers = {
          '<i class="bi bi-moon-stars mr-1"></i>Dark': L.tileLayer(
            'https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
            { attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>', subdomains: 'abcd', maxZoom: 19 }
          ),
          '<i class="bi bi-signpost-2 mr-1"></i>Street': L.tileLayer(
            'https://tile.openstreetmap.org/{z}/{x}/{y}.png',
            { attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors', maxZoom: 19 }
          ),
          '<i class="bi bi-globe-americas mr-1"></i>Satellite': L.tileLayer(
            'https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',
            { attribution: 'Tiles &copy; Esri &mdash; Source: Esri, i-cubed, USDA, USGS, AEX, GeoEye, Getmapping, Aerogrid, IGN, IGP, UPR-EGP, and the GIS User Community', maxZoom: 19 }
          ),
          '<i class="bi bi-mountains mr-1"></i>Topo': L.tileLayer(
            'https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png',
            { attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors, <a href="https://opentopomap.org">OpenTopoMap</a>', maxZoom: 17 }
          )
        };

        // ── Leaflet map ────────────────────────────────────────────────────────────
        var defaultLayer = tileLayers[Object.keys(tileLayers)[0]];
        var map = L.map('map', { zoomControl: true, layers: [defaultLayer] });

        var overlays = {};

        var layerControl = L.control.layers(tileLayers, overlays, { position: 'topright', collapsed: true }).addTo(map);

        // ── Helpers (defined early so external code can use them) ─────────────────
        function esc(s) {
          return String(s || '')
            .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
        }

        function markerColor(node) {
          if (node.isTalker)             return '#3fb950';
          if (node.tg && node.tg !== 0) return '#1f6feb';
          return '#6e7681';
        }

        function statusBadge(node) {
          var tg = node.tg || 0;
          if (node.isTalker) return '<span class="badge-talking">TALKING &middot; TG ' + tg + '</span>';
          if (tg !== 0)      return '<span class="badge-active">TG ' + tg + '</span>';
          return '<span class="badge-idle">IDLE</span>';
        }

        // ── Legend ─────────────────────────────────────────────────────────────────
        var legend = L.control({ position: 'bottomleft' });
        legend.onAdd = function () {
          var div = L.DomUtil.create('div', 'map-legend');
          div.innerHTML =
            '<div class="legend-title">Node status</div>' +
            '<div class="legend-row"><span class="legend-dot" style="background:#3fb950"></span>Talking</div>' +
            '<div class="legend-row"><span class="legend-dot" style="background:#1f6feb"></span>Active (on TG)</div>' +
            '<div class="legend-row"><span class="legend-dot" style="background:#6e7681"></span>Idle</div>' +
            '<div class="legend-row"><span class="legend-dot" style="background:#0891b2;border:1px dashed #0e4a5c"></span>Trunk peer</div>' +
            '<div class="legend-row"><span class="legend-dot" style="background:#d97706;border:1px dashed #78350f"></span>External SVX</div>';
          return div;
        };
        legend.addTo(map);

        // ── Off-map indicator ─────────────────────────────────────────────────────
        var offMapTotal = #{@off_map_total || 0};
        var offMapTalking = #{@off_map_talking || 0};
        var offMapActive = #{@off_map_active || 0};
        if (offMapTotal > 0) {
          var offMap = L.control({ position: 'bottomright' });
          offMap.onAdd = function () {
            var div = L.DomUtil.create('div', 'map-legend');
            div.id = 'off-map-info';
            var parts = [];
            if (offMapTalking > 0) parts.push('<span style="color:#3fb950;font-weight:600">' + offMapTalking + ' talking</span>');
            if (offMapActive > 0) parts.push('<span style="color:#79c0ff">' + offMapActive + ' active</span>');
            div.innerHTML =
              '<div class="legend-title"><i class="bi bi-geo-alt-fill mr-1"></i>Off map</div>' +
              '<div style="color:#c9d1d9;font-size:.8rem">' + offMapTotal + ' nodes without coordinates</div>' +
              (parts.length ? '<div style="font-size:.8rem;margin-top:.2rem">' + parts.join(' · ') + '</div>' : '');
            return div;
          };
          offMap.addTo(map);
        }

        // ── Filter control ─────────────────────────────────────────────────────────
        var currentTypeFilter = 'all';
        var currentSourceFilter = 'network';
        var markerMeta = {}; // cs → { nodeClass, source }

        var filterCtrl = L.control({ position: 'topleft' });
        filterCtrl.onAdd = function () {
          var div = L.DomUtil.create('div', 'map-filters');
          L.DomEvent.disableClickPropagation(div);
          L.DomEvent.disableScrollPropagation(div);

          var sourceTypes = [
            ['all', 'All'],
            ['network', '<i class="bi bi-hdd-network"></i> Network'],
            ['local', '<i class="bi bi-broadcast"></i> Local'],
            ['trunk', '<i class="bi bi-diagram-3"></i> Trunk'],
            ['svx', '<i class="bi bi-globe2"></i> Ext SVX']
          ];
          var nodeTypes = [
            ['all', 'All'], ['repeater', 'Repeater'], ['bridge', 'Bridge'],
            ['echolink', 'EchoLink'], ['xlx', 'XLX'], ['dmr', 'DMR'],
            ['ysf', 'YSF'], ['allstar', 'AllStar'], ['zello', 'Zello'],
            ['iax', 'IAX'], ['sip', 'SIP'], ['simplex', 'Simplex']
          ];

          var startCollapsed = window.innerWidth < 768;

          var html = '<div class="filter-toggle" id="filter-toggle">' +
                     '<span class="filter-toggle-label"><i class="bi bi-funnel mr-1"></i>Filters</span>' +
                     '<i class="bi bi-funnel filter-toggle-icon"></i>' +
                     '<i class="bi bi-chevron-down' + (startCollapsed ? '' : ' open') + '" id="filter-chevron"></i>' +
                     '</div>' +
                     '<div class="filter-body' + (startCollapsed ? ' collapsed' : '') + '" id="filter-body" style="max-height:500px">';
          html += '<div class="filter-title">Source</div><div class="source-btns">';
          sourceTypes.forEach(function(st) {
            html += '<button class="map-filter-btn' + (st[0] === 'network' ? ' active' : '') + '" data-source="' + st[0] + '">' + st[1] + '</button>';
          });
          html += '</div><div class="filter-title">Type</div><div class="type-btns">';
          nodeTypes.forEach(function(nt) {
            html += '<button class="map-filter-btn' + (nt[0] === 'all' ? ' active' : '') + '" data-type="' + nt[0] + '">' + nt[1] + '</button>';
          });
          html += '</div></div>';
          div.innerHTML = html;

          // Toggle collapse
          div.querySelector('#filter-toggle').addEventListener('click', function() {
            var body = div.querySelector('#filter-body');
            var chevron = div.querySelector('#filter-chevron');
            body.classList.toggle('collapsed');
            chevron.classList.toggle('open');
            div.classList.toggle('expanded');
          });

          div.querySelectorAll('[data-source]').forEach(function(btn) {
            btn.addEventListener('click', function() {
              currentSourceFilter = btn.dataset.source;
              div.querySelectorAll('[data-source]').forEach(function(b) { b.classList.toggle('active', b.dataset.source === currentSourceFilter); });
              applyMapFilters();
            });
          });
          div.querySelectorAll('[data-type]').forEach(function(btn) {
            btn.addEventListener('click', function() {
              currentTypeFilter = btn.dataset.type;
              div.querySelectorAll('[data-type]').forEach(function(b) { b.classList.toggle('active', b.dataset.type === currentTypeFilter); });
              applyMapFilters();
            });
          });

          return div;
        };
        filterCtrl.addTo(map);

        function sourceMatches(source, filter) {
          if (filter === 'all') return true;
          if (filter === 'network') return source === 'local' || source === 'trunk';
          return source === filter;
        }

        function applyMapFilters() {
          // Count which node types exist for the current source filter
          var typeCounts = {};
          Object.keys(markersByCs).forEach(function(cs) {
            var meta = markerMeta[cs];
            if (!meta) return;
            if (sourceMatches(meta.source, currentSourceFilter)) {
              typeCounts[meta.nodeClass] = (typeCounts[meta.nodeClass] || 0) + 1;
            }
          });

          // Show/hide type buttons based on available types
          var typeBtns = document.querySelectorAll('[data-type]');
          typeBtns.forEach(function(btn) {
            var t = btn.dataset.type;
            if (t === 'all') {
              btn.style.display = '';
            } else {
              btn.style.display = typeCounts[t] ? '' : 'none';
            }
          });

          // If current type filter has no markers, reset to 'all'
          if (currentTypeFilter !== 'all' && !typeCounts[currentTypeFilter]) {
            currentTypeFilter = 'all';
            typeBtns.forEach(function(b) { b.classList.toggle('active', b.dataset.type === 'all'); });
          }

          // Apply visibility
          Object.keys(markersByCs).forEach(function(cs) {
            var meta = markerMeta[cs];
            if (!meta) return;
            var typeMatch = currentTypeFilter === 'all' || meta.nodeClass === currentTypeFilter;
            var sourceMatch = sourceMatches(meta.source, currentSourceFilter);
            var visible = typeMatch && sourceMatch;
            if (visible) {
              if (!map.hasLayer(markersByCs[cs])) markersByCs[cs].addTo(map);
            } else {
              if (map.hasLayer(markersByCs[cs])) markersByCs[cs].remove();
            }
          });
        }

        // ── Icon marker factory ────────────────────────────────────────────────────
        var markerIconMap = { repeater: 'bi-arrow-repeat', bridge: 'bi-link-45deg', xlx: 'bi-globe', dmr: 'bi-broadcast-pin', ysf: 'bi-soundwave', allstar: 'bi-telephone', iax: 'bi-phone-vibrate', sip: 'bi-headset-vr', echolink: 'bi-headset', zello: 'bi-phone', simplex: 'bi-broadcast' };

        function createMarkerIcon(node) {
          var isExt = !!node._external;
          var isTrunk = node._external_type === 'trunk';
          var bg = isExt
            ? (isTrunk ? (node.isTalker ? '#22d3ee' : (node.tg ? '#0891b2' : '#155e75'))
                       : (node.isTalker ? '#f59e0b' : (node.tg ? '#d97706' : '#92400e')))
            : markerColor(node);
          var iconCls = markerIconMap[node.nodeClass] || 'bi-broadcast';
          var size = isExt ? 28 : 36;
          var cls = 'map-marker' + (isExt ? ' map-marker-ext' : '') + (node.isTalker ? ' map-marker-talking' : '');
          return L.divIcon({
            className: '',
            iconSize: [size, size],
            iconAnchor: [size/2, size/2],
            popupAnchor: [0, -size/2],
            html: '<div class="' + cls + '" style="background:' + bg + '"><i class="bi ' + iconCls + '"></i></div>'
          });
        }

        // ── Tooltip HTML builder (compact — no tone table, no links) ──────────────
        var tooltipIconMap = { repeater: 'bi-arrow-repeat', bridge: 'bi-link-45deg', xlx: 'bi-globe', dmr: 'bi-broadcast-pin', ysf: 'bi-soundwave', allstar: 'bi-telephone', iax: 'bi-phone-vibrate', sip: 'bi-headset-vr', echolink: 'bi-headset', zello: 'bi-phone', simplex: 'bi-broadcast' };

        function buildTooltipHtml(cs, node) {
          var iconCls = tooltipIconMap[node.nodeClass] || 'bi-broadcast';
          var html = '<div class="popup-callsign">' + esc(cs) + '</div>' +
                     '<div class="popup-row" style="margin-top:.35rem">' + statusBadge(node) + '</div>';
          if (node.nodeClass)    html += '<div class="popup-row"><i class="bi ' + iconCls + ' mr-1"></i><span>' + esc(node.nodeClass) + '</span></div>';
          if (node.nodeLocation) html += '<div class="popup-row"><i class="bi bi-geo-alt mr-1"></i><span>' + esc(node.nodeLocation) + '</span></div>';
          if (node.sysop)        html += '<div class="popup-row"><i class="bi bi-person mr-1"></i><span>' + esc(node.sysop) + '</span></div>';
          if (node._external)    html += '<div class="popup-row" style="color:#d97706"><i class="bi bi-globe2 mr-1"></i><span>' + esc(node._external) + '</span></div>';
          return html;
        }

        // ── Place markers ──────────────────────────────────────────────────────────
        var bounds = [];
        var markersByCs = {};

        Object.keys(nodes).forEach(function (cs) {
          var node = nodes[cs];
          var pos = node.qth && node.qth[0] && node.qth[0].pos;
          var lat = parseFloat(pos && pos.lat);
          var lng = parseFloat(pos && pos.long);
          if (!isFinite(lat) || !isFinite(lng)) return;

          var isExt = !!node._external;
          var isTrunk = node._external_type === 'trunk';
          var marker = L.marker([lat, lng], { icon: createMarkerIcon(node) }).addTo(map);

          marker.on('mouseover', function() { this.openPopup(); });
          marker.on('mouseout', function() { this.closePopup(); });

          // Popup
          var qth     = node.qth[0];
          var locator = pos.loc || '';
          var rxFreq  = qth.rx && Object.values(qth.rx)[0] && Object.values(qth.rx)[0].freq;
          var txFreq  = qth.tx && Object.values(qth.tx)[0] && Object.values(qth.tx)[0].freq;
          var nodeIcon = { repeater: 'bi-arrow-repeat', bridge: 'bi-link-45deg', xlx: 'bi-globe', dmr: 'bi-broadcast-pin', ysf: 'bi-soundwave', allstar: 'bi-telephone', iax: 'bi-phone-vibrate', sip: 'bi-headset-vr', echolink: 'bi-headset', zello: 'bi-phone', simplex: 'bi-broadcast' };
          var iconCls  = nodeIcon[node.nodeClass] || 'bi-broadcast';

          var html = '<div class="popup-callsign">' + esc(cs) + '</div>' +
                     '<div class="popup-row" style="margin-top:.35rem">' + statusBadge(node) + '</div>';
          if (node.nodeClass)    html += '<div class="popup-row"><i class="bi ' + iconCls + ' mr-1"></i><span>' + esc(node.nodeClass) + '</span></div>';
          if (node.nodeLocation) html += '<div class="popup-row"><i class="bi bi-geo-alt mr-1"></i><span>' + esc(node.nodeLocation) + '</span></div>';
          if (locator)           html += '<div class="popup-row"><i class="bi bi-grid-3x3-gap mr-1"></i><span class="font-mono">' + esc(locator) + '</span></div>';
          if (rxFreq && rxFreq > 0) html += '<div class="popup-row">RX <span class="font-mono">' + parseFloat(rxFreq).toFixed(4) + ' MHz</span></div>';
          if (txFreq && txFreq > 0) html += '<div class="popup-row">TX <span class="font-mono">' + parseFloat(txFreq).toFixed(4) + ' MHz</span></div>';
          if (node.sysop)        html += '<div class="popup-row"><i class="bi bi-person mr-1"></i><span>' + esc(node.sysop) + '</span></div>';
          if (node._external)   html += '<div class="popup-row" style="color:#d97706"><i class="bi bi-globe2 mr-1"></i><span>' + esc(node._external) + '</span></div>';
          if (node.links && node.links.length > 0) {
            html += '<div class="popup-row"><i class="bi bi-diagram-3 mr-1"></i>';
            if (node.remoteHost) html += '<span>' + esc(node.remoteHost) + '</span> ';
            node.links.forEach(function(lk) {
              html += '<span style="margin-left:.25rem">TG ' + lk.localTg + ' ↔ ' + lk.remoteTg + '</span>';
            });
            html += '</div>';
          }

          // Tone → TG mapping table
          var ttg = node.toneToTalkgroup;
          var activeTg = (node.isTalker && node.tg) ? node.tg : null;
          if (ttg && Object.keys(ttg).length > 0) {
            var rows = Object.keys(ttg).sort(function (a, b) { return parseFloat(a) - parseFloat(b); }).map(function (tone) {
              var tgNum = ttg[tone];
              var isActive = activeTg !== null && tgNum === activeTg;
              var tgCell = tgNum === 0
                ? '<td class="tone-tg-idle">local</td>'
                : '<td>' + tgNum + '</td>';
              return '<tr' + (isActive ? ' class="tone-active"' : '') + '><td>' + parseFloat(tone).toFixed(1) + ' Hz</td>' + tgCell + '</tr>';
            }).join('');
            html += '<div class="popup-row" style="margin-top:.5rem"><i class="bi bi-music-note-list mr-1"></i><span>Tone / TG</span></div>' +
                    '<table class="tone-table"><thead><tr><th>CTCSS</th><th>TG</th></tr></thead><tbody>' + rows + '</tbody></table>';
          }

          marker.bindPopup(buildTooltipHtml(cs, node), { maxWidth: 260 });
          marker.on('mouseover', function() { this.openPopup(); });
          marker.on('mouseout', function() { this.closePopup(); });
          markersByCs[cs] = marker;
          markerMeta[cs] = {
            nodeClass: (node.nodeClass || '').toLowerCase(),
            source: node._external_type === 'trunk' ? 'trunk' : (node._external_type === 'svx' ? 'svx' : 'local')
          };
          bounds.push([lat, lng]);
        });

        // Fit map to markers or default to Europe
        if (bounds.length > 0) {
          map.fitBounds(bounds, { padding: [40, 40] });
        } else {
          map.setView([48, 10], 5);
        }

        // Apply default filter (network = local + trunk)
        applyMapFilters();

        // Open popup for any node already talking at page load
        Object.keys(markersByCs).forEach(function (cs) {
          if (nodes[cs] && nodes[cs].isTalker) markersByCs[cs].openPopup();
        });

        // ── Popup HTML builder ─────────────────────────────────────────────────────
        function buildPopupHtml(cs, node) {
          var pos     = node.qth && node.qth[0] && node.qth[0].pos;
          var qth     = (node.qth && node.qth[0]) || {};
          var locator = (pos && pos.loc) || '';
          var rxFreq  = qth.rx && Object.values(qth.rx)[0] && Object.values(qth.rx)[0].freq;
          var txFreq  = qth.tx && Object.values(qth.tx)[0] && Object.values(qth.tx)[0].freq;
          var nodeIcon = { repeater: 'bi-arrow-repeat', bridge: 'bi-link-45deg', xlx: 'bi-globe', dmr: 'bi-broadcast-pin', ysf: 'bi-soundwave', allstar: 'bi-telephone', iax: 'bi-phone-vibrate', sip: 'bi-headset-vr', echolink: 'bi-headset', zello: 'bi-phone', simplex: 'bi-broadcast' };
          var iconCls  = nodeIcon[node.nodeClass] || 'bi-broadcast';
          var html = '<div class="popup-callsign">' + esc(cs) + '</div>' +
                     '<div class="popup-row" style="margin-top:.35rem">' + statusBadge(node) + '</div>';
          if (node.nodeClass)    html += '<div class="popup-row"><i class="bi ' + iconCls + ' mr-1"></i><span>' + esc(node.nodeClass) + '</span></div>';
          if (node.nodeLocation) html += '<div class="popup-row"><i class="bi bi-geo-alt mr-1"></i><span>' + esc(node.nodeLocation) + '</span></div>';
          if (locator)           html += '<div class="popup-row"><i class="bi bi-grid-3x3-gap mr-1"></i><span class="font-mono">' + esc(locator) + '</span></div>';
          if (rxFreq && rxFreq > 0) html += '<div class="popup-row">RX <span class="font-mono">' + parseFloat(rxFreq).toFixed(4) + ' MHz</span></div>';
          if (txFreq && txFreq > 0) html += '<div class="popup-row">TX <span class="font-mono">' + parseFloat(txFreq).toFixed(4) + ' MHz</span></div>';
          if (node.sysop)        html += '<div class="popup-row"><i class="bi bi-person mr-1"></i><span>' + esc(node.sysop) + '</span></div>';
          if (node._external)   html += '<div class="popup-row" style="color:#d97706"><i class="bi bi-globe2 mr-1"></i><span>' + esc(node._external) + '</span></div>';
          if (node.links && node.links.length > 0) {
            html += '<div class="popup-row"><i class="bi bi-diagram-3 mr-1"></i>';
            if (node.remoteHost) html += '<span>' + esc(node.remoteHost) + '</span> ';
            node.links.forEach(function(lk) {
              html += '<span style="margin-left:.25rem">TG ' + lk.localTg + ' ↔ ' + lk.remoteTg + '</span>';
            });
            html += '</div>';
          }
          var ttg = node.toneToTalkgroup;
          var activeTg = (node.isTalker && node.tg) ? node.tg : null;
          if (ttg && Object.keys(ttg).length > 0) {
            var rows = Object.keys(ttg).sort(function (a, b) { return parseFloat(a) - parseFloat(b); }).map(function (tone) {
              var tgNum = ttg[tone];
              var isActive = activeTg !== null && tgNum === activeTg;
              return '<tr' + (isActive ? ' class="tone-active"' : '') + '><td>' + parseFloat(tone).toFixed(1) + ' Hz</td>' +
                     (tgNum === 0 ? '<td class="tone-tg-idle">local</td>' : '<td>' + tgNum + '</td>') + '</tr>';
            }).join('');
            html += '<div class="popup-row" style="margin-top:.5rem"><i class="bi bi-music-note-list mr-1"></i><span>Tone / TG</span></div>' +
                    '<table class="tone-table"><thead><tr><th>CTCSS</th><th>TG</th></tr></thead><tbody>' + rows + '</tbody></table>';
          }
          return html;
        }

        // ── Live marker management ──────────────────────────────────────────────────
        function addOrUpdateMarker(cs, node) {
          var pos = node.qth && node.qth[0] && node.qth[0].pos;
          var lat = parseFloat(pos && pos.lat);
          var lng = parseFloat(pos && pos.long);
          if (node.hidden || !isFinite(lat) || !isFinite(lng)) {
            if (markersByCs[cs]) { markersByCs[cs].remove(); delete markersByCs[cs]; delete markerMeta[cs]; }
            return;
          }
          var isExt = !!node._external;
          var isTrunk = node._external_type === 'trunk';

          markerMeta[cs] = {
            nodeClass: (node.nodeClass || '').toLowerCase(),
            source: isTrunk ? 'trunk' : (node._external_type === 'svx' ? 'svx' : 'local')
          };

          if (markersByCs[cs]) {
            markersByCs[cs].setIcon(createMarkerIcon(node));
            markersByCs[cs].setPopupContent(buildTooltipHtml(cs, node));
          } else {
            var marker = L.marker([lat, lng], { icon: createMarkerIcon(node) });
            marker.bindPopup(buildTooltipHtml(cs, node), { maxWidth: 260 });
            marker.on('mouseover', function() { this.openPopup(); });
            marker.on('mouseout', function() { this.closePopup(); });
            markersByCs[cs] = marker;
          }
          // Respect active filters
          var meta = markerMeta[cs];
          var typeMatch = currentTypeFilter === 'all' || meta.nodeClass === currentTypeFilter;
          var sourceMatch = sourceMatches(meta.source, currentSourceFilter);
          if (typeMatch && sourceMatch) {
            if (!map.hasLayer(markersByCs[cs])) markersByCs[cs].addTo(map);
          } else {
            if (map.hasLayer(markersByCs[cs])) markersByCs[cs].remove();
          }
          if (node.isTalker && typeMatch && sourceMatch) {
            markersByCs[cs].openPopup();
          } else {
            markersByCs[cs].closePopup();
          }
        }

        // ── WebSocket indicator ────────────────────────────────────────────────────
        function setWs(state) {
          var color = state === 'connected' ? 'text-green-500' : state === 'disconnected' ? 'text-red-500' : 'text-yellow-500';
          var title = state === 'connected' ? 'Live' : state === 'disconnected' ? 'Disconnected' : 'Connecting\u2026';
          var pulse = state === 'connecting' ? 'animate-pulse' : '';
          document.querySelectorAll('.js-ws-icon').forEach(function(el) {
            el.className = 'bi bi-broadcast-pin js-ws-icon text-lg ' + color + (pulse ? ' ' + pulse : '');
            el.title = title;
          });
        }

        // ── WebSocket for live updates ─────────────────────────────────────────────
        function connectMapWs() {
          if (window._pageWs) { window._pageWs.onclose = null; window._pageWs.close(); }
          setWs('connecting');
          var proto = location.protocol === 'https:' ? 'wss' : 'ws';
          var ws = new WebSocket(proto + '://' + location.host + '/cable');
          window._pageWs = ws;
          ws.onopen = function () {
            ws.send(JSON.stringify({ command: 'subscribe', identifier: JSON.stringify({ channel: 'UpdatesChannel' }) }));
          };
          ws.onmessage = function (ev) {
            var envelope;
            try { envelope = JSON.parse(ev.data); } catch (e) { return; }
            if (envelope.type === 'welcome')              { setWs('connected'); return; }
            if (envelope.type === 'ping')                 { return; }
            if (envelope.type === 'confirm_subscription') { return; }
            var msg = envelope.message;
            if (!msg || !msg.nodes) return;
            if (window.audioPlayerUpdateTgs) window.audioPlayerUpdateTgs(msg.nodes);
            (msg.removed || []).forEach(function (cs) {
              if (markersByCs[cs]) { markersByCs[cs].remove(); delete markersByCs[cs]; delete markerMeta[cs]; }
            });
            (msg.changed || []).forEach(function (cs) {
              if (msg.nodes[cs]) addOrUpdateMarker(cs, msg.nodes[cs]);
            });
          };
          ws.onclose = function () { setWs('disconnected'); setTimeout(connectMapWs, 5000); };
          ws.onerror = function () { setWs('disconnected'); };
        }
        connectMapWs();
      })();
