!!!
%html{lang: "en"}
  :javascript
    (function(){var t=localStorage.getItem('theme')||'auto';var r=(t==='auto'?(window.matchMedia('(prefers-color-scheme:light)').matches?'light':'auto'):t);document.documentElement.setAttribute('data-theme',r);})();
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title= "SVXReflector #{@reflector_host} · TG Matrix"
    %script{src: "/vendor/tailwind/tailwind.js"}
    :javascript
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ghbg: '#0d1117',
              ghcard: '#161b22',
              ghborder: '#30363d',
              ghborder2: '#21262d',
              ghtext: '#c9d1d9',
              ghmuted: '#8b949e',
              ghdim: '#6e7681',
            }
          }
        }
      }
    %link{rel: "stylesheet", href: "/vendor/bootstrap-icons/font/bootstrap-icons.min.css"}
    :css
      body { background: #0d1117; }

      .ws-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; vertical-align: middle; }
      .ws-connected    { background: #3fb950; }
      .ws-disconnected { background: #f85149; }
      .ws-connecting   { background: #d29922; animation: blink 1s step-start infinite; }
      @keyframes blink { 50% { opacity: .2; } }

      /* ── Page header divider ─────────────────────────────────────────────── */
      .page-header {
        display: flex; align-items: center; gap: .75rem;
        padding: 1rem 0 .75rem;
        font-size: .7rem; text-transform: uppercase; letter-spacing: .08em;
        color: #6e7681; font-weight: 600;
      }
      .page-header::after { content: ''; flex: 1; height: 1px; background: #21262d; }

      /* ── Matrix wrapper ──────────────────────────────────────────────────── */
      .matrix-wrap {
        overflow-x: auto;
        overflow-y: auto;
        max-height: calc(100vh - 160px);
        border: 1px solid #30363d;
        border-radius: .4rem;
      }
      @media (min-width: 1024px) {
        .matrix-wrap { max-height: calc(100vh - 100px); }
      }

      /* ── Table base ──────────────────────────────────────────────────────── */
      .matrix-table {
        border-collapse: separate;
        border-spacing: 0;
        font-size: .8rem;
        white-space: nowrap;
        width: 100%;
      }

      /* ── Sticky first column ─────────────────────────────────────────────── */
      .matrix-table .col-node {
        position: sticky;
        left: 0;
        z-index: 2;
        background: #0d1117;
        border-right: 2px solid #30363d;
        min-width: 180px;
      }
      #tg-map-table { width: auto; }
      #tg-map-table .col-node {
        min-width: 150px;
        max-width: 150px;
      }

      /* ── Sticky header row ───────────────────────────────────────────────── */
      .matrix-table thead th {
        position: sticky;
        top: 0;
        z-index: 3;
        background: #161b22;
        border-bottom: 2px solid #30363d;
        padding: .5rem .65rem;
        font-size: .68rem;
        text-transform: uppercase;
        letter-spacing: .05em;
        color: #6e7681;
        font-weight: 600;
        text-align: center;
      }

      /* ── Top-left corner cell above both sticky axes ─────────────────────── */
      .matrix-table thead th.col-node {
        z-index: 4;
        background: #161b22;
        text-align: left;
      }

      /* ── TG column heading ───────────────────────────────────────────────── */
      .tg-col-head {
        font-family: monospace;
        color: #c9d1d9;
        font-size: .78rem;
        font-weight: 700;
        text-transform: none;
        letter-spacing: 0;
        display: block;
      }
      .tg-col-head.local { color: #8b949e; font-style: italic; }

      /* ── Body cells ──────────────────────────────────────────────────────── */
      .matrix-table td {
        padding: .35rem .65rem;
        border-bottom: 1px solid #21262d;
        text-align: center;
        vertical-align: middle;
      }
      .matrix-table tbody tr:last-child td { border-bottom: none; }
      .matrix-table tbody tr:hover td { background: #161b22; }
      .matrix-table tbody tr:hover td.col-node { background: #1c2128; }

      /* ── Node cell content ───────────────────────────────────────────────── */
      .node-cs  { font-family: monospace; font-weight: 700; color: #e6edf3; font-size: .85rem; }
      .node-loc { font-size: .7rem; color: #6e7681; margin-top: .05rem; }
      .node-freq { font-size: .68rem; color: #8b949e; font-family: monospace; margin-top: .1rem; }
      .node-freq .freq-val { color: #c9d1d9; }
      .node-freq .freq-offset { color: #6e7681; }
      .node-desc { font-size: .65rem; color: #6e7681; font-style: italic; margin-top: .1rem; max-width: 180px; white-space: normal; line-height: 1.2; }

      /* ── Tone cell ───────────────────────────────────────────────────────── */
      .tone-pill {
        display: inline-block;
        background: #1a3a52;
        border: 1px solid #1f6feb;
        border-radius: .25em;
        padding: .1em .5em;
        font-family: monospace;
        font-weight: 700;
        font-size: .78rem;
        color: #79c0ff;
      }
      .tone-pill .tone-unit { color: #4a7fa5; font-size: .65rem; font-weight: 400; }
      .tone-pill.local { background: #21262d; border-color: #30363d; color: #8b949e; }
      .tone-pill.local .tone-unit { color: #6e7681; }

      /* ── Empty cell ──────────────────────────────────────────────────────── */
      .empty-cell { color: #30363d; font-size: .9rem; }
  %body.text-ghtext

    = render 'shared/navbar', active: 'tg', ws_indicator: true

    .px-3.md:px-4

      - if @fetch_error
        .flex.items-center.p-3.rounded-lg.mb-3{class: "bg-yellow-900/30 border border-yellow-700 text-yellow-400", role: "alert"}
          %i.bi.bi-exclamation-triangle-fill.mr-2.shrink-0
          = @fetch_error

      .page-header
        %i.bi.bi-diagram-3.mr-1
        Talkgroups
        %span.ml-1.font-normal
          = "#{@tgs_db.size} talkgroup#{'s' unless @tgs_db.size == 1}"

      .rounded-lg.border.border-ghborder.overflow-hidden
        %table.w-full.text-sm
          %thead
            %tr.bg-ghcard
              %th.text-left.px-4.py-3.text-xs.uppercase.tracking-wider.text-ghdim.font-semibold{style: "width:80px"} TG
              %th.text-left.px-4.py-3.text-xs.uppercase.tracking-wider.text-ghdim.font-semibold Name
              %th.text-left.px-4.py-3.text-xs.uppercase.tracking-wider.text-ghdim.font-semibold Description
              %th.text-left.px-4.py-3.text-xs.uppercase.tracking-wider.text-ghdim.font-semibold Nodes
              %th.text-left.px-4.py-3.text-xs.uppercase.tracking-wider.text-ghdim.font-semibold Routing
          %tbody
            - all_tgs = @tgs_db.map { |t| { tg: t.tg.to_i, name: t.name, description: t.description.to_s, kind: t.respond_to?(:kind) ? t.kind : nil } }
            - cluster_defined = all_tgs.map { |t| t[:tg] }
            - @cluster_tgs.each do |ctg|
              - next if cluster_defined.include?(ctg.to_i)
              - all_tgs << { tg: ctg.to_i, name: "Cluster TG #{ctg}", description: "Network-wide cluster talkgroup", kind: 'cluster' }
            - if all_tgs.empty?
              %tr
                %td.text-gray-500.text-sm.py-6.text-center{colspan: 5}
                  %i.bi.bi-info-circle.mr-1
                  No talkgroups defined yet.
            - else
              - all_tgs.sort_by { |t| t[:tg].to_s }.each do |tg_rec|
                - tg_num = tg_rec[:tg]
                - nodes_on_tg = @tg_nodes[tg_num] || []
                %tr.border-t.border-ghborder2.hover:bg-ghcard
                  %td.px-4.py-3.font-mono.font-bold.text-gray-100= tg_num
                  %td.px-4.py-3.text-gray-300
                    = tg_rec[:name]
                    - if tg_rec[:kind] == 'cluster' || @cluster_tgs.include?(tg_num)
                      %span.text-xs.px-1.5.py-0.5.rounded-full.border.font-mono.ml-2{class: "bg-cyan-900/30 text-cyan-400 border-cyan-700"} cluster
                  %td.px-4.py-3.text-sm.text-gray-400= tg_rec[:description]
                  %td.px-4.py-3
                    - if nodes_on_tg.any?
                      .flex.flex-wrap.gap-1
                        - nodes_on_tg.sort_by { |n| n[:callsign] }.each do |entry|
                          - node = entry[:node]
                          - qth = node.dig('qth', 0) || {}
                          - rx_info = qth['rx']&.values&.first || {}
                          - tx_info = qth['tx']&.values&.first || {}
                          - rx_freq = rx_info['freq']
                          - tx_freq = tx_info['freq']
                          - rx_name = rx_info['name'].presence || tx_info['name'].presence
                          - tip_parts = []
                          - tip_parts << rx_name if rx_name
                          - tip_parts << node['nodeLocation'] if node['nodeLocation'].present? && node['nodeLocation'] != rx_name
                          - if tx_freq.to_f > 0
                            - tip_parts << "TX #{"%.4f" % tx_freq} MHz"
                            - if rx_freq.to_f > 0
                              - offset_khz = ((rx_freq - tx_freq) * 1000).round
                              - tip_parts << "Shift #{offset_khz > 0 ? '+' : ''}#{offset_khz} kHz" if offset_khz != 0
                          - ttg = node['toneToTalkgroup'] || {}
                          - tone_for_tg = ttg.find { |_, tg| tg == tg_num }&.first
                          - tip_parts << "CTCSS #{tone_for_tg.to_f.round(1)} Hz" if tone_for_tg
                          - tip = tip_parts.any? ? tip_parts.join(' · ') : (entry[:selected] ? "Selected on TG #{tg_num}" : "Monitoring TG #{tg_num}")
                          - if entry[:selected]
                            %span.inline-block.px-2.py-0.5.text-xs.font-mono.rounded.border.border-green-700.text-green-400{class: "bg-green-900/30", title: tip}= entry[:callsign]
                          - else
                            %span.inline-block.px-2.py-0.5.text-xs.font-mono.rounded.border.border-ghborder2.text-gray-400{title: tip}= entry[:callsign]
                    - else
                      %span.text-ghdim —
                  %td.px-4.py-3
                    - route = @route_for.call(tg_num)
                    - if route[:css]
                      - if route[:url]
                        %a.text-xs.px-1.5.py-0.5.rounded-full.border.font-mono.hover:brightness-125.transition{class: route[:css], href: route[:url], target: "_blank", rel: "noopener"}= route[:label]
                      - else
                        %span.text-xs.px-1.5.py-0.5.rounded-full.border.font-mono{class: route[:css]}= route[:label]
                    - else
                      %span.text-xs.text-ghmuted= route[:label]

    - nodes_json = @nodes.to_json.html_safe
    - db_tgs = @tgs_db.map { |t| { tg: t.tg.to_i, name: t.name, description: t.description.to_s } }
    - db_tg_nums = db_tgs.map { |t| t[:tg] }
    - @cluster_tgs.each { |ctg| db_tgs << { tg: ctg.to_i, name: "Cluster TG #{ctg}", description: "Network-wide cluster talkgroup" } unless db_tg_nums.include?(ctg.to_i) }
    - tgs_db_json = db_tgs.sort_by { |t| t[:tg] }.to_json.html_safe
    :javascript
      var _tgNodes = #{nodes_json};
      var _tgsDb   = #{tgs_db_json};

      (function () {
        'use strict';

        function esc(s) {
          return String(s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        function rebuildMatrix(allNodes) {
          var table = document.querySelector('.matrix-table:not(#tg-map-table)');
          if (!table) return;
          var thead = table.querySelector('thead tr');
          var tbody = table.querySelector('tbody');
          if (!thead || !tbody) return;

          var allTgSet = {};
          var rows = [];
          Object.keys(allNodes).sort().forEach(function (cs) {
            var node = allNodes[cs];
            if (node.hidden) return;
            var ttg = node.toneToTalkgroup || {};
            var tgTone = {};
            Object.keys(ttg).forEach(function (toneStr) {
              var tgNum = ttg[toneStr];
              allTgSet[tgNum] = true;
              tgTone[tgNum] = parseFloat(toneStr);
            });
            if (Object.keys(tgTone).length > 0) rows.push({ cs: cs, node: node, tgTone: tgTone });
          });

          var allTgs = Object.keys(allTgSet).map(Number).sort(function (a, b) { return a - b; });

          // Rebuild thead: keep Node column, replace TG columns
          while (thead.children.length > 1) thead.removeChild(thead.lastChild);
          allTgs.forEach(function (tg) {
            var th = document.createElement('th');
            var span = document.createElement('span');
            span.className = 'tg-col-head' + (tg === 0 ? ' local' : '');
            span.textContent = tg === 0 ? 'Local' : tg;
            th.appendChild(span);
            thead.appendChild(th);
          });

          // Rebuild tbody
          tbody.innerHTML = '';
          if (rows.length === 0) {
            var tr = document.createElement('tr');
            var td = document.createElement('td');
            td.colSpan = allTgs.length + 1;
            td.className = 'text-gray-500 text-sm py-4 text-center';
            td.innerHTML = '<i class="bi bi-info-circle mr-1"></i>No tone-to-TG mapping data found.';
            tr.appendChild(td);
            tbody.appendChild(tr);
            return;
          }

          rows.forEach(function (row) {
            var tr = document.createElement('tr');
            var nodeTd = document.createElement('td');
            nodeTd.className = 'col-node';
            var nodeHtml = '<div class="node-cs">' + esc(row.cs) + '</div>' +
              (row.node.nodeLocation ? '<div class="node-loc">' + esc(row.node.nodeLocation) + '</div>' : '');
            var qth = row.node.qth && row.node.qth[0];
            var txFreq = qth && qth.tx && Object.values(qth.tx)[0] && Object.values(qth.tx)[0].freq;
            var rxFreq = qth && qth.rx && Object.values(qth.rx)[0] && Object.values(qth.rx)[0].freq;
            if (txFreq && txFreq > 0) {
              var offset = (rxFreq && rxFreq > 0) ? Math.round((rxFreq - txFreq) * 1000) : null;
              nodeHtml += '<div class="node-freq">TX <span class="freq-val">' + txFreq.toFixed(4) + '</span> MHz';
              if (offset && offset !== 0) nodeHtml += ' <span class="freq-offset">(' + (offset > 0 ? '+' : '') + offset + ' kHz)</span>';
              nodeHtml += '</div>';
            }
            nodeTd.innerHTML = nodeHtml;
            tr.appendChild(nodeTd);
            allTgs.forEach(function (tg) {
              var td = document.createElement('td');
              var tone = row.tgTone[tg];
              if (tone !== undefined) {
                var pill = document.createElement('span');
                pill.className = 'tone-pill' + (tg === 0 ? ' local' : '');
                pill.innerHTML = tone.toFixed(1) + '<span class="tone-unit"> Hz</span>';
                td.appendChild(pill);
              } else {
                td.innerHTML = '<span class="empty-cell">\u00B7</span>';
              }
              tr.appendChild(td);
            });
            tbody.appendChild(tr);
          });
        }

        function rebuildTgMap(allNodes) {
          var table = document.getElementById('tg-map-table');
          if (!table || !_tgsDb || _tgsDb.length === 0) return;
          var thead = table.querySelector('thead tr');
          var tbody = table.querySelector('tbody');
          if (!thead || !tbody) return;

          // Build all visible nodes
          var visibleNodes = [];
          Object.keys(allNodes).sort().forEach(function (cs) {
            var node = allNodes[cs];
            if (node.hidden) return;
            visibleNodes.push({ cs: cs, node: node });
          });

          // Rebuild thead: TG column + one per visible node
          while (thead.children.length > 1) thead.removeChild(thead.lastChild);
          visibleNodes.forEach(function (row) {
            var th = document.createElement('th');
            th.innerHTML = '<div class="node-cs" style="font-size:.75rem;">' + esc(row.cs) + '</div>';
            thead.appendChild(th);
          });

          // Rebuild tbody: one row per DB talkgroup
          tbody.innerHTML = '';

          _tgsDb.forEach(function (tgRec) {
            var tr = document.createElement('tr');
            var nodeTd = document.createElement('td');
            nodeTd.className = 'col-node';
            nodeTd.innerHTML = '<div class="node-cs">' + esc(tgRec.tg) + '</div>' +
              '<div class="node-loc">' + esc(tgRec.name) + '</div>' +
              (tgRec.description ? '<div class="node-desc">' + esc(tgRec.description) + '</div>' : '');
            tr.appendChild(nodeTd);

            if (visibleNodes.length === 0) {
              var td = document.createElement('td');
              td.innerHTML = '<span class="empty-cell">\u00B7</span>';
              tr.appendChild(td);
            } else {
              visibleNodes.forEach(function (row) {
                var td = document.createElement('td');
                var ttg = row.node.toneToTalkgroup || {};
                var tone;
                Object.keys(ttg).forEach(function (toneStr) {
                  if (ttg[toneStr] === tgRec.tg) tone = parseFloat(toneStr);
                });
                var onTg = (row.node.tg || 0) === tgRec.tg || (row.node.monitoredTGs || []).indexOf(tgRec.tg) !== -1;
                if (tone !== undefined) {
                  var pill = document.createElement('span');
                  pill.className = 'tone-pill';
                  pill.innerHTML = tone.toFixed(1) + '<span class="tone-unit"> Hz</span>';
                  td.appendChild(pill);
                } else if (onTg) {
                  td.innerHTML = '<i class="bi bi-link-45deg text-green-500 text-lg" title="Connected to TG ' + tgRec.tg + '"></i>';
                } else {
                  td.innerHTML = '<span class="empty-cell">\u00B7</span>';
                }
                tr.appendChild(td);
              });
            }
            tbody.appendChild(tr);
          });
        }

        function setWs(state) {
          var color = state === 'connected' ? 'text-green-500' : state === 'disconnected' ? 'text-red-500' : 'text-yellow-500';
          var title = state === 'connected' ? 'Live' : state === 'disconnected' ? 'Disconnected' : 'Connecting\u2026';
          var pulse = state === 'connecting' ? 'animate-pulse' : '';
          document.querySelectorAll('.js-ws-icon').forEach(function(el) {
            el.className = 'bi bi-broadcast-pin js-ws-icon text-lg ' + color + (pulse ? ' ' + pulse : '');
            el.title = title;
          });
        }

        function connectTgWs() {
          if (window._pageWs) { window._pageWs.onclose = null; window._pageWs.close(); }
          setWs('connecting');
          var proto = location.protocol === 'https:' ? 'wss' : 'ws';
          var ws = new WebSocket(proto + '://' + location.host + '/cable');
          window._pageWs = ws;
          ws.onopen = function () {
            ws.send(JSON.stringify({ command: 'subscribe', identifier: JSON.stringify({ channel: 'UpdatesChannel' }) }));
          };
          ws.onmessage = function (ev) {
            var envelope;
            try { envelope = JSON.parse(ev.data); } catch (e) { return; }
            if (envelope.type === 'welcome')              { setWs('connected'); return; }
            if (envelope.type === 'ping')                 { return; }
            if (envelope.type === 'confirm_subscription') { return; }
            var msg = envelope.message;
            if (!msg || !msg.nodes) return;
            _tgNodes = msg.nodes;
            rebuildMatrix(msg.nodes);
            rebuildTgMap(msg.nodes);
            if (window.audioPlayerUpdateTgs) window.audioPlayerUpdateTgs(msg.nodes);
          };
          ws.onclose = function () { setWs('disconnected'); setTimeout(connectTgWs, 5000); };
          ws.onerror = function () { setWs('disconnected'); };
        }
        connectTgWs();
      })();
