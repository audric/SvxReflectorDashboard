!!!
%html{lang: "en"}
  :javascript
    (function(){var t=localStorage.getItem('theme')||'auto';var r=(t==='auto'?(window.matchMedia('(prefers-color-scheme:light)').matches?'light':'auto'):t);document.documentElement.setAttribute('data-theme',r);})();
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title= "SVXReflector #{@reflector_host} · Trunks"
    %script{src: "/vendor/tailwind/tailwind.js"}
    :javascript
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ghbg: '#0d1117',
              ghcard: '#161b22',
              ghborder: '#30363d',
              ghborder2: '#21262d',
              ghtext: '#c9d1d9',
              ghmuted: '#8b949e',
              ghdim: '#6e7681',
            }
          }
        }
      }
    %link{rel: "stylesheet", href: "/vendor/bootstrap-icons/font/bootstrap-icons.min.css"}
    :css
      body { background: #0d1117; }
      .page-header {
        display: flex; align-items: center; gap: .75rem;
        padding: 1rem 0 .75rem;
        font-size: .7rem; text-transform: uppercase; letter-spacing: .08em;
        color: #6e7681; font-weight: 600;
      }
      .page-header::after { content: ''; flex: 1; height: 1px; background: #21262d; }
      .trunk-tab.active { background: #1f3a5f; color: #79c0ff; }
      .event-type-badge {
        display: inline-flex; align-items: center; gap: .25rem;
        font-size: .68rem; font-weight: 600; text-transform: uppercase;
        letter-spacing: .04em; padding: .15em .55em; border-radius: .25em;
        white-space: nowrap;
      }

  %body.text-ghtext

    = render 'shared/navbar', active: 'trunks'

    .px-3.md:px-4

      .flex.items-center.justify-between.mb-4
        .page-header.mb-0
          %i.bi.bi-diagram-3.mr-1
          Trunks
        .inline-flex.rounded.border.border-ghborder.overflow-hidden
          %button.trunk-tab.px-3.py-1.text-xs.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors{type: "button", "data-tab" => "list", onclick: "switchTrunkTab('list')"}
            %i.bi.bi-list-ul.mr-1
            List
          %button.trunk-tab.px-3.py-1.text-xs.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors.border-l.border-ghborder{type: "button", "data-tab" => "topology", onclick: "switchTrunkTab('topology')"}
            %i.bi.bi-share.mr-1
            Topology

      #trunk-tab-topology.hidden
        - local_host = @reflector_host || ENV['DOMAIN'] || 'this reflector'
        - local_prefix = @local_prefix || @reflector_config&.dig('local_prefix')
        - local_prefix_str = Array(local_prefix).flatten.flat_map { |x| x.to_s.split(',') }.map(&:strip).join(', ')
        - local_ext_host = Setting.get('reflector_ext_host', ENV.fetch('REFLECTOR_EXT_HOST', ''))
        - sat_parent_host = @reflector_mode == 'satellite' ? (@reflector_config.dig('satellite', 'parent_host') || @reflector_config.dig('satellite', 'host')) : nil
        :javascript
          (function() {
            var localHost = #{local_ext_host.present? ? local_ext_host.to_json : local_host.to_json};
            var localExtHost = #{local_host.to_json};
            var localPrefix = #{local_prefix_str.to_json};
            var trunksData = #{@trunks.to_json};
            var localTrunks = #{@local_trunks.to_json};
            var remoteConfigs = #{@remote_configs.to_json};
            var satelliteMode = #{(@reflector_mode == 'satellite').to_json};
            var satelliteParentHost = #{sat_parent_host.to_json};
            var satellitesData = #{@satellites.to_json};

            // Check if a hostname refers to our local reflector
            function isLocalHost(h) {
              if (!h) return false;
              if (h === localHost) return true;
              if (localExtHost && h === localExtHost) return true;
              return false;
            }

            function drawTopology() {
              var container = document.getElementById('topology-canvas');
              if (!container) return;
              var width = container.clientWidth || 800;

              // ── Build all reflector nodes (local + peers) ──
              var allNodes = []; // {id, host, prefix, isLocal, nodeCount}
              var localId = '__local__';
              allNodes.push({
                id: localId,
                host: localHost,
                prefix: localPrefix,
                isLocal: true,
                nodeCount: null
              });

              Object.keys(localTrunks).forEach(function(name) {
                var cfg = localTrunks[name] || {};
                var remote = remoteConfigs[name] || {};
                var live = trunksData[name] || {};
                var rPrefix = remote.local_prefix || live.remote_prefix || [];
                var host = cfg.HOST || live.host || name;
                // Deduplicate by host (skip if it's us or already listed)
                if (!isLocalHost(host) && !allNodes.some(function(n) { return n.host === host; })) {
                  allNodes.push({
                    id: host,
                    host: host,
                    prefix: Array.isArray(rPrefix) ? rPrefix.join(', ') : String(rPrefix),
                    isLocal: false,
                    nodeCount: remote.nodes ? Object.keys(remote.nodes).length : null
                  });
                }
              });

              // In satellite mode, add the parent as a peer
              if (satelliteMode && satelliteParentHost) {
                if (!allNodes.some(function(n) { return n.host === satelliteParentHost; })) {
                  allNodes.push({
                    id: satelliteParentHost,
                    host: satelliteParentHost,
                    prefix: '',
                    isLocal: false,
                    nodeCount: null,
                    isParent: true
                  });
                }
              }

              if (allNodes.length <= 1) {
                container.innerHTML = '<div class="text-center text-ghmuted py-8"><i class="bi bi-diagram-3 block text-2xl mb-2"></i>No trunk peers configured.</div>';
                return;
              }

              // ── Build edges: all trunk links between all pairs ──
              // An edge = {from: hostA, to: hostB, name, outA: bool, outB: bool}
              // From local to each peer: we know outbound/inbound from trunksData
              var edges = [];
              var edgeKey = function(a, b) { return a < b ? a + '|' + b : b + '|' + a; };
              var edgeMap = {}; // dedup

              Object.keys(localTrunks).forEach(function(name) {
                var cfg = localTrunks[name] || {};
                var live = trunksData[name] || {};
                var peerHost = cfg.HOST || live.host || name;
                var key = edgeKey(localHost, peerHost);
                if (!edgeMap[key]) {
                  edgeMap[key] = {
                    fromHost: localHost, toHost: peerHost, name: name,
                    outFromA: !!live.outbound_connected, outFromB: !!live.inbound_connected
                  };
                }
              });

              // Satellite → parent edge
              if (satelliteMode && satelliteParentHost) {
                var key = edgeKey(localHost, satelliteParentHost);
                if (!edgeMap[key]) {
                  edgeMap[key] = {
                    fromHost: localHost, toHost: satelliteParentHost, name: 'satellite',
                    outFromA: true, outFromB: true, isSatellite: true
                  };
                }
              }

              // Parent: add connected satellites as nodes
              if (!satelliteMode && satellitesData) {
                Object.keys(satellitesData).forEach(function(satId) {
                  var sat = satellitesData[satId] || {};
                  allNodes.push({
                    id: 'sat_' + satId,
                    host: satId,
                    prefix: '',
                    isLocal: false,
                    nodeCount: null,
                    isSatellite: true
                  });
                  var key = edgeKey(localHost, satId);
                  if (!edgeMap[key]) {
                    edgeMap[key] = {
                      fromHost: localHost, toHost: satId, name: 'satellite',
                      outFromA: !!sat.authenticated, outFromB: !!sat.authenticated, isSatellite: true
                    };
                  }
                });
              }

              // From each remote peer's trunk list, find links between peers
              Object.keys(remoteConfigs).forEach(function(trunkName) {
                var remote = remoteConfigs[trunkName] || {};
                var cfg = localTrunks[trunkName] || {};
                var peerHost = cfg.HOST || (trunksData[trunkName] || {}).host || trunkName;
                var remoteTrunks = remote.trunks || {};

                Object.keys(remoteTrunks).forEach(function(rName) {
                  var rt = remoteTrunks[rName];
                  if (!rt || typeof rt !== 'object') return;
                  var targetHost = rt.host;
                  if (!targetHost) return;
                  // Normalize: if target is our reflector, use canonical local name
                  var resolvedTarget = isLocalHost(targetHost) ? localHost : targetHost;
                  var key = edgeKey(peerHost, resolvedTarget);
                  if (edgeMap[key]) return;
                  edgeMap[key] = {
                    fromHost: peerHost, toHost: resolvedTarget, name: rName,
                    outFromA: !!rt.outbound_connected, outFromB: !!rt.inbound_connected
                  };
                  // Ensure target node exists (skip if it's us)
                  if (!isLocalHost(targetHost) && !allNodes.some(function(n) { return n.host === resolvedTarget; })) {
                    var rPrefix = rt.remote_prefix || [];
                    allNodes.push({
                      id: resolvedTarget, host: resolvedTarget,
                      prefix: Array.isArray(rPrefix) ? rPrefix.join(', ') : String(rPrefix),
                      isLocal: false, nodeCount: null
                    });
                  }
                });
              });

              edges = Object.keys(edgeMap).map(function(k) { return edgeMap[k]; });

              // ── Measure node widths based on text content ──
              var charW = 7.2; // approx monospace char width at font-size 12
              var padding = 30;
              var nodeH = 70;
              allNodes.forEach(function(nd) {
                var hostLen = nd.host.length * charW;
                var prefixLen = nd.prefix ? ('prefix: ' + nd.prefix).length * (charW * 10/12) : 0;
                nd.w = Math.max(140, Math.ceil(Math.max(hostLen, prefixLen) + padding));
              });
              var nodeW = Math.max.apply(null, allNodes.map(function(nd) { return nd.w; }));

              // ── Layout: all nodes on a circle ──
              var gap = 40;
              var n = allNodes.length;
              var minArc = nodeW + gap;
              var minRadius = n <= 2 ? 160 : Math.max(160, (n * minArc) / (2 * Math.PI));
              var maxRadius = (width / 2) - nodeW / 2 - 20;
              var radius = Math.min(minRadius, maxRadius);
              var neededWidth = (radius + nodeW / 2 + 20) * 2;
              if (neededWidth > width) width = neededWidth;

              var cxC = width / 2;
              var cyC = radius + nodeH / 2 + 40;
              var svgH = cyC * 2 + 30;

              // Position each node on the circle, store width for edge clipping
              var positions = {};
              var nodeWidths = {};
              allNodes.forEach(function(nd, i) {
                var angle = -Math.PI / 2 + (2 * Math.PI * i / n);
                positions[nd.host] = { x: cxC + radius * Math.cos(angle), y: cyC + radius * Math.sin(angle) };
                nodeWidths[nd.host] = nd.w;
              });

              var svg = '<svg xmlns="http://www.w3.org/2000/svg" width="' + width + '" height="' + svgH + '" style="font-family: ui-monospace, monospace;">';

              // Arrow markers
              svg += '<defs>';
              ['green','orange','red'].forEach(function(c) {
                var fill = c === 'green' ? '#22c55e' : (c === 'orange' ? '#f97316' : '#ef4444');
                svg += '<marker id="arr-' + c + '" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto"><path d="M0,0 L8,3 L0,6" fill="' + fill + '"/></marker>';
                svg += '<marker id="arr-' + c + '-r" markerWidth="8" markerHeight="6" refX="0" refY="3" orient="auto"><path d="M8,0 L0,3 L8,6" fill="' + fill + '"/></marker>';
              });
              svg += '</defs>';

              // ── Draw edges (pass 1: lines) ──
              var labels = []; // collect labels for de-overlap
              edges.forEach(function(e) {
                var posA = positions[e.fromHost];
                var posB = positions[e.toHost];
                if (!posA || !posB) return;

                var dx = posB.x - posA.x, dy = posB.y - posA.y;
                var dist = Math.sqrt(dx * dx + dy * dy);
                if (dist === 0) return;
                var ux = dx / dist, uy = dy / dist;

                // Clip line to rectangle edge (proper ray-box intersection)
                function clipToBox(cx, cy, hw, hh, tux, tuy) {
                  // Find t where ray from (cx,cy) in direction (tux,tuy) hits the box edge
                  var tx = tux !== 0 ? hw / Math.abs(tux) : Infinity;
                  var ty = tuy !== 0 ? hh / Math.abs(tuy) : Infinity;
                  var t = Math.min(tx, ty) + 12; // margin so arrow tips clear the box
                  return { x: cx + tux * t, y: cy + tuy * t };
                }
                var hwA = (nodeWidths[e.fromHost] || nodeW) / 2;
                var hwB = (nodeWidths[e.toHost] || nodeW) / 2;
                var hhA = nodeH / 2, hhB = nodeH / 2;
                var ptA = clipToBox(posA.x, posA.y, hwA, hhA, ux, uy);
                var ptB = clipToBox(posB.x, posB.y, hwB, hhB, -ux, -uy);
                var ax = ptA.x, ay = ptA.y;
                var bx = ptB.x, by = ptB.y;

                var bothOk = e.outFromA && e.outFromB;
                var oneOk = e.outFromA || e.outFromB;
                var lineColor = bothOk ? '#22c55e' : (oneOk ? '#f97316' : '#ef4444');
                var colorName = bothOk ? 'green' : (oneOk ? 'orange' : 'red');

                // Perpendicular offset for two parallel arrows
                var px = -uy * 4, py = ux * 4;

                // A→B arrow
                var abColor = e.outFromA ? lineColor : '#ef4444';
                var abMark = e.outFromA ? colorName : 'red';
                svg += '<line x1="' + (ax+px) + '" y1="' + (ay+py) + '" x2="' + (bx+px) + '" y2="' + (by+py) + '" stroke="' + abColor + '" stroke-width="1.5" marker-end="url(#arr-' + abMark + ')" opacity="0.6"/>';

                // B→A arrow
                var baColor = e.outFromB ? lineColor : '#ef4444';
                var baMark = e.outFromB ? colorName : 'red';
                svg += '<line x1="' + (bx-px) + '" y1="' + (by-py) + '" x2="' + (ax-px) + '" y2="' + (ay-py) + '" stroke="' + baColor + '" stroke-width="1.5" marker-end="url(#arr-' + baMark + ')" opacity="0.6"/>';

                // Collect label for de-overlap pass
                var shortName = e.name.replace(/^TRUNK_/, '');
                var lblW = shortName.length * 6 + 10;
                var lblH = 14;
                labels.push({ ax: ax, ay: ay, bx: bx, by: by, t: 0.5, text: shortName, w: lblW, h: lblH, color: lineColor });
              });

              // ── De-overlap labels ──
              // Try sliding labels along their edge (t: 0.2–0.8) to resolve overlaps
              function lblRect(l) {
                var x = l.ax + (l.bx - l.ax) * l.t;
                var y = l.ay + (l.by - l.ay) * l.t;
                return { x: x - l.w/2, y: y - l.h/2, w: l.w, h: l.h, cx: x, cy: y };
              }
              function overlaps(a, b) {
                return !(a.x + a.w < b.x || b.x + b.w < a.x || a.y + a.h < b.y || b.y + b.h < a.y);
              }
              for (var pass = 0; pass < 20; pass++) {
                var moved = false;
                for (var i = 0; i < labels.length; i++) {
                  var ri = lblRect(labels[i]);
                  for (var j = i + 1; j < labels.length; j++) {
                    var rj = lblRect(labels[j]);
                    if (overlaps(ri, rj)) {
                      // Nudge both labels away from each other along their edges
                      labels[i].t = Math.max(0.15, labels[i].t - 0.08);
                      labels[j].t = Math.min(0.85, labels[j].t + 0.08);
                      moved = true;
                    }
                  }
                }
                if (!moved) break;
              }

              // ── Draw labels ──
              labels.forEach(function(l) {
                var r = lblRect(l);
                svg += '<rect x="' + r.x + '" y="' + r.y + '" width="' + r.w + '" height="' + r.h + '" rx="3" fill="#0d1117" opacity="0.9"/>';
                svg += '<text x="' + r.cx + '" y="' + (r.cy + 3.5) + '" text-anchor="middle" fill="' + l.color + '" font-size="8" font-weight="600">' + l.text.replace(/</g, '&lt;') + '</text>';
              });

              // ── Draw nodes ──
              allNodes.forEach(function(nd) {
                var pos = positions[nd.host];
                var bx = pos.x, by = pos.y;
                var w = nd.w;
                var isSatOrParent = nd.isSatellite || nd.isParent;
                var stroke = nd.isLocal ? '#58a6ff' : (isSatOrParent ? '#a855f7' : '#6e7681');
                var strokeW = nd.isLocal || isSatOrParent ? 2 : 1.5;
                var hostColor = nd.isLocal ? '#58a6ff' : (isSatOrParent ? '#a855f7' : '#c9d1d9');

                svg += '<rect x="' + (bx - w/2) + '" y="' + (by - nodeH/2) + '" width="' + w + '" height="' + nodeH + '" rx="8" fill="#161b22" stroke="' + stroke + '" stroke-width="' + strokeW + '"/>';
                svg += '<a href="https://' + encodeURI(nd.host) + '" target="_blank" rel="noopener">';
                svg += '<text x="' + bx + '" y="' + (by - 8) + '" text-anchor="middle" fill="' + hostColor + '" font-size="12" font-weight="700" style="cursor:pointer"><title>https://' + nd.host.replace(/</g, '&lt;') + '</title>' + nd.host.replace(/</g, '&lt;') + '</text>';
                svg += '</a>';
                if (nd.prefix) {
                  svg += '<text x="' + bx + '" y="' + (by + 10) + '" text-anchor="middle" fill="#8b949e" font-size="10">prefix: ' + nd.prefix.replace(/</g, '&lt;') + '</text>';
                }
                if (nd.isLocal) {
                  svg += '<text x="' + bx + '" y="' + (by + 25) + '" text-anchor="middle" fill="#6e7681" font-size="9" font-style="italic">' + (satelliteMode ? 'SATELLITE' : 'LOCAL') + '</text>';
                } else if (nd.isParent) {
                  svg += '<text x="' + bx + '" y="' + (by + 25) + '" text-anchor="middle" fill="#a855f7" font-size="9" font-style="italic">PARENT</text>';
                } else if (nd.isSatellite) {
                  svg += '<text x="' + bx + '" y="' + (by + 25) + '" text-anchor="middle" fill="#a855f7" font-size="9" font-style="italic">SATELLITE</text>';
                } else if (nd.nodeCount !== null) {
                  svg += '<text x="' + bx + '" y="' + (by + 25) + '" text-anchor="middle" fill="#6e7681" font-size="9">' + nd.nodeCount + ' node' + (nd.nodeCount !== 1 ? 's' : '') + '</text>';
                }
              });

              svg += '</svg>';
              container.innerHTML = svg;
              container.style.overflowX = width > container.parentElement.clientWidth ? 'auto' : 'hidden';
            }

            // Expose for live updates
            window._topoTrunksData = trunksData;
            window._topoRemoteConfigs = remoteConfigs;
            window._drawTopology = drawTopology;

            // Initial draw (deferred so container is visible)
            setTimeout(drawTopology, 50);

            // Redraw on resize
            window.addEventListener('resize', drawTopology);
          })();

        #topology-canvas.w-full.rounded-lg.border.border-ghborder.bg-ghcard.p-4{style: "min-height: 300px"}

      #trunk-tab-list

      - if @reflector_mode == 'satellite'
        - parent_host = @reflector_config.dig('satellite', 'parent_host') || @reflector_config.dig('satellite', 'host') || 'parent reflector'
        - parent_port = @reflector_config.dig('satellite', 'parent_port') || '5303'
        - sat_id = @reflector_config.dig('satellite', 'id') || ''
        .flex.items-center.gap-3.px-4.py-2.5.rounded-lg.border.mb-4{class: "bg-purple-900/20 border-purple-700/50"}
          .flex.items-center.justify-center.w-8.h-8.rounded-full.shrink-0{class: "bg-purple-800/50"}
            %i.bi.bi-broadcast.text-purple-400
          .flex-1.min-w-0
            .flex.items-center.gap-2.flex-wrap
              %span.text-purple-300.font-semibold.text-sm Satellite Mode
              - if sat_id.present?
                %span.text-xs.px-1.5.py-0.5.rounded.border.font-mono{class: "bg-purple-900/50 text-purple-400 border-purple-700"}= sat_id
            .text-xs.text-ghmuted.mt-0.5
              Connected to
              %span.font-mono.text-purple-300= parent_host
              %span.text-ghdim= ":#{parent_port}"
            %p.text-purple-300.text-xs.mt-1 This reflector is operating as a satellite. Trunk management is handled by the parent reflector.

      - else
        -# ── Local Trunk Configuration ────────────────────────────────────────
        .page-header.mb-3
          %i.bi.bi-gear.mr-1
          Local Configuration

        - if @reflector_config['version'].present? || @local_prefix.present? || @cluster_tgs.any?
          .mb-3
            - if @reflector_config['version'].present?
              %span.text-xs.text-ghmuted Version:
              %span.text-xs.font-mono.text-gray-300.ml-1= @reflector_config['version']
            - if @local_prefix.present?
              %span.text-xs.text-ghmuted{class: @reflector_config['version'].present? ? 'ml-3' : ''} LOCAL_PREFIX:
              %span.text-xs.font-mono.text-cyan-400.ml-1= @local_prefix
            - if @cluster_tgs.any?
              %span.text-xs.text-ghmuted.ml-3 CLUSTER_TGS:
              %span.text-xs.font-mono.text-cyan-400.ml-1= @cluster_tgs.join(', ')

        - if @local_trunks.any?
          .grid.grid-cols-1.md:grid-cols-2.xl:grid-cols-3.gap-3.mb-4
            - @local_trunks.each do |name, cfg|
              - live = @trunks[name]
              - connected = live && live['connected']
              .rounded-lg.border.border-ghborder.p-4
                .flex.items-center.gap-2.mb-3
                  - if connected
                    %span.inline-block.w-2.5.h-2.5.rounded-full.bg-green-500{title: "Outbound Connected"}
                  - elsif live
                    %span.inline-block.w-2.5.h-2.5.rounded-full.bg-red-500{title: "Outbound Disconnected"}
                  - else
                    %span.inline-block.w-2.5.h-2.5.rounded-full.bg-gray-600{title: "Unknown"}
                  %span.font-mono.text-sm.font-semibold.text-gray-100= name
                  %span.ml-auto.text-xs.px-2.py-0.5.rounded-full.font-semibold{class: connected ? "bg-green-900/50 text-green-400 border border-green-700" : "bg-red-900/50 text-red-400 border border-red-700"}
                    = connected ? 'Outbound Connected' : 'Outbound Disconnected'
                .space-y-1.5
                  .flex.items-center.gap-2
                    %i.bi.bi-globe.text-ghdim{style: "font-size:.7rem"}
                    %span.text-xs.text-ghmuted Host
                    %a.text-xs.font-mono.text-gray-300.ml-auto.hover:text-blue-400.transition-colors{href: "https://#{cfg['HOST']}", target: "_blank", rel: "noopener"}= cfg['HOST']
                  .flex.items-center.gap-2
                    %i.bi.bi-hdd-network.text-ghdim{style: "font-size:.7rem"}
                    %span.text-xs.text-ghmuted Port
                    %span.text-xs.font-mono.text-gray-300.ml-auto= cfg['PORT'] || '5302'
                  - if cfg['REMOTE_PREFIX'].present?
                    .flex.items-center.gap-2
                      %i.bi.bi-tag.text-ghdim{style: "font-size:.7rem"}
                      %span.text-xs.text-ghmuted Remote Prefix
                      %span.text-xs.font-mono.text-cyan-400.ml-auto= cfg['REMOTE_PREFIX']

                -# Active talkers from live data
                - if connected && live['active_talkers'].present? && live['active_talkers'].any?
                  .mt-3.pt-3.border-t.border-ghborder2
                    .text-xs.text-ghmuted.mb-1.5
                      %i.bi.bi-mic-fill.mr-1{style: "font-size:.6rem"}
                      Active Talkers
                    .flex.flex-wrap.gap-1
                      - live['active_talkers'].each do |tg, cs|
                        %span.text-xs.px-1.5.py-0.5.rounded.font-mono{class: "bg-green-900/50 text-green-400 border border-green-700"}
                          %i.bi.bi-mic-fill.mr-1{style: "font-size:.55rem"}
                          = "#{cs} TG#{tg}"

                -# Remote reflector's view of this trunk
                - remote = @remote_configs[name]
                - if remote
                  .mt-3.pt-3.border-t.border-ghborder2
                    .flex.items-center.gap-2.mb-2
                      %i.bi.bi-arrow-left-right.text-cyan-400{style: "font-size:.7rem"}
                      %span.text-xs.text-cyan-400.font-semibold.uppercase Remote Peer View
                    - r_mode = remote['mode'] || 'reflector'
                    - r_trunks = remote['trunks'] || {}
                    - r_local_prefix = remote.dig('global', 'LOCAL_PREFIX') || remote['local_prefix']
                    - r_cluster_tgs = remote['cluster_tgs'] || []
                    .space-y-1.5
                      - if remote['version'].present?
                        .flex.items-center.gap-2
                          %i.bi.bi-code-square.text-ghdim{style: "font-size:.7rem"}
                          %span.text-xs.text-ghmuted Version
                          %span.text-xs.font-mono.text-gray-300.ml-auto= remote['version']
                      .flex.items-center.gap-2
                        %i.bi.bi-broadcast-pin.text-ghdim{style: "font-size:.7rem"}
                        %span.text-xs.text-ghmuted Mode
                        %span.text-xs.font-mono.text-gray-300.ml-auto= r_mode
                      - if r_local_prefix.present?
                        .flex.items-center.gap-2
                          %i.bi.bi-tag.text-ghdim{style: "font-size:.7rem"}
                          %span.text-xs.text-ghmuted Their Local Prefix
                          %span.text-xs.font-mono.text-cyan-400.ml-auto= Array(r_local_prefix).flatten.flat_map { |x| x.to_s.split(',') }.map(&:strip).join(', ')
                      - if r_cluster_tgs.any?
                        .flex.items-center.gap-2
                          %i.bi.bi-broadcast.text-ghdim{style: "font-size:.7rem"}
                          %span.text-xs.text-ghmuted Their Cluster TGs
                          %span.text-xs.font-mono.text-cyan-400.ml-auto= r_cluster_tgs.join(', ')

                    -# ── Prefix discrepancy checks ──────────────────────────────
                    - normalize_pfx = ->(v) { Array(v).flatten.flat_map { |x| x.to_s.split(',') }.map(&:strip).reject(&:blank?).sort }
                    - our_remote_pfx = normalize_pfx.(cfg['REMOTE_PREFIX'])
                    - their_local_pfx = normalize_pfx.(r_local_prefix)
                    - our_local_pfx = normalize_pfx.(@local_prefix)
                    - their_trunk_to_us = r_trunks.values.select { |t| t.is_a?(Hash) }.find { |t| our_local_pfx.any? && normalize_pfx.(t['remote_prefix']) == our_local_pfx }
                    - their_remote_pfx = their_trunk_to_us ? normalize_pfx.(their_trunk_to_us['remote_prefix']) : []
                    - warnings = []
                    - if their_local_pfx.any? && our_remote_pfx.any? && our_remote_pfx != their_local_pfx
                      - warnings << { label: "Our REMOTE_PREFIX for them", ours: our_remote_pfx.join(', '), theirs: their_local_pfx.join(', '), theirs_label: "their LOCAL_PREFIX" }
                    - if their_trunk_to_us && their_remote_pfx.any? && our_local_pfx.any? && their_remote_pfx != our_local_pfx
                      - warnings << { label: "Their REMOTE_PREFIX for us", ours: our_local_pfx.join(', '), theirs: their_remote_pfx.join(', '), theirs_label: "our LOCAL_PREFIX" }
                    - if their_local_pfx.any? && our_remote_pfx.blank?
                      - warnings << { label: "Our REMOTE_PREFIX is not set", ours: "(empty)", theirs: their_local_pfx.join(', '), theirs_label: "their LOCAL_PREFIX" }
                    - if !their_trunk_to_us && r_trunks.any?
                      - warnings << { label: "No trunk peer on their side points back to us", ours: our_local_pfx.any? ? our_local_pfx.join(', ') : '(not set)', theirs: '', theirs_label: '' }
                    - if warnings.any?
                      .mt-3.rounded.border.p-2.space-y-1.5{class: "border-yellow-700/50 bg-yellow-900/20"}
                        .flex.items-center.gap-1.5.mb-1
                          %i.bi.bi-exclamation-triangle-fill.text-yellow-500{style: "font-size:.7rem"}
                          %span.text-xs.font-semibold.text-yellow-400 Prefix Mismatch
                        - warnings.each do |w|
                          .text-xs.text-yellow-300
                            %span.font-semibold= w[:label]
                            - if w[:theirs].present?
                              = ": "
                              %span.font-mono= w[:ours]
                              %span.text-yellow-500 ≠
                              %span.font-mono= w[:theirs]
                              %span.text-yellow-500= "(#{w[:theirs_label]})"

                    - if r_trunks.any?
                      .mt-2
                        .text-xs.text-ghmuted.mb-1
                          %i.bi.bi-diagram-3.mr-1{style: "font-size:.6rem"}
                          Their Trunk Peers
                        - r_trunks.each do |r_name, r_trunk|
                          .flex.items-center.gap-2.py-1.text-xs
                            - r_connected = r_trunk.is_a?(Hash) ? r_trunk['connected'] : nil
                            - if r_connected == true
                              %span.inline-block.w-2.h-2.rounded-full.bg-green-500
                            - elsif r_connected == false
                              %span.inline-block.w-2.h-2.rounded-full.bg-red-500
                            - else
                              %span.inline-block.w-2.h-2.rounded-full.bg-gray-600
                            %span.font-mono.text-gray-300= r_name
                            - if r_trunk.is_a?(Hash) && r_trunk['host'].present?
                              %a.text-ghmuted.ml-auto.hover:text-blue-400.transition-colors{href: "https://#{r_trunk['host']}", target: "_blank", rel: "noopener"}= r_trunk['host']
                - elsif cfg['STATUS_URL'].present?
                  .mt-3.pt-3.border-t.border-ghborder2
                    .text-xs.text-ghmuted
                      %i.bi.bi-arrow-clockwise.text-gray-500.mr-1{style: "font-size:.65rem"}
                      Loading remote peer view...

        - else
          .rounded-lg.border.border-ghborder.p-6.text-center.text-ghmuted.text-sm.mb-4
            %i.bi.bi-diagram-3.block.text-2xl.mb-2
            No trunk peers configured.

        -# ── Remote Trunks (connected but not locally configured) ──────────
        - remote_trunks = @trunks.reject { |name, _| @local_trunks.key?(name) }
        - if remote_trunks.any?
          .page-header.mb-3
            %i.bi.bi-cloud-arrow-down.mr-1
            Remote Trunks

          .grid.grid-cols-1.md:grid-cols-2.xl:grid-cols-3.gap-3.mb-4
            - remote_trunks.each do |name, trunk|
              .rounded-lg.border.border-ghborder.p-4
                .flex.items-center.gap-2.mb-3
                  - if trunk['connected']
                    %span.inline-block.w-2.5.h-2.5.rounded-full.bg-green-500{title: "Connected"}
                  - else
                    %span.inline-block.w-2.5.h-2.5.rounded-full.bg-red-500{title: "Disconnected"}
                  %span.font-mono.text-sm.font-semibold.text-gray-100= name
                  %span.ml-auto.text-xs.px-2.py-0.5.rounded-full.font-semibold{class: trunk['connected'] ? "bg-green-900/50 text-green-400 border border-green-700" : "bg-red-900/50 text-red-400 border border-red-700"}
                    = trunk['connected'] ? 'Connected' : 'Disconnected'
                .space-y-1.5
                  - if trunk['host'].present?
                    .flex.items-center.gap-2
                      %i.bi.bi-globe.text-ghdim{style: "font-size:.7rem"}
                      %span.text-xs.text-ghmuted Host
                      %a.text-xs.font-mono.text-gray-300.ml-auto.hover:text-blue-400.transition-colors{href: "https://#{trunk['host']}", target: "_blank", rel: "noopener"}= trunk['host']
                  - if trunk['remote_prefix'].present?
                    .flex.items-center.gap-2
                      %i.bi.bi-tag.text-ghdim{style: "font-size:.7rem"}
                      %span.text-xs.text-ghmuted Prefix
                      %span.text-xs.font-mono.text-cyan-400.ml-auto= Array(trunk['remote_prefix']).join(', ')

                - if trunk['connected'] && trunk['active_talkers'].present? && trunk['active_talkers'].any?
                  .mt-3.pt-3.border-t.border-ghborder2
                    .text-xs.text-ghmuted.mb-1.5
                      %i.bi.bi-mic-fill.mr-1{style: "font-size:.6rem"}
                      Active Talkers
                    .flex.flex-wrap.gap-1
                      - trunk['active_talkers'].each do |tg, cs|
                        %span.text-xs.px-1.5.py-0.5.rounded.font-mono{class: "bg-green-900/50 text-green-400 border border-green-700"}
                          %i.bi.bi-mic-fill.mr-1{style: "font-size:.55rem"}
                          = "#{cs} TG#{tg}"

        -# ── Satellites ────────────────────────────────────────────────────────
        - if @satellites.any?
          .page-header.mb-3
            %i.bi.bi-broadcast.mr-1
            Satellites

          .grid.grid-cols-1.md:grid-cols-2.xl:grid-cols-3.gap-3.mb-4
            - @satellites.each do |sat_id, sat|
              .rounded-lg.border.border-ghborder.p-4
                .flex.items-center.gap-2.mb-3
                  - if sat['authenticated']
                    %span.inline-block.w-2.5.h-2.5.rounded-full.bg-green-500{title: "Authenticated"}
                  - else
                    %span.inline-block.w-2.5.h-2.5.rounded-full.bg-yellow-500{title: "Pending authentication"}
                  %span.font-mono.text-sm.font-semibold.text-gray-100= sat_id
                  %span.ml-auto.text-xs.px-2.py-0.5.rounded-full.font-semibold{class: sat['authenticated'] ? "bg-green-900/50 text-green-400 border border-green-700" : "bg-yellow-900/50 text-yellow-400 border border-yellow-700"}
                    = sat['authenticated'] ? 'Authenticated' : 'Pending'
                - active_tgs = sat['active_tgs'] || []
                - if active_tgs.any?
                  .mt-1
                    .text-xs.text-ghmuted.mb-1.5
                      %i.bi.bi-collection.mr-1{style: "font-size:.6rem"}
                      Active TGs
                    .flex.flex-wrap.gap-1
                      - active_tgs.each do |tg|
                        %span.text-xs.px-1.5.py-0.5.rounded.font-mono.border.border-ghborder.text-ghmuted= "TG#{tg}"

        -# ── Recent Trunk Events ──────────────────────────────────────────────
        .page-header.mb-3
          %i.bi.bi-activity.mr-1
          Recent Events

        .rounded-lg.border.border-ghborder.mb-4#events-container
          - if @recent_events.any?
            .overflow-y-auto#events-list{style: "max-height:400px; scrollbar-width: thin"}
              - @recent_events.each do |ev|
                - type_style = {'trunk_connected' => ['bg-cyan-700 text-white', 'bi-diagram-3'], 'trunk_disconnected' => ['bg-red-700 text-white', 'bi-diagram-3'], 'remote_talk_start' => ['bg-emerald-600 text-white', 'bi-mic-fill'], 'remote_talk_stop' => ['bg-gray-600 text-white', 'bi-mic-mute'], 'satellite_connected' => ['bg-purple-600 text-white', 'bi-broadcast'], 'satellite_disconnected' => ['bg-red-700 text-white', 'bi-broadcast']}.fetch(ev.event_type, ['bg-gray-600 text-white', 'bi-dot'])
                - rx = ev.metadata.present? ? (JSON.parse(ev.metadata) rescue nil) : nil
                .px-3.py-1.5.border-b.border-ghborder2.hover:bg-ghcard.flex.items-center.gap-2.flex-wrap
                  %span.text-gray-500.font-mono.shrink-0{style: "font-size:.72rem"}= ev.created_at.strftime('%Y-%m-%d %H:%M')
                  %span.event-type-badge.shrink-0{class: type_style[0]}
                    %i.bi{class: "#{type_style[1]} mr-1"}
                    = ev.event_type.tr('_', ' ')
                  %strong.font-mono.text-gray-100.shrink-0{style: "font-size:.82rem"}= ev.callsign
                  - if ev.tg.to_i != 0
                    %span.text-gray-500.text-xs TG
                    %span.text-yellow-500.text-xs.font-semibold= ev.tg
                  - if rx && rx['host'].present?
                    %span.text-xs.text-ghmuted= rx['host']
                  - if ev.source.present?
                    %span.text-xs.font-mono.text-cyan-400.ml-auto
                      %i.bi.bi-diagram-3.mr-1{style: "font-size:.6rem"}
                      = ev.source
          - else
            .text-center.text-gray-500.py-8.text-sm
              %i.bi.bi-hourglass-split.block.text-xl.mb-2
              No trunk events recorded yet.

    - trunks_json = @trunks.to_json.html_safe
    :javascript
      (function() {
        'use strict';
        var trunks = #{trunks_json};

        function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
        function now() { var d=new Date(); return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0')+' '+String(d.getHours()).padStart(2,'0')+':'+String(d.getMinutes()).padStart(2,'0'); }

        // Update trunk cards live
        function updateTrunkCards(trunksData) {
          Object.keys(trunksData).forEach(function(name) {
            var t = trunksData[name];
            // Find all status badges and dots in cards — they use the trunk name in heading
            var cards = document.querySelectorAll('.rounded-lg.border.border-ghborder.p-4');
            cards.forEach(function(card) {
              var nameEl = card.querySelector('.font-mono.text-sm.font-semibold');
              if (!nameEl || nameEl.textContent.trim() !== name) return;

              // Update status dot
              var dot = card.querySelector('.rounded-full');
              if (dot) {
                dot.className = 'inline-block w-2.5 h-2.5 rounded-full ' + (t.connected ? 'bg-green-500' : 'bg-red-500');
                dot.title = t.connected ? 'Connected' : 'Disconnected';
              }

              // Update status badge
              var badge = card.querySelector('.rounded-full.font-semibold');
              if (badge) {
                badge.className = 'ml-auto text-xs px-2 py-0.5 rounded-full font-semibold ' +
                  (t.connected ? 'bg-green-900/50 text-green-400 border border-green-700' : 'bg-red-900/50 text-red-400 border border-red-700');
                badge.textContent = t.connected ? 'Connected' : 'Disconnected';
              }

              // Update active talkers section
              var talkerSection = card.querySelector('.border-t.border-ghborder2');
              var talkers = t.active_talkers || {};
              var talkerKeys = Object.keys(talkers);
              if (talkerKeys.length > 0) {
                var html = '<div class="text-xs text-ghmuted mb-1.5"><i class="bi bi-mic-fill mr-1" style="font-size:.6rem"></i>Active Talkers</div><div class="flex flex-wrap gap-1">';
                talkerKeys.forEach(function(tg) {
                  html += '<span class="text-xs px-1.5 py-0.5 rounded font-mono bg-green-900/50 text-green-400 border border-green-700"><i class="bi bi-mic-fill mr-1" style="font-size:.55rem"></i>' + esc(talkers[tg]) + ' TG' + esc(tg) + '</span>';
                });
                html += '</div>';
                if (talkerSection) {
                  talkerSection.innerHTML = html;
                } else {
                  var wrapper = document.createElement('div');
                  wrapper.className = 'mt-3 pt-3 border-t border-ghborder2';
                  wrapper.innerHTML = html;
                  card.appendChild(wrapper);
                }
              } else if (talkerSection) {
                talkerSection.remove();
              }
            });
          });
        }

        // Add live event to the events list
        var typeStyles = {
          trunk_connected:    ['bg-cyan-700 text-white',   'bi-diagram-3'],
          trunk_disconnected: ['bg-red-700 text-white',    'bi-diagram-3'],
          remote_talk_start:  ['bg-emerald-600 text-white','bi-mic-fill'],
          remote_talk_stop:   ['bg-gray-600 text-white',   'bi-mic-mute']
        };

        function addEvent(type, name, tg, source) {
          var listEl = document.getElementById('events-list');
          var emptyEl = document.querySelector('#events-container .text-center');
          var st = typeStyles[type] || ['bg-gray-600 text-white', 'bi-dot'];
          var h = '<div class="px-3 py-1.5 border-b border-ghborder2 hover:bg-ghcard flex items-center gap-2 flex-wrap">';
          h += '<span class="text-gray-500 font-mono shrink-0" style="font-size:.72rem">' + now() + '</span>';
          h += '<span class="event-type-badge shrink-0 ' + st[0] + '"><i class="bi ' + st[1] + ' mr-1"></i>' + type.replace(/_/g, ' ') + '</span>';
          h += '<strong class="font-mono text-gray-100 shrink-0" style="font-size:.82rem">' + esc(name) + '</strong>';
          if (tg) h += '<span class="text-gray-500 text-xs">TG </span><span class="text-yellow-500 text-xs font-semibold">' + esc(tg) + '</span>';
          if (source) h += '<span class="text-xs font-mono text-cyan-400 ml-auto"><i class="bi bi-diagram-3 mr-1" style="font-size:.6rem"></i>' + esc(source) + '</span>';
          h += '</div>';

          if (!listEl) {
            if (emptyEl) emptyEl.parentNode.removeChild(emptyEl);
            var container = document.getElementById('events-container');
            listEl = document.createElement('div');
            listEl.id = 'events-list';
            listEl.className = 'overflow-y-auto';
            listEl.style.maxHeight = '400px';
            listEl.style.scrollbarWidth = 'thin';
            container.appendChild(listEl);
          }
          listEl.insertAdjacentHTML('afterbegin', h);
          while (listEl.children.length > 100) listEl.removeChild(listEl.lastChild);
        }

        // Detect trunk events from state diffs
        var prevTrunks = trunks;

        function diffTrunks(curr) {
          var allNames = {};
          Object.keys(curr).forEach(function(n) { allNames[n] = true; });
          Object.keys(prevTrunks).forEach(function(n) { allNames[n] = true; });

          Object.keys(allNames).forEach(function(name) {
            var c = curr[name];
            var p = prevTrunks[name];

            // Connection state changes
            if (c && (!p || c.connected !== p.connected)) {
              addEvent(c.connected ? 'trunk_connected' : 'trunk_disconnected', name, null, name);
            }
            if (p && !c) {
              addEvent('trunk_disconnected', name, null, name);
            }

            // Remote talker changes
            if (c && p) {
              var cTalkers = c.active_talkers || {};
              var pTalkers = p.active_talkers || {};
              Object.keys(cTalkers).forEach(function(tg) {
                if (!pTalkers[tg] || pTalkers[tg] !== cTalkers[tg]) {
                  addEvent('remote_talk_start', cTalkers[tg], tg, name);
                }
              });
              Object.keys(pTalkers).forEach(function(tg) {
                if (!cTalkers[tg]) {
                  addEvent('remote_talk_stop', pTalkers[tg], tg, name);
                }
              });
            }
          });
          prevTrunks = curr;
        }

        // WebSocket
        function connect() {
          var proto = location.protocol === 'https:' ? 'wss' : 'ws';
          var ws = new WebSocket(proto + '://' + location.host + '/cable');
          ws.onopen = function() {
            ws.send(JSON.stringify({ command: 'subscribe', identifier: JSON.stringify({ channel: 'UpdatesChannel' }) }));
          };
          ws.onmessage = function(ev) {
            var envelope;
            try { envelope = JSON.parse(ev.data); } catch(e) { return; }
            if (!envelope.message) return;
            var msg = envelope.message;
            if (msg.trunks) {
              trunks = msg.trunks;
              updateTrunkCards(msg.trunks);
              diffTrunks(msg.trunks);
              if (window._topoTrunksData) {
                window._topoTrunksData = msg.trunks;
                window._drawTopology && window._drawTopology();
              }
            }
          };
          ws.onclose = function() { setTimeout(connect, 3000); };
        }
        connect();
      })();

      function switchTrunkTab(tab) {
        var list = document.getElementById('trunk-tab-list');
        var topo = document.getElementById('trunk-tab-topology');
        list.style.display = tab === 'list' ? '' : 'none';
        topo.classList.toggle('hidden', tab !== 'topology');
        document.querySelectorAll('.trunk-tab').forEach(function(b) {
          b.classList.toggle('active', b.dataset.tab === tab);
        });
        localStorage.setItem('trunks-tab', tab);
        if (tab === 'topology' && window._drawTopology) {
          setTimeout(window._drawTopology, 50);
        }
      }
      (function() {
        var saved = localStorage.getItem('trunks-tab') || 'list';
        switchTrunkTab(saved);
      })();
