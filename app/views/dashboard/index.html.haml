    - nodes_json = @nodes.to_json.html_safe
    :javascript
      (function () {
        'use strict';

        // Initial state cloned from server render
        var nodes = #{nodes_json};
        var updateCount = 0;
        var sqlTimeoutMs = #{@sql_timeout_ms || 'null'};
        var talkTimers = {}; // callsign => { start, interval }

        // ── Utilities ──────────────────────────────────────────────────────────────
        function setText(id, val) {
          var el = document.getElementById(id);
          if (el) el.textContent = val;
        }

        function esc(s) {
          return String(s)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
        }

        // ── SQL timeout countdown ─────────────────────────────────────────────────
        function startCountdown(callsign) {
          if (!sqlTimeoutMs || talkTimers[callsign]) return;
          var start = Date.now();
          var total = sqlTimeoutMs;
          function tick() {
            var elapsed = Date.now() - start;
            var remaining = Math.max(0, total - elapsed);
            var pct = remaining / total * 100;
            var secs = Math.ceil(remaining / 1000);
            var cd = document.getElementById('node-' + callsign + '-countdown');
            if (cd) cd.textContent = secs > 0 ? secs + 's' : '0s';
            var fill = document.getElementById('node-' + callsign + '-sql-fill');
            if (fill) {
              fill.style.width = pct + '%';
              fill.className = 'sql-bar-fill' + (pct < 20 ? ' sql-danger' : pct < 50 ? ' sql-warn' : '');
            }
          }
          tick();
          talkTimers[callsign] = { start: start, interval: setInterval(tick, 250) };
        }

        function stopCountdown(callsign) {
          var t = talkTimers[callsign];
          if (t) clearInterval(t.interval);
          delete talkTimers[callsign];
          var cd = document.getElementById('node-' + callsign + '-countdown');
          if (cd) cd.textContent = '';
          var fill = document.getElementById('node-' + callsign + '-sql-fill');
          if (fill) { fill.style.width = '100%'; fill.className = 'sql-bar-fill'; }
        }

        // ── Signal level helpers ────────────────────────────────────────────────────
        function siglevPct(val) {
          if (val === null || val === undefined) return 0;
          if (val < 0) return Math.max(0, Math.min(100, (val + 120) / 100 * 100));
          return Math.max(0, Math.min(100, val));
        }

        function siglevColor(pct) {
          return pct > 66 ? 'green' : (pct > 33 ? 'yellow' : 'red');
        }

        // ── Stats ──────────────────────────────────────────────────────────────────
        function refreshStats() {
          var vals = Object.values(nodes);
          setText('stat-total',   vals.length);
          setText('stat-active',  vals.filter(function(n){ return n.tg && n.tg !== 0; }).length);
          setText('stat-talking', vals.filter(function(n){ return n.isTalker; }).length);
          setText('nodes-count',  vals.filter(function(n){ return !n.hidden; }).length);
        }

        // ── Node card update ───────────────────────────────────────────────────────
        function updateCard(callsign, patch) {
          var card = document.getElementById('node-' + callsign);
          if (!card) return;

          if (!nodes[callsign]) nodes[callsign] = {};
          Object.assign(nodes[callsign], patch);
          var n = nodes[callsign];

          var tg       = (n.tg !== undefined) ? n.tg : 0;
          var isTalker = !!n.isTalker;

          // Card state classes
          card.classList.remove('node-idle', 'node-active', 'node-talking');
          card.classList.add(isTalker ? 'node-talking' : (tg !== 0 ? 'node-active' : 'node-idle'));

          // Status badge
          var badge = document.getElementById('node-' + callsign + '-status');
          if (badge) {
            var stCol = isTalker ? 'green' : (tg !== 0 ? 'blue' : 'gray');
            badge.className = 'inline-block px-2 py-0.5 text-xs rounded font-semibold text-white bg-' + stCol + '-600';
            badge.textContent = isTalker
              ? ('TALKING \u00B7 TG ' + tg)
              : (tg !== 0 ? 'TG ' + tg : 'IDLE');
          }

          // Mic icon
          var mic = document.getElementById('node-' + callsign + '-mic');
          if (mic) {
            mic.className = 'bi bi-mic-fill mr-1 ' + (isTalker ? 'text-green-500 mic-active' : 'text-gray-500 opacity-25');
          }

          // LIVE banner
          var liveBanner = document.getElementById('node-' + callsign + '-live-banner');
          if (liveBanner) {
            var span = liveBanner.querySelector('span:not(.sql-countdown)');
            if (isTalker) {
              liveBanner.classList.remove('hidden');
              if (span) span.textContent = 'TRANSMITTING \u00B7 TG ' + tg;
            } else {
              liveBanner.classList.add('hidden');
            }
          }

          // SQL timeout countdown
          var sqlBar = document.getElementById('node-' + callsign + '-sql-bar');
          if (sqlTimeoutMs && isTalker && !talkTimers[callsign]) {
            startCountdown(callsign);
            if (sqlBar) sqlBar.classList.remove('hidden');
          } else if (!isTalker && talkTimers[callsign]) {
            stopCountdown(callsign);
            if (sqlBar) sqlBar.classList.add('hidden');
          }

          // TG pills
          if (n.monitoredTGs) {
            n.monitoredTGs.forEach(function (tgNum) {
              var pill = document.getElementById('node-' + callsign + '-tgpill-' + tgNum);
              if (pill) pill.className = 'tg-pill' + (tgNum === tg && tg !== 0 ? ' active' : '');
            });
          }

          // Tone → TG active highlight
          if (n.toneToTalkgroup) {
            Object.keys(n.toneToTalkgroup).forEach(function (tone) {
              var tgNum = n.toneToTalkgroup[tone];
              var row = document.getElementById('node-' + callsign + '-tone-' + tone);
              if (row) row.className = 'tone-row' + (tgNum === tg && tg !== 0 ? ' active' : '');
            });
          }

          // Signal levels
          if (n.qth && n.qth[0] && n.qth[0].rx) {
            var rx = n.qth[0].rx;
            Object.keys(rx).forEach(function (port) {
              var rxData  = rx[port];
              var siglev  = rxData.siglev;
              var sqlOpen = rxData.sql_open;

              var pct = siglevPct(siglev);
              var col = siglevColor(pct);

              var sigBar = document.getElementById('node-' + callsign + '-sigbar-' + port);
              if (sigBar) {
                sigBar.style.width = pct + '%';
                sigBar.className   = 'siglev-fill bg-' + col + '-500';
              }

              var sigVal = document.getElementById('node-' + callsign + '-siglev-' + port);
              if (sigVal && siglev !== null && siglev !== undefined) {
                sigVal.textContent = Math.round(siglev) + (siglev < 0 ? ' dBm' : '%');
              }

              var squelch = document.getElementById('node-' + callsign + '-squelch-' + port);
              if (squelch && sqlOpen !== null && sqlOpen !== undefined) {
                squelch.className   = 'inline-block px-1.5 py-0.5 text-xs rounded font-semibold text-white ml-1 ' + (sqlOpen ? 'bg-green-600' : 'bg-gray-600');
                squelch.textContent = sqlOpen ? 'OPEN' : 'SQ';
              }
            });
          }

          // D-STAR RX info
          var dstarRow = document.getElementById('node-' + callsign + '-dstar-rx');
          if (dstarRow) {
            var dr = n.dstar_rx;
            if (dr && dr.mycall) {
              dstarRow.classList.remove('hidden');
              var mycallEl = document.getElementById('node-' + callsign + '-dstar-mycall');
              if (mycallEl) mycallEl.innerHTML = esc(dr.mycall) + (dr.suffix ? '<span class="text-purple-400">/' + esc(dr.suffix) + '</span>' : '');
              var rptEl = document.getElementById('node-' + callsign + '-dstar-rpt');
              if (rptEl) {
                if (dr.rpt) { rptEl.classList.remove('hidden'); rptEl.querySelector('span').textContent = dr.rpt; }
                else { rptEl.classList.add('hidden'); }
              }
              var textEl = document.getElementById('node-' + callsign + '-dstar-text');
              if (textEl) {
                if (dr.text) { textEl.textContent = dr.text; textEl.title = dr.text; textEl.classList.remove('hidden'); }
                else { textEl.textContent = ''; textEl.classList.add('hidden'); }
              }
            } else {
              dstarRow.classList.add('hidden');
            }
          }

          // DMR RX info
          var dmrRow = document.getElementById('node-' + callsign + '-dmr-rx');
          if (dmrRow) {
            var dmr = n.dmr_rx;
            if (dmr && dmr.src_id) {
              dmrRow.classList.remove('hidden');
              var srcEl = document.getElementById('node-' + callsign + '-dmr-srcid');
              if (srcEl) srcEl.textContent = dmr.src_id;
              var tgEl = document.getElementById('node-' + callsign + '-dmr-tg');
              if (tgEl) tgEl.querySelector('span').textContent = dmr.talkgroup;
              var tsEl = document.getElementById('node-' + callsign + '-dmr-ts');
              if (tsEl) tsEl.querySelector('span').textContent = dmr.timeslot;
            } else {
              dmrRow.classList.add('hidden');
            }
          }

          // YSF RX info
          var ysfRow = document.getElementById('node-' + callsign + '-ysf-rx');
          if (ysfRow) {
            var ysf = n.ysf_rx;
            if (ysf && ysf.callsign) {
              ysfRow.classList.remove('hidden');
              var ysfCsEl = document.getElementById('node-' + callsign + '-ysf-callsign');
              if (ysfCsEl) ysfCsEl.textContent = ysf.callsign;
              var ysfLocEl = document.getElementById('node-' + callsign + '-ysf-location');
              if (ysfLocEl) { ysfLocEl.textContent = ysf.location || ''; }
            } else {
              ysfRow.classList.add('hidden');
            }
          }

          // M17 RX info
          var m17Row = document.getElementById('node-' + callsign + '-m17-rx');
          if (m17Row) {
            var m17 = n.m17_rx;
            if (m17 && m17.callsign) {
              m17Row.classList.remove('hidden');
              var m17CsEl = document.getElementById('node-' + callsign + '-m17-callsign');
              if (m17CsEl) m17CsEl.textContent = m17.callsign;
            } else {
              m17Row.classList.add('hidden');
            }
          }

          // Node location
          var locEl = document.getElementById('node-' + callsign + '-location');
          if (locEl && n.nodeLocation) { locEl.textContent = n.nodeLocation; locEl.parentElement.title = n.nodeLocation; locEl.parentElement.classList.remove('hidden'); }
          else if (locEl && !n.nodeLocation) { locEl.parentElement.classList.add('hidden'); }

          // Software version
          var swEl = document.getElementById('node-' + callsign + '-sw');
          if (swEl) swEl.textContent = [n.sw, (n.swVer||'').replace(/(\.0)+$/, '')].filter(Boolean).join(' ');

          var updEl = document.getElementById('node-' + callsign + '-updated');
          if (updEl) updEl.textContent = new Date().toLocaleTimeString();

          // Brief flash
          card.classList.remove('flash');
          void card.offsetWidth;
          card.classList.add('flash');
        }

        // ── Node card removal ──────────────────────────────────────────────────────
        function removeCard(callsign) {
          var col = document.getElementById('node-col-' + callsign);
          if (col) col.remove();
        }

        // ── Node card creation ─────────────────────────────────────────────────────
        function createCard(callsign, n) {
          nodes[callsign] = n;

          var tg       = (n.tg !== undefined) ? n.tg : 0;
          var isTalker = !!n.isTalker;
          var stCls    = isTalker ? 'node-talking' : (tg !== 0 ? 'node-active' : 'node-idle');
          var stTxt    = isTalker ? ('TALKING \u00B7 TG ' + tg) : (tg !== 0 ? 'TG ' + tg : 'IDLE');
          var stCol    = isTalker ? 'green' : (tg !== 0 ? 'blue' : 'gray');
          var cs       = esc(callsign);

          var iconMap = { repeater: 'bi-arrow-repeat', bridge: 'bi-link-45deg', xlx: 'bi-globe', dmr: 'bi-broadcast-pin', ysf: 'bi-soundwave', allstar: 'bi-telephone', echolink: 'bi-headset', simplex: 'bi-broadcast' };
          var iconCls = iconMap[n.nodeClass] || 'bi-broadcast';
          var qth     = (n.qth && n.qth[0]) || {};
          var rxFreq  = qth.rx && Object.values(qth.rx)[0] && Object.values(qth.rx)[0].freq;
          var txFreq  = qth.tx && Object.values(qth.tx)[0] && Object.values(qth.tx)[0].freq;
          var locator = qth.pos && qth.pos.loc;

          var h = '';

          // Card header
          h += '<div class="card-header flex items-center justify-between py-2 px-3">' +
               '<span class="font-bold font-mono text-base text-gray-100">' +
               '<i class="bi bi-mic-fill mr-1 ' + (isTalker ? 'text-green-500 mic-active' : 'text-gray-500 opacity-25') + '" id="node-' + cs + '-mic"></i>' +
               cs + '</span>' +
               '<span class="inline-block px-2 py-0.5 text-xs rounded font-semibold text-white bg-' + stCol + '-600" id="node-' + cs + '-status">' + stTxt + '</span>' +
               '</div>';

          // LIVE banner
          h += '<div class="live-banner ' + (isTalker ? '' : 'hidden') + '" id="node-' + cs + '-live-banner">' +
               '<i class="bi bi-broadcast-pin"></i>' +
               '<span>' + (isTalker ? 'TRANSMITTING \u00B7 TG ' + tg : 'TRANSMITTING') + '</span>' +
               (sqlTimeoutMs ? '<span class="sql-countdown" id="node-' + cs + '-countdown"></span>' : '') +
               '</div>';
          if (sqlTimeoutMs) {
            h += '<div class="sql-bar ' + (isTalker ? '' : 'hidden') + '" id="node-' + cs + '-sql-bar">' +
                 '<div class="sql-bar-fill" id="node-' + cs + '-sql-fill" style="width:100%"></div></div>';
          }

          // Card body
          h += '<div class="py-2 px-3 text-sm text-gray-500">';

          // Class / location / locator
          h += '<div class="mb-2 flex flex-wrap items-center gap-2">';
          if (n.nodeClass)    h += '<span class="capitalize" id="node-' + cs + '-class"><i class="bi ' + iconCls + '"></i> ' + esc(n.nodeClass) + '</span>';
          h += '<span class="truncate' + (n.nodeLocation ? '' : ' hidden') + '" title="' + esc(n.nodeLocation || '') + '"><i class="bi bi-geo-alt mr-1"></i><span id="node-' + cs + '-location">' + esc(n.nodeLocation || '') + '</span></span>';
          if (locator)        h += '<span class="inline-block px-1.5 py-0.5 text-xs rounded border border-gray-600 text-gray-500 bg-[#0d1117]" title="Maidenhead locator">' + esc(locator) + '</span>';
          h += '</div>';

          // Bridge links
          if (n.links && n.links.length > 0) {
            h += '<div class="mb-2 flex flex-wrap items-center gap-2" id="node-' + cs + '-links">';
            h += '<i class="bi bi-diagram-3 text-gray-500"></i>';
            if (n.remoteHost) h += '<span class="text-gray-400">' + esc(n.remoteHost) + '</span>';
            n.links.forEach(function(lk) {
              h += '<span class="inline-block px-1.5 py-0.5 text-xs rounded border border-gray-600 text-gray-400 bg-[#0d1117]">' +
                   'TG ' + lk.localTg + ' <i class="bi bi-arrow-left-right mx-1 text-gray-500"></i> TG ' + lk.remoteTg + '</span>';
            });
            h += '</div>';
          }

          // D-STAR RX info
          var dr = n.dstar_rx;
          h += '<div class="mb-2 flex items-center gap-2 flex-wrap' + (dr && dr.mycall ? '' : ' hidden') + '" id="node-' + cs + '-dstar-rx">';
          h += '<i class="bi bi-broadcast text-purple-400"></i>';
          h += '<span class="text-purple-300 font-mono font-semibold" id="node-' + cs + '-dstar-mycall">' + (dr && dr.mycall ? esc(dr.mycall) + (dr.suffix ? '<span class="text-purple-400">/' + esc(dr.suffix) + '</span>' : '') : '') + '</span>';
          h += '<span class="text-gray-500 text-xs' + (dr && dr.rpt ? '' : ' hidden') + '" id="node-' + cs + '-dstar-rpt">via <span class="text-gray-400">' + (dr && dr.rpt ? esc(dr.rpt) : '') + '</span></span>';
          h += '<span class="text-gray-400 text-xs truncate' + (dr && dr.text ? '' : ' hidden') + '" id="node-' + cs + '-dstar-text" title="' + (dr && dr.text ? esc(dr.text) : '') + '">' + (dr && dr.text ? esc(dr.text) : '') + '</span>';
          h += '</div>';

          // DMR RX info
          var dmr = n.dmr_rx;
          h += '<div class="mb-2 flex items-center gap-2 flex-wrap' + (dmr && dmr.src_id ? '' : ' hidden') + '" id="node-' + cs + '-dmr-rx">';
          h += '<i class="bi bi-broadcast-pin text-amber-400"></i>';
          h += '<span class="text-amber-300 font-mono font-semibold" id="node-' + cs + '-dmr-srcid">' + (dmr && dmr.src_id ? dmr.src_id : '') + '</span>';
          h += '<span class="text-gray-500 text-xs" id="node-' + cs + '-dmr-tg">TG <span class="text-gray-400">' + (dmr && dmr.talkgroup ? dmr.talkgroup : '') + '</span></span>';
          h += '<span class="text-gray-500 text-xs" id="node-' + cs + '-dmr-ts">TS <span class="text-gray-400">' + (dmr && dmr.timeslot ? dmr.timeslot : '') + '</span></span>';
          h += '</div>';

          // YSF RX info
          var ysf = n.ysf_rx;
          h += '<div class="mb-2 flex items-center gap-2 flex-wrap' + (ysf && ysf.callsign ? '' : ' hidden') + '" id="node-' + cs + '-ysf-rx">';
          h += '<i class="bi bi-soundwave text-cyan-400"></i>';
          h += '<span class="text-cyan-300 font-mono font-semibold" id="node-' + cs + '-ysf-callsign">' + (ysf && ysf.callsign ? esc(ysf.callsign) : '') + '</span>';
          h += '<span class="text-gray-400 text-xs truncate" id="node-' + cs + '-ysf-location">' + (ysf && ysf.location ? esc(ysf.location) : '') + '</span>';
          h += '</div>';

          // M17 RX info
          var m17 = n.m17_rx;
          h += '<div class="mb-2 flex items-center gap-2 flex-wrap' + (m17 && m17.callsign ? '' : ' hidden') + '" id="node-' + cs + '-m17-rx">';
          h += '<i class="bi bi-signpost-2 text-rose-400"></i>';
          h += '<span class="text-rose-300 font-mono font-semibold" id="node-' + cs + '-m17-callsign">' + (m17 && m17.callsign ? esc(m17.callsign) : '') + '</span>';
          h += '</div>';

          // Frequencies
          if ((rxFreq && rxFreq > 0) || (txFreq && txFreq > 0)) {
            h += '<div class="mb-2 flex gap-3">';
            if (rxFreq && rxFreq > 0) h += '<span class="freq-label"><span class="text-gray-500">RX</span> <span class="text-gray-100 ml-1">' + rxFreq.toFixed(4) + '</span> MHz</span>';
            if (txFreq && txFreq > 0) h += '<span class="freq-label"><span class="text-gray-500">TX</span> <span class="text-gray-100 ml-1">' + txFreq.toFixed(4) + '</span> MHz</span>';
            h += '</div>';
          }

          // Signal strength
          var rxPorts = [];
          if (n.qth) n.qth.forEach(function (q) { if (q.rx) Object.keys(q.rx).forEach(function (p) { rxPorts.push([p, q.rx[p]]); }); });
          if (rxPorts.length > 0) {
            h += '<div class="mb-2" id="node-' + cs + '-rx-section">';
            rxPorts.forEach(function (pr) {
              var port = pr[0]; var rx = pr[1];
              var pct = siglevPct(rx.siglev); var col = siglevColor(pct);
              h += '<div id="node-' + cs + '-rx-' + esc(port) + '">' +
                   '<div class="flex justify-between items-center"><span>' +
                   '<i class="bi bi-reception-4 mr-1"></i>RX-' + esc(port) +
                   (rx.name ? '<span class="text-gray-100 ml-1">' + esc(rx.name) + '</span>' : '') +
                   (rx.sql_open !== null && rx.sql_open !== undefined
                     ? '<span class="inline-block px-1.5 py-0.5 text-xs rounded font-semibold text-white ml-1 ' + (rx.sql_open ? 'bg-green-600' : 'bg-gray-600') + '" id="node-' + cs + '-squelch-' + esc(port) + '">' + (rx.sql_open ? 'OPEN' : 'SQ') + '</span>'
                     : '') +
                   '</span>' +
                   '<span class="font-mono" id="node-' + cs + '-siglev-' + esc(port) + '">' +
                   (rx.siglev !== null && rx.siglev !== undefined ? Math.round(rx.siglev) + (rx.siglev < 0 ? ' dBm' : '%') : '\u2014') + '</span></div>' +
                   '<div class="siglev-bar mb-1"><div class="siglev-fill bg-' + col + '-500" id="node-' + cs + '-sigbar-' + esc(port) + '" style="width:' + pct + '%"></div></div>' +
                   '</div>';
            });
            h += '</div>';
          }

          // Monitored TGs
          if (n.monitoredTGs && n.monitoredTGs.length > 0) {
            h += '<div class="mb-2 flex flex-wrap gap-1 items-center"><span class="mr-1">TGs:</span>';
            n.monitoredTGs.forEach(function (tgNum) {
              h += '<span class="tg-pill' + (tgNum === tg && tg !== 0 ? ' active' : '') + '" id="node-' + cs + '-tgpill-' + tgNum + '">' + tgNum + '</span>';
            });
            h += '</div>';
          }

          // Tone → TG
          var ttg = n.toneToTalkgroup;
          if (ttg && Object.keys(ttg).length > 0) {
            h += '<div class="mb-2 tone-table node-detail"><div class="text-gray-500 mb-1" style="font-size:.68rem;text-transform:uppercase;letter-spacing:.06em"><i class="bi bi-soundwave mr-1"></i>CTCSS \u2192 TG</div>';
            Object.keys(ttg).sort(function (a, b) { return parseFloat(a) - parseFloat(b); }).forEach(function (tone) {
              var tgNum = ttg[tone];
              h += '<div class="tone-row' + (tgNum === tg && tg !== 0 ? ' active' : '') + '" id="node-' + cs + '-tone-' + tone + '">' +
                   '<span class="t-freq">' + tone + ' Hz</span>' +
                   '<span class="t-tg">' + (tgNum === 0 ? '\u2014 local' : tgNum) + '</span>' +
                   '</div>';
            });
            h += '</div>';
          }

          // Sysop
          if (n.sysop) h += '<div><i class="bi bi-person mr-1"></i>' + esc(n.sysop) + '</div>';

          h += '</div>'; // end card-body

          // Footer
          h += '<div class="card-footer node-detail flex justify-between px-3 py-1">' +
               '<span class="text-gray-500" id="node-' + cs + '-sw">' + esc([n.sw, (n.swVer||'').replace(/(\.0)+$/, '')].filter(Boolean).join(' ')) + '</span>' +
               '<span class="text-gray-500" id="node-' + cs + '-updated"></span>' +
               '</div>';

          var card = document.createElement('div');
          card.className = 'rounded-lg node-card h-full ' + stCls;
          card.id = 'node-' + callsign;
          card.setAttribute('data-callsign', callsign);
          card.innerHTML = h;

          var colEl = document.createElement('div');
          colEl.id = 'node-col-' + callsign;
          colEl.setAttribute('data-node-class', (n.nodeClass || '').toLowerCase());
          colEl.appendChild(card);

          var grid = document.getElementById('nodes-grid');
          if (grid) {
            // Remove the "no nodes connected" placeholder if present
            var empty = grid.querySelector('.text-center.py-5');
            if (empty) empty.remove();
            // Apply current filter
            var f = localStorage.getItem('nodes-filter') || 'all';
            if (f !== 'all' && colEl.dataset.nodeClass !== f) colEl.style.display = 'none';
            grid.appendChild(colEl);
          }
        }

        // ── WebSocket indicator ────────────────────────────────────────────────────
        function setWs(state) {
          var color = state === 'connected' ? 'text-green-500' : state === 'disconnected' ? 'text-red-500' : 'text-yellow-500';
          var title = state === 'connected' ? 'Live' : state === 'disconnected' ? 'Disconnected' : 'Connecting\u2026';
          var pulse = state === 'connecting' ? 'animate-pulse' : '';
          document.querySelectorAll('.js-ws-icon').forEach(function(el) {
            el.className = 'bi bi-broadcast-pin js-ws-icon text-lg ' + color + (pulse ? ' ' + pulse : '');
            el.title = title;
          });
        }

        // ── ActionCable subscription ───────────────────────────────────────────────
        function connect() {
          if (window._pageWs) { window._pageWs.onclose = null; window._pageWs.close(); }
          setWs('connecting');
          var proto = location.protocol === 'https:' ? 'wss' : 'ws';
          var ws    = new WebSocket(proto + '://' + location.host + '/cable');
          window._pageWs = ws;

          ws.onopen = function () {
            ws.send(JSON.stringify({
              command:    'subscribe',
              identifier: JSON.stringify({ channel: 'UpdatesChannel' })
            }));
          };

          ws.onmessage = function (ev) {
            var envelope;
            try { envelope = JSON.parse(ev.data); } catch (e) { return; }
            if (envelope.type === 'welcome')              { setWs('connected'); return; }
            if (envelope.type === 'ping')                 { return; }
            if (envelope.type === 'confirm_subscription') { return; }

            var msg = envelope.message;
            if (!msg) return;

            updateCount++;
            setText('stat-updates', updateCount);

            // Full snapshot
            if (msg.nodes && typeof msg.nodes === 'object') {
              // Remove cards for nodes absent from the new snapshot
              Object.keys(nodes).forEach(function (cs) {
                if (!Object.prototype.hasOwnProperty.call(msg.nodes, cs)) {
                  removeCard(cs);
                  delete nodes[cs];
                }
              });
              Object.keys(msg.nodes).forEach(function (cs) {
                if (document.getElementById('node-' + cs)) {
                  updateCard(cs, msg.nodes[cs]);
                } else {
                  createCard(cs, msg.nodes[cs]);
                }
              });
              refreshStats();
              if (window.audioPlayerUpdateTgs) window.audioPlayerUpdateTgs(msg.nodes);
              return;
            }

            // Single-node update
            if (msg.callsign) updateCard(msg.callsign, msg);
            refreshStats();
          };

          ws.onclose = function () { setWs('disconnected'); setTimeout(connect, 5000); };
          ws.onerror = function () { setWs('disconnected'); };
        }

        connect();

        // ── Start countdowns for nodes already talking on page load ──
        if (sqlTimeoutMs) {
          Object.keys(nodes).forEach(function(cs) {
            if (nodes[cs].isTalker) startCountdown(cs);
          });
        }

        // ── Node detail toggle ──
        var grid = document.getElementById('nodes-grid');
        var toggleBtn = document.getElementById('toggle-detail');
        var toggleIcon = document.getElementById('toggle-detail-icon');
        var toggleLabel = document.getElementById('toggle-detail-label');
        var compact = localStorage.getItem('nodes-compact') === '1';
        function applyCompact() {
          grid.classList.toggle('compact-nodes', compact);
          toggleIcon.className = 'bi ' + (compact ? 'bi-eye-slash' : 'bi-eye-fill');
          toggleLabel.textContent = compact ? 'Compact' : 'Detailed';
        }
        applyCompact();
        if (toggleBtn) toggleBtn.addEventListener('click', function() {
          compact = !compact;
          localStorage.setItem('nodes-compact', compact ? '1' : '0');
          applyCompact();
        });

        // ── Node class filter ──
        var currentFilter = localStorage.getItem('nodes-filter') || 'all';
        var filterBtns = document.querySelectorAll('.filter-btn');
        var nodesTable = document.getElementById('nodes-table');
        function applyFilter() {
          filterBtns.forEach(function(b) { b.classList.toggle('active', b.dataset.filter === currentFilter); });
          grid.querySelectorAll('[data-node-class]').forEach(function(col) {
            col.style.display = (currentFilter === 'all' || col.dataset.nodeClass === currentFilter) ? '' : 'none';
          });
          if (nodesTable) {
            nodesTable.querySelectorAll('tbody tr[data-node-class]').forEach(function(row) {
              row.style.display = (currentFilter === 'all' || row.dataset.nodeClass === currentFilter) ? '' : 'none';
            });
          }
        }
        applyFilter();
        filterBtns.forEach(function(btn) {
          btn.addEventListener('click', function() {
            currentFilter = btn.dataset.filter;
            localStorage.setItem('nodes-filter', currentFilter);
            applyFilter();
          });
        });

        // ── View toggle (cards vs table) ──
        var viewCardsBtn = document.getElementById('view-cards');
        var viewTableBtn = document.getElementById('view-table');
        var currentView = localStorage.getItem('nodes-view') || 'cards';
        function applyView() {
          var isTable = currentView === 'table';
          grid.classList.toggle('hidden', isTable);
          if (nodesTable) nodesTable.classList.toggle('hidden', !isTable);
          viewCardsBtn.classList.toggle('view-toggle-active', !isTable);
          viewCardsBtn.classList.toggle('text-ghmuted', isTable);
          viewTableBtn.classList.toggle('view-toggle-active', isTable);
          viewTableBtn.classList.toggle('text-ghmuted', !isTable);
          // Hide detail toggle in table view
          if (toggleBtn) toggleBtn.style.display = isTable ? 'none' : '';
        }
        applyView();
        if (viewCardsBtn) viewCardsBtn.addEventListener('click', function() {
          currentView = 'cards';
          localStorage.setItem('nodes-view', currentView);
          applyView();
        });
        if (viewTableBtn) viewTableBtn.addEventListener('click', function() {
          currentView = 'table';
          localStorage.setItem('nodes-view', currentView);
          applyView();
        });
      })();

      // ── Node Block Modal ──
      (function() {
        var modal = document.getElementById('block-modal');
        if (!modal) return;
        var callsignEl = document.getElementById('block-modal-callsign');
        var durationEl = document.getElementById('block-modal-duration');
        var resultEl = document.getElementById('block-modal-result');
        var confirmBtn = document.getElementById('block-modal-confirm');
        var cancelBtn = document.getElementById('block-modal-cancel');
        var titleEl = document.getElementById('block-modal-title-text');
        var currentCallsign = '';
        var blockedNodes = {}; // { callsign: expiresAt (ms) }

        function isBlocked(callsign) {
          var exp = blockedNodes[callsign];
          if (!exp) return false;
          if (Date.now() > exp) { delete blockedNodes[callsign]; updateIcon(callsign, false); return false; }
          return true;
        }

        function updateIcon(callsign, blocked) {
          var btn = document.querySelector('#node-' + CSS.escape(callsign) + ' .block-node-btn');
          if (!btn) return;
          var icon = btn.querySelector('i');
          if (blocked) {
            btn.classList.remove('text-gray-500', 'hover:text-orange-400');
            btn.classList.add('text-orange-400', 'hover:text-green-400');
            icon.className = 'bi bi-mic-mute-fill';
            btn.title = 'Unblock node';
          } else {
            btn.classList.remove('text-orange-400', 'hover:text-green-400');
            btn.classList.add('text-gray-500', 'hover:text-orange-400');
            icon.className = 'bi bi-mic-mute';
            btn.title = 'Block node';
          }
        }

        window.openBlockModal = function(callsign) {
          currentCallsign = callsign;
          callsignEl.textContent = callsign;
          resultEl.innerHTML = '';
          confirmBtn.disabled = false;
          var blocked = isBlocked(callsign);
          if (blocked) {
            durationEl.value = '0';
            titleEl.textContent = 'Unblock';
            confirmBtn.innerHTML = '<i class="bi bi-mic mr-1"></i>Unblock';
            confirmBtn.classList.remove('bg-orange-600', 'hover:bg-orange-700');
            confirmBtn.classList.add('bg-green-600', 'hover:bg-green-700');
          } else {
            durationEl.value = '300';
            titleEl.textContent = 'Block';
            confirmBtn.innerHTML = '<i class="bi bi-mic-mute mr-1"></i>Block';
            confirmBtn.classList.remove('bg-green-600', 'hover:bg-green-700');
            confirmBtn.classList.add('bg-orange-600', 'hover:bg-orange-700');
          }
          modal.classList.remove('hidden');
          modal.classList.add('flex');
        };

        function closeModal() {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
        }

        cancelBtn.addEventListener('click', closeModal);
        modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

        durationEl.addEventListener('change', function() {
          var seconds = parseInt(durationEl.value);
          if (seconds === 0) {
            confirmBtn.innerHTML = '<i class="bi bi-mic mr-1"></i>Unblock';
            confirmBtn.classList.remove('bg-orange-600', 'hover:bg-orange-700');
            confirmBtn.classList.add('bg-green-600', 'hover:bg-green-700');
          } else {
            confirmBtn.innerHTML = '<i class="bi bi-mic-mute mr-1"></i>Block';
            confirmBtn.classList.remove('bg-green-600', 'hover:bg-green-700');
            confirmBtn.classList.add('bg-orange-600', 'hover:bg-orange-700');
          }
        });

        confirmBtn.addEventListener('click', function() {
          var seconds = parseInt(durationEl.value);
          confirmBtn.disabled = true;
          var token = document.querySelector('meta[name="csrf-token"]');
          fetch('/admin/reflector/block_node', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token ? token.content : '' },
            body: JSON.stringify({ callsign: currentCallsign, seconds: seconds })
          })
          .then(function(r) { return r.json(); })
          .then(function(data) {
            confirmBtn.disabled = false;
            if (data.ok) {
              if (data.seconds === 0) {
                delete blockedNodes[data.callsign];
                updateIcon(data.callsign, false);
                resultEl.innerHTML = '<span class="text-green-400"><i class="bi bi-mic mr-1"></i>' + data.callsign + ' unblocked</span>';
              } else {
                blockedNodes[data.callsign] = Date.now() + data.seconds * 1000;
                updateIcon(data.callsign, true);
                resultEl.innerHTML = '<span class="text-orange-400"><i class="bi bi-mic-mute mr-1"></i>' + data.callsign + ' blocked for ' + data.seconds + 's</span>';
              }
              setTimeout(closeModal, 1500);
            } else {
              resultEl.innerHTML = '<span class="text-red-400">' + (data.error || 'Unknown error') + '</span>';
            }
          })
          .catch(function() {
            confirmBtn.disabled = false;
            resultEl.innerHTML = '<span class="text-red-400">Request failed</span>';
          });
        });
      })();
