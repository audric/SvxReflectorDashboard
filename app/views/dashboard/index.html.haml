!!!
%html{lang: "en"}
  :javascript
    (function(){var t=localStorage.getItem('theme')||'auto';var r=(t==='auto'?(window.matchMedia('(prefers-color-scheme:light)').matches?'light':'auto'):t);document.documentElement.setAttribute('data-theme',r);})();
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title SVXReflector Dashboard
    = csrf_meta_tags
    %script{src: "/vendor/tailwind/tailwind.js"}
    :javascript
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ghbg: '#0d1117',
              ghcard: '#161b22',
              ghborder: '#30363d',
              ghborder2: '#21262d',
              ghtext: '#c9d1d9',
              ghmuted: '#8b949e',
              ghdim: '#6e7681',
            }
          }
        }
      }
    %link{rel: "stylesheet", href: "/vendor/bootstrap-icons/font/bootstrap-icons.min.css"}
    :css
      body { background: #0d1117; }

      .node-card {
        border: 1px solid #30363d;
        border-left-width: 4px;
        transition: border-color .3s, box-shadow .3s;
      }
      .node-idle    { border-left-color: #6e7681; }
      .node-active  { border-left-color: #1f6feb; }
      .node-talking {
        border-left-color: #3fb950;
        box-shadow: 0 0 0 1px rgba(63,185,80,.3), 0 0 16px rgba(63,185,80,.15);
        animation: glow-pulse 1.4s ease-in-out infinite;
      }
      @keyframes glow-pulse {
        0%,100% { box-shadow: 0 0 0 1px rgba(63,185,80,.3), 0 0 12px rgba(63,185,80,.1); }
        50%     { box-shadow: 0 0 0 2px rgba(63,185,80,.5), 0 0 24px rgba(63,185,80,.3); }
      }

      .node-card .card-header { background: #161b22; border-bottom: 1px solid #21262d; }
      .node-card .card-footer { background: #0d1117; border-top: 1px solid #21262d; font-size: .72rem; }

      /* LIVE banner */
      .live-banner {
        display: flex;
        align-items: center;
        gap: .5rem;
        background: linear-gradient(90deg, rgba(63,185,80,.18), transparent);
        border-bottom: 1px solid rgba(63,185,80,.25);
        color: #3fb950;
        font-size: .78rem;
        font-weight: 600;
        padding: .3rem .75rem;
        letter-spacing: .04em;
      }
      .live-banner .sql-countdown {
        flex: 1;
        text-align: right;
        font-variant-numeric: tabular-nums;
        font-size: .72rem;
        opacity: .85;
      }
      .sql-bar {
        height: 3px;
        background: rgba(63,185,80,.15);
        overflow: hidden;
      }
      .sql-bar-fill {
        height: 100%;
        background: #3fb950;
        transition: width .25s linear;
      }
      .sql-bar-fill.sql-warn { background: #d29922; }
      .sql-bar-fill.sql-danger { background: #f85149; }
      .mic-active {
        animation: mic-pulse 1s ease-in-out infinite;
      }
      @keyframes mic-pulse {
        0%,100% { opacity: 1; transform: scale(1); }
        50%      { opacity: .55; transform: scale(1.25); }
      }

      /* Signal strength */
      .siglev-bar {
        height: 4px;
        background: #21262d;
        border-radius: 2px;
        overflow: hidden;
        margin-top: 3px;
      }
      .siglev-fill {
        height: 100%;
        border-radius: 2px;
        min-width: 2px;
        transition: width .5s ease, background-color .3s;
      }

      .activity-item { font-size: .72rem; border-color: #21262d !important; }
      .activity-item:hover { background: #161b22 !important; }

      .ws-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; vertical-align: middle; }
      .ws-connected    { background: #3fb950; }
      .ws-disconnected { background: #f85149; }
      .ws-connecting   { background: #d29922; animation: blink 1s step-start infinite; }
      @keyframes blink { 50% { opacity: .2; } }

      .tg-pill {
        font-size: .72rem; padding: .1em .5em;
        background: #21262d; border: 1px solid #30363d;
        border-radius: 2em; color: #8b949e;
      }
      .tg-pill.active { background: #1f3a5f; border-color: #1f6feb; color: #79c0ff; }

      .freq-label { font-size: .78rem; font-family: monospace; }

      .tone-table { font-size: .73rem; font-family: monospace; }
      .compact-nodes .node-detail { display: none !important; }
      .filter-btn.active { background: #1f3a5f; color: #79c0ff; }
      .view-toggle-active { background: #1f3a5f; color: #c9d1d9; }
      .tone-row {
        display: flex;
        justify-content: space-between;
        padding: .12rem .4rem;
        border-radius: .2rem;
        color: #6e7681;
        border-left: 2px solid transparent;
        transition: background .3s, border-color .3s, color .3s;
      }
      .tone-row.active {
        background: rgba(31,111,235,.12);
        border-left-color: #1f6feb;
        color: #79c0ff;
      }
      .tone-row .t-freq { color: #8b949e; }
      .tone-row.active .t-freq { color: #58a6ff; }
      .tone-row .t-tg { font-weight: 600; }

      @keyframes flash-update {
        0%   { background-color: rgba(210,153,34,.22); }
        100% { background-color: transparent; }
      }
      .flash { animation: flash-update .8s ease-out; }
  %body.text-ghtext.pb-8
    = render 'shared/navbar', active: 'dashboard', ws_indicator: true

    .px-3.md:px-4

      -# ── Fetch error ─────────────────────────────────────────────────────
      - if @fetch_error
        .flex.items-center.p-3.rounded-lg.mb-4{class: "bg-yellow-900/30 border border-yellow-700 text-yellow-400", role: "alert"}
          %i.bi.bi-exclamation-triangle-fill.mr-2.shrink-0
          = @fetch_error

      -# ── Stats row ────────────────────────────────────────────────────────
      - stats = []
      - stats << {id: 'stat-total',   icon: 'bi-diagram-3',   color: 'text-gray-100',  label: 'Nodes',        val: @nodes.size}
      - stats << {id: 'stat-active',  icon: 'bi-wifi',         color: 'text-blue-500',  label: 'Active',       val: @nodes.count { |_, n| n['tg'].to_i != 0 }}
      - stats << {id: 'stat-talking', icon: 'bi-mic-fill',     color: 'text-green-500', label: 'Talking',      val: @nodes.count { |_, n| n['isTalker'] }}
      - stats << {id: 'stat-updates', icon: 'bi-arrow-repeat', color: 'text-yellow-500', label: 'Live Updates', val: 0}
      .flex.flex-wrap.gap-2.mb-4
        - stats.each do |s|
          .rounded-lg.border.border-ghborder.flex.items-center.gap-2.px-3.py-1.5
            %i.bi.text-xs{class: "#{s[:icon]} #{s[:color]}"}
            %span.text-gray-500.text-xs= s[:label]
            %span.font-bold.text-sm{class: s[:color], id: s[:id]}= s[:val]

      -# ── Node grid ──────────────────────────────────────────────────────────
      .flex.items-center.mb-2.gap-2.flex-wrap
        %span.text-gray-500.uppercase.font-semibold.text-sm
          %i.bi.bi-hdd-network.mr-1
          Connected Nodes
        %span.inline-block.px-2.py-0.5.text-xs.rounded-full.bg-gray-600.text-gray-200#nodes-count
          = @nodes.reject { |_, n| n['hidden'] }.size
        .inline-flex.rounded.border.border-ghborder.overflow-hidden
          %button#view-cards.px-2.py-0.5.text-xs.text-gray-200.cursor-pointer.transition-colors.view-toggle-active{type: "button", title: "Card view"}
            %i.bi.bi-grid-3x3-gap
          %button#view-table.px-2.py-0.5.text-xs.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors{type: "button", title: "Table view"}
            %i.bi.bi-table
        %button#toggle-detail.px-2.py-0.5.text-xs.rounded.border.border-ghborder.text-ghmuted.hover:text-gray-200.hover:border-gray-500.cursor-pointer.transition-colors{type: "button", title: "Toggle node details"}
          %i.bi.bi-eye-fill#toggle-detail-icon
          %span#toggle-detail-label Detailed
      .overflow-x-auto.mb-3.pb-1{style: "-webkit-overflow-scrolling:touch"}
        .inline-flex.rounded.border.border-ghborder.overflow-hidden#node-filters
          %button.filter-btn.px-2.py-0.5.text-xs.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors{type: "button", "data-filter" => "all"}
            %i.bi.bi-grid.mr-1
            All
          %button.filter-btn.px-2.py-0.5.text-xs.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors.border-l.border-ghborder{type: "button", "data-filter" => "repeater"}
            %i.bi.bi-arrow-repeat.mr-1
            Repeaters
          %button.filter-btn.px-2.py-0.5.text-xs.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors.border-l.border-ghborder{type: "button", "data-filter" => "bridge"}
            %i.bi.bi-link-45deg.mr-1
            Bridges
          %button.filter-btn.px-2.py-0.5.text-xs.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors.border-l.border-ghborder{type: "button", "data-filter" => "echolink"}
            %i.bi.bi-headset.mr-1
            EchoLink
          %button.filter-btn.px-2.py-0.5.text-xs.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors.border-l.border-ghborder{type: "button", "data-filter" => "xlx"}
            %i.bi.bi-globe.mr-1
            XLX
          %button.filter-btn.px-2.py-0.5.text-xs.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors.border-l.border-ghborder{type: "button", "data-filter" => "dmr"}
            %i.bi.bi-broadcast-pin.mr-1
            DMR
          %button.filter-btn.px-2.py-0.5.text-xs.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors.border-l.border-ghborder{type: "button", "data-filter" => "ysf"}
            %i.bi.bi-soundwave.mr-1
            YSF
          %button.filter-btn.px-2.py-0.5.text-xs.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors.border-l.border-ghborder{type: "button", "data-filter" => "allstar"}
            %i.bi.bi-telephone.mr-1
            AllStar
          %button.filter-btn.px-2.py-0.5.text-xs.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors.border-l.border-ghborder{type: "button", "data-filter" => "simplex"}
            %i.bi.bi-broadcast.mr-1
            Simplex

      .grid.grid-cols-1.sm:grid-cols-2.xl:grid-cols-3.2xl:grid-cols-5.gap-3#nodes-grid
        - visible = @nodes.reject { |_, n| n['hidden'] }
        - sorted = visible.sort_by { |cs, n| [n['isTalker'] ? 0 : (n['tg'].to_i != 0 ? 1 : 2), cs] }
        - sorted.each do |callsign, node|
          - tg        = node['tg'].to_i
          - is_talker = node['isTalker']
          - st_cls    = is_talker ? 'node-talking' : (tg != 0 ? 'node-active' : 'node-idle')
          - st_txt    = is_talker ? "TALKING \u00B7 TG #{tg}" : (tg != 0 ? "TG #{tg}" : 'IDLE')
          - st_col    = is_talker ? 'green' : (tg != 0 ? 'blue' : 'gray')
          - qth       = node.dig('qth', 0) || {}
          - rx_freq   = qth['rx']&.values&.first&.dig('freq')
          - tx_freq   = qth['tx']&.values&.first&.dig('freq')
          - locator   = qth.dig('pos', 'loc')
          - node_icon = { 'repeater' => 'bi-arrow-repeat', 'bridge' => 'bi-link-45deg', 'xlx' => 'bi-globe', 'dmr' => 'bi-broadcast-pin', 'ysf' => 'bi-soundwave', 'allstar' => 'bi-telephone', 'echolink' => 'bi-headset', 'simplex' => 'bi-broadcast' }.fetch(node['nodeClass'].to_s, 'bi-broadcast')
          - rx_ports  = (node['qth'] || []).flat_map { |q| (q['rx'] || {}).map { |p, r| [p, r] } }

          %div{id: "node-col-#{callsign}", "data-node-class" => node['nodeClass'].to_s.downcase}
            .rounded-lg.node-card.h-full{class: st_cls, id: "node-#{callsign}", "data-callsign" => callsign}

              -# ── Card header: callsign + mic + status badge ──
              .card-header.flex.items-center.justify-between.py-2.px-3
                %span.font-bold.font-mono.text-base.text-gray-100
                  %i.bi.bi-mic-fill.mr-1{class: (is_talker ? 'text-green-500 mic-active' : 'text-gray-500 opacity-25'), id: "node-#{callsign}-mic"}
                  = callsign
                .flex.items-center.gap-2
                  %span.inline-block.px-2.py-0.5.text-xs.rounded.font-semibold.text-white{class: "bg-#{st_col}-600", id: "node-#{callsign}-status"}
                    = st_txt
                  - if current_user&.reflector_admin?
                    %button.block-node-btn.text-gray-500.hover:text-orange-400.cursor-pointer.transition-colors{type: "button", onclick: "openBlockModal('#{callsign}')", title: "Block node"}
                      %i.bi.bi-mic-mute{style: "font-size: 0.85rem"}

              -# ── LIVE banner (visible only when transmitting) ──
              .live-banner{class: (is_talker ? nil : 'hidden'), id: "node-#{callsign}-live-banner"}
                %i.bi.bi-broadcast-pin
                %span= is_talker ? "TRANSMITTING \u00B7 TG #{tg}" : 'TRANSMITTING'
                - if @sql_timeout_ms
                  %span.sql-countdown{id: "node-#{callsign}-countdown"}
              - if @sql_timeout_ms
                .sql-bar{id: "node-#{callsign}-sql-bar", class: (is_talker ? nil : 'hidden')}
                  .sql-bar-fill{id: "node-#{callsign}-sql-fill", style: "width:100%"}

              .py-2.px-3.text-sm.text-gray-500

                -# Class + Location + Locator
                .mb-2.flex.flex-wrap.items-center.gap-2
                  %span.capitalize{id: "node-#{callsign}-class"}
                    %i.bi{class: node_icon}
                    = node['nodeClass']
                  %span.truncate{title: node['nodeLocation'].to_s, class: node['nodeLocation'].present? ? '' : 'hidden'}
                    %i.bi.bi-geo-alt.mr-1
                    %span{id: "node-#{callsign}-location"}= node['nodeLocation']
                  - if locator.present?
                    %span.inline-block.px-1.5.py-0.5.text-xs.rounded.border.border-gray-600.text-gray-500{class: "bg-[#0d1117]", title: "Maidenhead locator"}
                      = locator

                -# Bridge links
                - if node['links'].present?
                  .mb-2.flex.flex-wrap.items-center.gap-2{id: "node-#{callsign}-links"}
                    %i.bi.bi-diagram-3.text-gray-500
                    - if node['remoteHost'].present?
                      %span.text-gray-400= node['remoteHost']
                    - node['links'].each do |link|
                      %span.inline-block.px-1.5.py-0.5.text-xs.rounded.border.border-gray-600.text-gray-400{class: "bg-[#0d1117]"}
                        TG #{link['localTg']}
                        %i.bi.bi-arrow-left-right.mx-1.text-gray-500
                        TG #{link['remoteTg']}

                -# D-STAR RX info (XLX bridges)
                - dstar = node['dstar_rx']
                .mb-2.flex.items-center.gap-2.flex-wrap{id: "node-#{callsign}-dstar-rx", class: (dstar ? '' : 'hidden')}
                  %i.bi.bi-broadcast.text-purple-400
                  %span.text-purple-300.font-mono.font-semibold{id: "node-#{callsign}-dstar-mycall"}
                    = dstar&.dig('mycall')
                    - if dstar&.dig('suffix').present?
                      %span.text-purple-400= "/#{dstar.dig('suffix')}"
                  %span.text-gray-500.text-xs{id: "node-#{callsign}-dstar-rpt", class: (dstar&.dig('rpt').present? ? '' : 'hidden')}
                    via
                    %span.text-gray-400= dstar&.dig('rpt')
                  %span.text-gray-400.text-xs.truncate{id: "node-#{callsign}-dstar-text", title: dstar&.dig('text').to_s, class: (dstar&.dig('text').present? ? '' : 'hidden')}= dstar&.dig('text')

                -# DMR RX info (DMR bridges)
                - dmr = node['dmr_rx']
                .mb-2.flex.items-center.gap-2.flex-wrap{id: "node-#{callsign}-dmr-rx", class: (dmr ? '' : 'hidden')}
                  %i.bi.bi-broadcast-pin.text-amber-400
                  %span.text-amber-300.font-mono.font-semibold{id: "node-#{callsign}-dmr-srcid"}= dmr&.dig('src_id')
                  %span.text-gray-500.text-xs{id: "node-#{callsign}-dmr-tg"}
                    TG
                    %span.text-gray-400= dmr&.dig('talkgroup')
                  %span.text-gray-500.text-xs{id: "node-#{callsign}-dmr-ts"}
                    TS
                    %span.text-gray-400= dmr&.dig('timeslot')

                -# YSF RX info (YSF bridges)
                - ysf = node['ysf_rx']
                .mb-2.flex.items-center.gap-2.flex-wrap{id: "node-#{callsign}-ysf-rx", class: (ysf ? '' : 'hidden')}
                  %i.bi.bi-soundwave.text-cyan-400
                  %span.text-cyan-300.font-mono.font-semibold{id: "node-#{callsign}-ysf-callsign"}= ysf&.dig('callsign')
                  - if ysf&.dig('location').present?
                    %span.text-gray-400.text-xs.truncate{id: "node-#{callsign}-ysf-location"}= ysf&.dig('location')

                -# M17 RX info (M17 bridges)
                - m17 = node['m17_rx']
                .mb-2.flex.items-center.gap-2.flex-wrap{id: "node-#{callsign}-m17-rx", class: (m17 ? '' : 'hidden')}
                  %i.bi.bi-signpost-2.text-rose-400
                  %span.text-rose-300.font-mono.font-semibold{id: "node-#{callsign}-m17-callsign"}= m17&.dig('callsign')

                -# Frequencies
                - if rx_freq.to_f > 0 || tx_freq.to_f > 0
                  .mb-2.flex.gap-3
                    - if rx_freq.to_f > 0
                      %span.freq-label
                        %span.text-gray-500 RX
                        %span.text-gray-100.ml-1= "%.4f" % rx_freq
                        MHz
                    - if tx_freq.to_f > 0
                      %span.freq-label
                        %span.text-gray-500 TX
                        %span.text-gray-100.ml-1= "%.4f" % tx_freq
                        MHz

                -# Signal strength (one bar per RX port)
                - if rx_ports.any?
                  .mb-2{id: "node-#{callsign}-rx-section"}
                    - rx_ports.each do |port, rx|
                      - siglev   = rx['siglev']
                      - sql_open = rx['sql_open']
                      - pct      = siglev.nil? ? 0 : (siglev < 0 ? [[((siglev + 120) / 100.0 * 100).round, 0].max, 100].min : [[siglev.to_i, 0].max, 100].min)
                      - bar_col  = pct > 66 ? 'green' : (pct > 33 ? 'yellow' : 'red')
                      %div{id: "node-#{callsign}-rx-#{port}"}
                        .flex.justify-between.items-center
                          %span
                            %i.bi.bi-reception-4.mr-1
                            = "RX-#{port}"
                            - if rx['name'].present?
                              %span.text-gray-100.ml-1= rx['name']
                            - unless sql_open.nil?
                              %span.inline-block.px-1.5.py-0.5.text-xs.rounded.font-semibold.text-white.ml-1{class: (sql_open ? 'bg-green-600' : 'bg-gray-600'), id: "node-#{callsign}-squelch-#{port}"}
                                = sql_open ? 'OPEN' : 'SQ'
                          %span.font-mono{id: "node-#{callsign}-siglev-#{port}"}
                            = siglev ? "#{siglev.round}#{siglev < 0 ? ' dBm' : '%'}" : '—'
                        .siglev-bar.mb-1
                          .siglev-fill{class: "bg-#{bar_col}-500", id: "node-#{callsign}-sigbar-#{port}", style: "width: #{pct}%"}

                -# Monitored TGs
                - if node['monitoredTGs']&.any?
                  .mb-2.flex.flex-wrap.gap-1.items-center
                    %span.mr-1 TGs:
                    - node['monitoredTGs'].each do |tg_num|
                      %span.tg-pill{class: (tg_num == tg && tg != 0 ? 'active' : nil), id: "node-#{callsign}-tgpill-#{tg_num}"}
                        = tg_num

                -# Tone → Talkgroup
                - if node['toneToTalkgroup']&.any?
                  .mb-2.tone-table.node-detail
                    .text-gray-500.mb-1{style: "font-size:.68rem;text-transform:uppercase;letter-spacing:.06em"}
                      %i.bi.bi-soundwave.mr-1
                      CTCSS → TG
                    - node['toneToTalkgroup'].sort_by { |tone, _| tone.to_f }.each do |tone, tg_num|
                      .tone-row{class: (tg_num == tg && tg != 0 ? 'active' : nil), id: "node-#{callsign}-tone-#{tone}"}
                        %span.t-freq= "#{tone} Hz"
                        %span.t-tg= tg_num == 0 ? '— local' : tg_num

                -# Sysop
                - if node['sysop'].present?
                  %div
                    %i.bi.bi-person.mr-1
                    = node['sysop']

              .card-footer.flex.justify-between.px-3.py-1.node-detail
                %span.text-gray-500{id: "node-#{callsign}-sw"}= [node['sw'], node['swVer'].to_s.sub(/(\.0)+$/, '')].reject(&:blank?).join(' ')
                %span.text-gray-500{id: "node-#{callsign}-updated"}

        - if visible.empty?
          .text-center.text-gray-500.py-5
            %i.bi.bi-hdd-network.text-6xl.block.mb-2
            No nodes currently connected.

      -# ── Table view (hidden by default) ──
      .rounded-lg.border.border-ghborder.overflow-hidden.hidden#nodes-table
        .overflow-x-auto
          %table.w-full.text-left.text-sm
            %thead
              %tr.bg-ghcard.border-b.border-ghborder
                %th.px-3.py-2.text-xs.uppercase.tracking-wider.text-ghdim.font-semibold Callsign
                %th.px-3.py-2.text-xs.uppercase.tracking-wider.text-ghdim.font-semibold Status
                %th.px-3.py-2.text-xs.uppercase.tracking-wider.text-ghdim.font-semibold Type
                %th.px-3.py-2.text-xs.uppercase.tracking-wider.text-ghdim.font-semibold Location
                %th.px-3.py-2.text-xs.uppercase.tracking-wider.text-ghdim.font-semibold TG
                %th.px-3.py-2.text-xs.uppercase.tracking-wider.text-ghdim.font-semibold Signal
                %th.px-3.py-2.text-xs.uppercase.tracking-wider.text-ghdim.font-semibold Software
            %tbody
              - sorted.each do |callsign, node|
                - tg = node['tg'].to_i
                - is_talker = node['isTalker']
                - st_col = is_talker ? 'green' : (tg != 0 ? 'blue' : 'gray')
                - st_txt = is_talker ? "Talking" : (tg != 0 ? "Active" : 'Idle')
                - node_cls = node['nodeClass'].to_s
                - node_icon = { 'repeater' => 'bi-arrow-repeat', 'bridge' => 'bi-link-45deg', 'xlx' => 'bi-globe', 'dmr' => 'bi-broadcast-pin', 'ysf' => 'bi-soundwave', 'allstar' => 'bi-telephone', 'echolink' => 'bi-headset', 'simplex' => 'bi-broadcast' }.fetch(node_cls, 'bi-broadcast')
                - rx_ports = (node['qth'] || []).flat_map { |q| (q['rx'] || {}).map { |p, r| [p, r] } }
                - best_sig = rx_ports.map { |_, r| r['siglev'] }.compact.max
                %tr.border-b.border-ghborder2.hover:bg-ghcard{"data-node-class" => node_cls}
                  %td.px-3.py-2
                    - if is_talker
                      %i.bi.bi-mic-fill.text-green-500.mr-1{style: "font-size:.7rem"}
                    %strong.font-mono.text-gray-100= callsign
                  %td.px-3.py-2
                    %span.inline-block.px-2.py-0.5.text-xs.rounded.font-semibold{class: "bg-#{st_col}-600 text-white"}= st_txt
                    - if tg != 0
                      %span.text-yellow-500.font-mono.ml-1= "TG#{tg}"
                  %td.px-3.py-2
                    %i.bi.mr-1{class: node_icon}
                    %span.capitalize= node_cls.presence || '—'
                  %td.px-3.py-2.text-gray-400= node['nodeLocation'].presence || '—'
                  %td.px-3.py-2
                    - if tg != 0
                      %span.font-mono.text-yellow-500.font-semibold= tg
                    - else
                      %span.text-gray-500 —
                  %td.px-3.py-2
                    - if best_sig
                      - pct = best_sig < 0 ? [[((best_sig + 120) / 100.0 * 100).round, 0].max, 100].min : [[best_sig.to_i, 0].max, 100].min
                      - bar_col = pct > 66 ? 'green' : (pct > 33 ? 'yellow' : 'red')
                      .flex.items-center.gap-2
                        .h-1.5.rounded-full.bg-ghborder2{style: "width:50px"}
                          .h-full.rounded-full{class: "bg-#{bar_col}-500", style: "width:#{pct}%"}
                        %span.font-mono.text-gray-500{style: "font-size:.7rem"}= "#{best_sig.round}#{best_sig < 0 ? ' dBm' : '%'}"
                    - else
                      %span.text-gray-500 —
                  %td.px-3.py-2.text-gray-500{style: "font-size:.75rem"}= [node['sw'], node['swVer']].compact.join(' ').presence || '—'


    - if current_user&.reflector_admin?
      -# ── Block Node Modal ──
      #block-modal.hidden.fixed.inset-0.z-50.items-center.justify-center{style: "background: rgba(0,0,0,0.6)"}
        .rounded-lg.border.border-gray-600.bg-ghcard.p-6.shadow-xl{style: "width: 380px; max-width: 95vw;"}
          .flex.items-center.gap-2.mb-4
            %i.bi.bi-mic-mute.text-orange-400
            %h5.text-lg.font-semibold.text-gray-100
              %span#block-modal-title-text Block
              %span#block-modal-callsign.font-mono
          %p.text-sm.text-ghmuted.mb-4
