!!!
%html{lang: "en"}
  :javascript
    (function(){var t=localStorage.getItem('theme')||'auto';var r=(t==='auto'?(window.matchMedia('(prefers-color-scheme:light)').matches?'light':'auto'):t);document.documentElement.setAttribute('data-theme',r);})();
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title= "SVXReflector #{@reflector_host} · Info image blobs"
    = csrf_meta_tags
    %script{src: "/vendor/tailwind/tailwind.js"}
    :javascript
      tailwind.config = { theme: { extend: { colors: { ghbg: '#0d1117', ghcard: '#161b22', ghborder: '#30363d', ghborder2: '#21262d', ghtext: '#c9d1d9', ghmuted: '#8b949e', ghdim: '#6e7681' } } } }
    %link{rel: "stylesheet", href: "/vendor/bootstrap-icons/font/bootstrap-icons.min.css"}
    :css
      body { background: #0d1117; }
  %body.text-ghtext
    = render 'shared/navbar', active: 'info'

    #confirm-modal.fixed.inset-0.z-50.items-center.justify-center.hidden{style: "background: rgba(0,0,0,0.6)"}
      .bg-ghcard.border.border-gray-600.rounded-lg.p-5.max-w-sm.w-full.mx-4.shadow-xl
        .flex.items-center.gap-3.mb-3
          .w-10.h-10.rounded-full.flex.items-center.justify-center.shrink-0{class: "bg-red-500/15"}
            %i.bi.bi-exclamation-triangle.text-red-400
          %h6.text-base.font-semibold.text-gray-100#confirm-title Delete this blob?
        %p.text-sm.text-gray-400.mb-4#confirm-body This action cannot be undone.
        .flex.justify-end.gap-2
          %button#confirm-cancel.px-3.py-1.5.rounded-md.border.border-gray-600.text-sm.text-gray-300.hover:text-gray-100.cursor-pointer{type: "button"} Cancel
          %button#confirm-delete.px-3.py-1.5.rounded-md.bg-red-600.hover:bg-red-700.text-sm.text-white.font-semibold.cursor-pointer{type: "button"}
            %i.bi.bi-trash3.mr-1
            Delete

    .max-w-5xl.mx-auto.px-4.py-8
      .flex.items-center.justify-between.mb-4
        %h1.text-2xl.font-semibold
          %i.bi.bi-images.mr-2
          Info image blobs
        = link_to admin_info_pages_path, class: "px-3 py-2 rounded border border-ghborder text-ghtext hover:bg-ghcard text-sm" do
          %i.bi.bi-arrow-left.mr-1
          Back to pages

      - if flash[:notice]
        .mb-4.px-3.py-2.rounded.bg-green-900.text-green-100= flash[:notice]
      - if flash[:alert]
        .mb-4.px-3.py-2.rounded.bg-red-900.text-red-100= flash[:alert]

      .grid.grid-cols-3.gap-3.mb-6
        .border.border-ghborder.rounded.p-3.bg-ghcard
          .text-xs.text-ghmuted Used
          .text-xl.font-semibold= @used_blobs.size
        .border.border-ghborder.rounded.p-3.bg-ghcard
          .text-xs.text-ghmuted Orphan
          .text-xl.font-semibold= @orphan_blobs.size
        .border.border-ghborder.rounded.p-3.bg-ghcard
          .text-xs.text-ghmuted Reclaimable
          .text-xl.font-semibold= format_bytes(@orphan_bytes)

      %h2.text-lg.font-semibold.mb-2
        %i.bi.bi-check2-circle.text-green-400.mr-1
        Used
        %span.text-ghmuted.text-sm.ml-1= "(#{@used_blobs.size})"
      .border.border-ghborder.rounded.overflow-hidden.mb-8
        %table.w-full.text-sm
          %thead.bg-ghcard.text-ghmuted
            %tr
              %th.text-left.px-3.py-2{style: "width: 80px"} Preview
              %th.text-left.px-3.py-2 File
              %th.text-left.px-3.py-2 Type
              %th.text-right.px-3.py-2 Size
              %th.text-left.px-3.py-2 Uploaded
              %th.text-left.px-3.py-2 Referenced by
          %tbody
            - if @used_blobs.empty?
              %tr
                %td.px-3.py-4.text-ghmuted{colspan: 6} No used blobs.
            - @used_blobs.each do |b|
              %tr.border-t.border-ghborder
                %td.px-3.py-2
                  - if b.image?
                    = image_tag(rails_blob_path(b, only_path: true), class: "max-h-12 max-w-16 rounded border border-ghborder")
                  - else
                    %i.bi.bi-file-earmark.text-2xl.text-ghmuted
                %td.px-3.py-2
                  = link_to b.filename.to_s, rails_blob_path(b, only_path: true), target: "_blank", class: "text-blue-300 hover:underline"
                  %div.text-xs.text-ghmuted= "id ##{b.id}"
                %td.px-3.py-2.text-ghmuted= b.content_type
                %td.px-3.py-2.text-right= format_bytes(b.byte_size)
                %td.px-3.py-2.text-ghmuted= b.created_at.strftime("%Y-%m-%d %H:%M")
                %td.px-3.py-2
                  - @references[b.id].each do |slug, title|
                    = link_to title, edit_admin_info_page_path(slug), class: "inline-block px-2 py-0.5 mr-1 mb-1 rounded bg-ghborder2 text-ghtext text-xs hover:bg-ghcard"

      .flex.items-center.justify-between.mb-2
        %h2.text-lg.font-semibold
          %i.bi.bi-exclamation-circle.text-amber-400.mr-1
          Orphan
          %span.text-ghmuted.text-sm.ml-1= "(#{@orphan_blobs.size})"
        - if @orphan_blobs.any?
          %button.px-3.py-2.rounded.bg-red-700.hover:bg-red-600.text-white.text-sm.cursor-pointer{type: "button", data: { action: purge_orphan_blobs_admin_info_pages_path, count: @orphan_blobs.size, size: format_bytes(@orphan_bytes) }, onclick: "confirmPurgeAll(this)"}
            %i.bi.bi-trash3.mr-1
            Delete all orphans
      .border.border-ghborder.rounded.overflow-hidden
        %table.w-full.text-sm
          %thead.bg-ghcard.text-ghmuted
            %tr
              %th.text-left.px-3.py-2{style: "width: 80px"} Preview
              %th.text-left.px-3.py-2 File
              %th.text-left.px-3.py-2 Type
              %th.text-right.px-3.py-2 Size
              %th.text-left.px-3.py-2 Uploaded
              %th.text-right.px-3.py-2 Actions
          %tbody
            - if @orphan_blobs.empty?
              %tr
                %td.px-3.py-4.text-ghmuted{colspan: 6} No orphan blobs — nothing to clean up.
            - @orphan_blobs.each do |b|
              %tr.border-t.border-ghborder
                %td.px-3.py-2
                  - if b.image?
                    = image_tag(rails_blob_path(b, only_path: true), class: "max-h-12 max-w-16 rounded border border-ghborder")
                  - else
                    %i.bi.bi-file-earmark.text-2xl.text-ghmuted
                %td.px-3.py-2
                  = link_to b.filename.to_s, rails_blob_path(b, only_path: true), target: "_blank", class: "text-blue-300 hover:underline"
                  %div.text-xs.text-ghmuted= "id ##{b.id}"
                %td.px-3.py-2.text-ghmuted= b.content_type
                %td.px-3.py-2.text-right= format_bytes(b.byte_size)
                %td.px-3.py-2.text-ghmuted= b.created_at.strftime("%Y-%m-%d %H:%M")
                %td.px-3.py-2.text-right.whitespace-nowrap
                  %button.text-red-400.hover:text-red-300.cursor-pointer{type: "button", title: "Delete", data: { action: purge_blob_admin_info_pages_path(blob_id: b.id), name: b.filename.to_s, size: format_bytes(b.byte_size) }, onclick: "confirmPurge(this)"}
                    %i.bi.bi-trash

    :javascript
      var _action = null;
      function showModal(title, body) {
        document.getElementById('confirm-title').textContent = title;
        document.getElementById('confirm-body').textContent = body;
        document.getElementById('confirm-modal').style.display = 'flex';
      }
      function confirmPurge(btn) {
        _action = btn.dataset.action;
        showModal('Delete "' + btn.dataset.name + '"?', 'Frees ' + btn.dataset.size + '. This cannot be undone.');
      }
      function confirmPurgeAll(btn) {
        _action = btn.dataset.action;
        showModal('Delete ' + btn.dataset.count + ' orphan blob(s)?', 'Frees ' + btn.dataset.size + '. This cannot be undone.');
      }
      document.getElementById('confirm-delete').addEventListener('click', function() {
        if (!_action) return;
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = _action;
        var m = document.createElement('input');
        m.type = 'hidden'; m.name = '_method'; m.value = 'delete';
        form.appendChild(m);
        var token = document.querySelector('meta[name="csrf-token"]');
        if (token) {
          var c = document.createElement('input');
          c.type = 'hidden'; c.name = 'authenticity_token'; c.value = token.content;
          form.appendChild(c);
        }
        document.body.appendChild(form);
        form.submit();
      });
      document.getElementById('confirm-cancel').addEventListener('click', function() {
        _action = null;
        document.getElementById('confirm-modal').style.display = 'none';
      });
      document.getElementById('confirm-modal').addEventListener('click', function(e) {
        if (e.target === this) { _action = null; this.style.display = 'none'; }
      });
