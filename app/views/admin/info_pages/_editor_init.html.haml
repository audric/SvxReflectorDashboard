:javascript
  (function(){
    var uploadUrl = "#{upload_image_admin_info_pages_path}";
    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var csrfToken = csrfMeta ? csrfMeta.getAttribute('content') : '';
    var textarea = document.getElementById('info-body');
    var form = document.getElementById('info-form');

    var editor = new toastui.Editor({
      el: document.getElementById('editor'),
      height: '600px',
      initialEditType: 'markdown',
      previewStyle: 'vertical',
      hideModeSwitch: true,
      usageStatistics: false,
      initialValue: textarea.value,
      toolbarItems: [
        ['heading', 'bold', 'italic', 'strike'],
        ['hr', 'quote'],
        ['ul', 'ol', 'task'],
        ['table', 'image', 'link'],
        ['code', 'codeblock'],
        ['scrollSync']
      ],
      hooks: {
        addImageBlobHook: function(blob, callback) {
          var fd = new FormData();
          fd.append('file', blob);
          fetch(uploadUrl, {
            method: 'POST',
            headers: { 'X-CSRF-Token': csrfToken, 'Accept': 'application/json' },
            body: fd,
            credentials: 'same-origin'
          }).then(function(r){
            if (!r.ok) { return r.json().then(function(j){ throw new Error(j.error || ('HTTP ' + r.status)); }); }
            return r.json();
          }).then(function(j){
            callback(j.url, blob.name || 'image');
          }).catch(function(e){
            alert('Image upload failed: ' + e.message);
          });
        }
      }
    });

    form.addEventListener('submit', function(){
      textarea.value = editor.getMarkdown();
    });

    function applyEditorTheme() {
      var theme = document.documentElement.getAttribute('data-theme') || 'auto';
      var isDark = theme !== 'light';
      var container = document.querySelector('.toastui-editor-defaultUI');
      if (container) {
        container.classList.toggle('toastui-editor-dark', isDark);
      }
    }
    applyEditorTheme();
    new MutationObserver(applyEditorTheme).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  })();
