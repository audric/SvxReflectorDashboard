!!!
%html{lang: "en"}
  :javascript
    (function(){var t=localStorage.getItem('theme')||'auto';var r=(t==='auto'?(window.matchMedia('(prefers-color-scheme:light)').matches?'light':'auto'):t);document.documentElement.setAttribute('data-theme',r);})();
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title= "SVXReflector #{@reflector_host} · Edit Info"
    = csrf_meta_tags
    = csp_meta_tag
    %script{src: "/vendor/tailwind/tailwind.js"}
    :javascript
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ghbg: '#0d1117',
              ghcard: '#161b22',
              ghborder: '#30363d',
              ghborder2: '#21262d',
              ghtext: '#c9d1d9',
              ghmuted: '#8b949e',
              ghdim: '#6e7681',
            }
          }
        }
      }
    %link{rel: "stylesheet", href: "/vendor/bootstrap-icons/font/bootstrap-icons.min.css"}
    %link{rel: "stylesheet", href: "/vendor/toastui-editor/toastui-editor.min.css"}
    %link{rel: "stylesheet", href: "/vendor/toastui-editor/toastui-editor-dark.min.css"}
    %script{src: "/vendor/toastui-editor/toastui-editor-all.min.js"}
    :css
      body { background: #0d1117; }
      /* Keep the Toast UI container styled consistently with the rest of the app. */
      .toastui-editor-defaultUI { border-color: #30363d !important; border-radius: .4rem; }
  %body.text-ghtext
    = render 'shared/navbar', active: 'info'
    .max-w-5xl.mx-auto.px-4.py-8
      %h1.text-2xl.font-semibold.mb-4
        %i.bi.bi-pencil-square.mr-2
        Edit /info page
      - if flash[:notice]
        .mb-4.px-3.py-2.rounded.bg-green-900.text-green-100= flash[:notice]
      = form_with url: admin_info_path, method: :patch, local: true, html: { id: 'info-form' } do |f|
        %textarea#info-body{name: "body", style: "display:none;"}= @body
        #editor
        .mt-4.flex.gap-2
          = f.submit "Save", class: "px-4 py-2 rounded bg-blue-700 hover:bg-blue-600 text-white cursor-pointer"
          = link_to "Cancel", info_path, class: "px-4 py-2 rounded bg-ghcard border border-ghborder text-ghtext"
    :javascript
      (function(){
        var uploadUrl = "#{upload_image_admin_info_path}";
        var csrfMeta = document.querySelector('meta[name="csrf-token"]');
        var csrfToken = csrfMeta ? csrfMeta.getAttribute('content') : '';
        var textarea = document.getElementById('info-body');
        var form = document.getElementById('info-form');

        var editor = new toastui.Editor({
          el: document.getElementById('editor'),
          height: '600px',
          initialEditType: 'markdown',
          previewStyle: 'vertical',
          usageStatistics: false,
          initialValue: textarea.value,
          toolbarItems: [
            ['heading', 'bold', 'italic', 'strike'],
            ['hr', 'quote'],
            ['ul', 'ol', 'task'],
            ['table', 'image', 'link'],
            ['code', 'codeblock'],
            ['scrollSync']
          ],
          hooks: {
            addImageBlobHook: function(blob, callback) {
              var fd = new FormData();
              fd.append('file', blob);
              fetch(uploadUrl, {
                method: 'POST',
                headers: { 'X-CSRF-Token': csrfToken, 'Accept': 'application/json' },
                body: fd,
                credentials: 'same-origin'
              }).then(function(r){
                if (!r.ok) { return r.json().then(function(j){ throw new Error(j.error || ('HTTP ' + r.status)); }); }
                return r.json();
              }).then(function(j){
                callback(j.url, blob.name || 'image');
              }).catch(function(e){
                alert('Image upload failed: ' + e.message);
              });
            }
          }
        });

        form.addEventListener('submit', function(){
          textarea.value = editor.getMarkdown();
        });

        function applyEditorTheme() {
          var theme = document.documentElement.getAttribute('data-theme') || 'auto';
          var isDark = theme !== 'light';
          var container = document.querySelector('.toastui-editor-defaultUI');
          if (container) {
            container.classList.toggle('toastui-editor-dark', isDark);
          }
        }
        applyEditorTheme();
        new MutationObserver(applyEditorTheme).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
      })();
