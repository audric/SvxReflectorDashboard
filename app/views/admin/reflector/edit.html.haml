      // ── Backup browser ──
      var _backupData = null;
      function openBackups() {
        openModal('backup-modal');
        if (_backupData) { renderBackupList(_backupData); return; }
        fetch('/admin/reflector/backups')
          .then(function(r) { return r.json(); })
          .then(function(data) { _backupData = data; renderBackupList(data); })
          .catch(function() {
            document.getElementById('backup-list-inner').innerHTML = '<span class="text-red-400">Failed to load backups</span>';
          });
      }
      function closeBackups() {
        closeModal('backup-modal');
      }
      document.getElementById('backup-modal').addEventListener('click', function(e) {
        if (e.target === this) closeBackups();
      });
      function renderBackupList(backups) {
        var list = document.getElementById('backup-list-inner');
        if (!backups.length) { list.innerHTML = '<span class="text-ghdim">No backups available</span>'; return; }
        list.innerHTML = '';
        backups.forEach(function(b, i) {
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'w-full text-left px-3 py-2 rounded-md text-sm hover:bg-ghborder2 cursor-pointer transition-colors text-gray-300 backup-item';
          btn.innerHTML = '<div class="font-mono text-xs">' + b.label + '</div>';
          btn.addEventListener('click', function() {
            document.querySelectorAll('.backup-item').forEach(function(el) { el.classList.remove('bg-ghborder2', 'text-gray-100'); });
            btn.classList.add('bg-ghborder2', 'text-gray-100');
            document.getElementById('backup-content-pre').textContent = b.content;
          });
          list.appendChild(btn);
          if (i === 0) btn.click();
        });
      }

      // ── Pending CSRs ──
      function loadCsrs() {
        var content = document.getElementById('csrs-content');
        content.innerHTML = '<span class="text-ghdim">Loading…</span>';
        fetch('#{pending_csrs_admin_reflector_path}')
          .then(function(r) { return r.json(); })
          .then(function(csrs) { renderCsrs(csrs); })
          .catch(function() { content.innerHTML = '<span class="text-red-400">Failed to load CSRs</span>'; });
      }
      function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

      function renderCsrs(csrs) {
        var content = document.getElementById('csrs-content');
        var count = document.getElementById('csr-count');
        count.textContent = csrs.length > 0 ? '(' + csrs.length + ' pending)' : '';
        if (!csrs.length) {
          content.innerHTML = '<div class="flex items-center gap-2 text-green-400 py-2"><i class="bi bi-check-circle"></i> No pending certificate requests.</div>';
          return;
        }
        var html = '<div class="space-y-2">';
        csrs.forEach(function(csr) {
          var subjectHtml = csr.subject ? '<span class="text-ghmuted text-xs ml-2">' + esc(csr.subject) + '</span>' : '';
          var dateHtml = csr.date ? '<span class="text-ghdim text-xs">' + esc(csr.date) + '</span>' : '';
          html += '<div class="border border-gray-700 rounded-lg px-4 py-3" id="csr-row-' + esc(csr.callsign) + '">' +
            '<div class="flex items-center justify-between">' +
              '<div class="flex items-center gap-3 min-w-0">' +
                '<i class="bi bi-file-earmark-lock text-yellow-400 shrink-0"></i>' +
                '<div class="min-w-0">' +
                  '<div class="flex items-center gap-2 flex-wrap">' +
                    '<span class="font-mono font-semibold text-gray-200">' + esc(csr.callsign) + '</span>' +
                    dateHtml +
                  '</div>' +
                  (csr.subject ? '<div class="text-xs text-ghmuted truncate mt-0.5">' + esc(csr.subject) + '</div>' : '') +
                '</div>' +
              '</div>' +
              '<div class="flex items-center gap-2 shrink-0 ml-3">' +
                '<button type="button" class="p-2 rounded-md text-gray-400 hover:text-gray-200 hover:bg-ghborder2 cursor-pointer" onclick="inspectCsr(\'' + esc(csr.callsign) + '\')" title="Inspect">' +
                  '<i class="bi bi-eye"></i>' +
                '</button>' +
                '<button type="button" class="p-2 rounded-md text-green-400 hover:text-green-300 hover:bg-ghborder2 cursor-pointer" onclick="signCsr(\'' + esc(csr.callsign) + '\', this)" title="Sign">' +
                  '<i class="bi bi-check-lg"></i>' +
                '</button>' +
                '<button type="button" class="p-2 rounded-md text-red-400 hover:text-red-300 hover:bg-ghborder2 cursor-pointer" onclick="rejectCsr(\'' + esc(csr.callsign) + '\', this)" title="Reject">' +
                  '<i class="bi bi-trash3"></i>' +
                '</button>' +
              '</div>' +
            '</div>' +
          '</div>';
        });
        html += '</div>';
        content.innerHTML = html;
      }

      function inspectCsr(callsign) {
        var modal = document.getElementById('csr-modal');
        document.getElementById('csr-modal-title').textContent = callsign;
        document.getElementById('csr-modal-body').innerHTML = '<span class="text-ghdim">Loading…</span>';
        openModal('csr-modal');
        fetch('#{inspect_csr_admin_reflector_path}?callsign=' + encodeURIComponent(callsign))
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.error) {
              document.getElementById('csr-modal-body').innerHTML = '<span class="text-red-400">' + esc(data.error) + '</span>';
              return;
            }
            var html = '<div class="space-y-3">';
            if (data.subject) {
              html += '<div><div class="text-ghmuted text-xs uppercase tracking-wide mb-1">Subject</div>' +
                '<div class="text-gray-200 text-sm font-mono whitespace-pre">' + esc(data.subject) + '</div></div>';
            }
            if (data.key_info) {
              html += '<div><div class="text-ghmuted text-xs uppercase tracking-wide mb-1">Public Key</div>' +
                '<div class="text-gray-300 text-xs font-mono whitespace-pre">' + esc(data.key_info) + '</div></div>';
            }
            html += '</div>';
            document.getElementById('csr-modal-body').innerHTML = html;
          })
          .catch(function() {
            document.getElementById('csr-modal-body').innerHTML = '<span class="text-red-400">Failed to load CSR details</span>';
          });
      }
      function closeCsrModal() {
        closeModal('csr-modal');
      }
      document.getElementById('csr-modal').addEventListener('click', function(e) {
        if (e.target === this) closeCsrModal();
      });

      function csrAction(url, callsign, btn, successIcon, successLabel) {
        btn.disabled = true;
        var token = document.querySelector('meta[name="csrf-token"]');
        fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token ? token.content : '' },
          body: JSON.stringify({ callsign: callsign })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.ok) {
            var row = document.getElementById('csr-row-' + callsign);
            if (row) row.innerHTML =
              '<div class="flex items-center gap-3"><i class="bi ' + successIcon + '"></i>' +
              '<span class="font-mono font-semibold text-gray-200">' + data.callsign + '</span></div>' +
              '<span class="text-sm">' + successLabel + '</span>';
          } else {
            btn.disabled = false;
            alert('Error: ' + (data.error || 'Unknown error'));
          }
        })
        .catch(function() { btn.disabled = false; alert('Operation failed'); });
      }
      function signCsr(callsign, btn) {
        csrAction('#{sign_csr_admin_reflector_path}', callsign, btn, 'bi-check-circle text-green-400', '<i class="bi bi-check-lg mr-1 text-green-400"></i><span class="text-green-400">Signed</span>');
      }
      function rejectCsr(callsign, btn) {
        showDanger(
          'Reject CSR for "' + callsign + '"?',
          'This will delete the pending certificate request. The node will need to reconnect to submit a new one.',
          'Reject',
          function() {
            csrAction('#{reject_csr_admin_reflector_path}', callsign, btn, 'bi-x-circle text-red-400', '<i class="bi bi-x-lg mr-1 text-red-400"></i><span class="text-red-400">Rejected</span>');
          }
        );
      }

      // ── Node Block ──
      function blockNode() {
        var callsign = document.getElementById('block-callsign').value.trim();
        var seconds = parseInt(document.getElementById('block-duration').value);
        var result = document.getElementById('block-result');
        var btn = document.getElementById('block-btn');
        if (!callsign) { result.innerHTML = '<span class="text-red-400">Enter a callsign</span>'; return; }
        btn.disabled = true;
        var token = document.querySelector('meta[name="csrf-token"]');
        fetch('#{block_node_admin_reflector_path}', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token ? token.content : '' },
          body: JSON.stringify({ callsign: callsign, seconds: seconds })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          btn.disabled = false;
          if (data.ok) {
            if (data.seconds === 0) {
              result.innerHTML = '<span class="text-green-400"><i class="bi bi-mic mr-1"></i>' + esc(data.callsign) + ' unblocked</span>';
            } else {
              result.innerHTML = '<span class="text-orange-400"><i class="bi bi-mic-mute mr-1"></i>' + esc(data.callsign) + ' blocked for ' + data.seconds + 's</span>';
            }
          } else {
            result.innerHTML = '<span class="text-red-400">' + esc(data.error || 'Unknown error') + '</span>';
          }
        })
        .catch(function() { btn.disabled = false; result.innerHTML = '<span class="text-red-400">Request failed</span>'; });
      }

      // ── Revoke Certificate ──
      function revokeCert(callsign, btn) {
        showDanger(
          'Revoke certificate for "' + callsign + '"?',
          'This will remove all certificate files for this node. Note: if the node already has a valid certificate cached locally, it can still connect until it expires. Use REJECT_CALLSIGN to fully block it.',
          'Revoke',
          function() {
            btn.disabled = true;
            var token = document.querySelector('meta[name="csrf-token"]');
            fetch('#{revoke_cert_admin_reflector_path}', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token ? token.content : '' },
              body: JSON.stringify({ callsign: callsign })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data.ok) {
                var row = document.getElementById('cert-row-' + callsign);
                if (row) row.innerHTML =
                  '<div class="flex items-center gap-2 py-2">' +
                    '<i class="bi bi-x-circle text-red-400"></i>' +
                    '<span class="font-mono font-semibold text-gray-200">' + esc(data.callsign) + '</span>' +
                    '<span class="text-red-400 text-sm">Revoked</span>' +
                  '</div>';
              } else {
                btn.disabled = false;
                alert('Error: ' + (data.error || 'Unknown error'));
              }
            })
            .catch(function() { btn.disabled = false; alert('Revoke failed'); });
          }
        );
      }

      // ── Danger confirm modal ──
      var _dangerCallback = null;
      function showDanger(title, body, confirmLabel, callback) {
        document.getElementById('danger-title').textContent = title;
        document.getElementById('danger-body').textContent = body;
        document.getElementById('danger-confirm-label').textContent = confirmLabel;
        _dangerCallback = callback;
        document.getElementById('danger-modal').classList.remove('hidden');
        document.getElementById('danger-modal').classList.add('flex');
      }
      function closeDanger() {
        document.getElementById('danger-modal').classList.add('hidden');
        document.getElementById('danger-modal').classList.remove('flex');
        _dangerCallback = null;
      }
      document.getElementById('danger-confirm').addEventListener('click', function() {
        if (_dangerCallback) _dangerCallback();
        closeDanger();
      });
      document.getElementById('danger-cancel').addEventListener('click', closeDanger);
      document.getElementById('danger-modal').addEventListener('click', function(e) {
        if (e.target === this) closeDanger();
      });

      // ── Reset PKI ──
      function resetPki() {
        showDanger(
          'Reset all certificates?',
          'This will delete all certificates and restart the reflector. All connected nodes will need to reconnect and have their CSRs re-signed.',
          'Reset PKI',
          function() {
            var btn = document.getElementById('btn-reset-pki');
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass-split mr-1"></i>Resetting…';
            var token = document.querySelector('meta[name="csrf-token"]');
            fetch('#{reset_pki_admin_reflector_path}', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-CSRF-Token': token ? token.content : '' }
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data.ok) {
                window.location.reload();
                return;
              }
              btn.innerHTML = '<i class="bi bi-trash3 mr-1"></i>Reset PKI';
              btn.disabled = false;
            })
            .catch(function() { btn.innerHTML = '<i class="bi bi-trash3 mr-1"></i>Reset PKI'; btn.disabled = false; });
          }
        );
      }

      // ── Our Certificates ──
      var _ourCertsLoaded = false;
      function loadOurCerts() {
        if (_ourCertsLoaded) return;
        var content = document.getElementById('ourcerts-content');
        content.innerHTML = '<span class="text-ghdim">Loading…</span>';
        fetch('#{certificates_admin_reflector_path}')
          .then(function(r) { return r.json(); })
          .then(function(certs) { _ourCertsLoaded = true; renderOurCerts(certs); })
          .catch(function() { content.innerHTML = '<span class="text-red-400">Failed to load certificates</span>'; });
      }
      function renderOurCerts(certs) {
        var content = document.getElementById('ourcerts-content');
        if (!certs.length) {
          content.innerHTML = '<div class="text-ghdim py-2">No certificates found.</div>';
          return;
        }
        var infraCerts = ['svxreflector_root_ca', 'svxreflector_issuing_ca', 'svxreflector_server'];
        var labels = {
          'svxreflector_root_ca': { icon: 'bi-shield-lock', label: 'Root CA', color: 'text-yellow-400' },
          'svxreflector_issuing_ca': { icon: 'bi-shield-check', label: 'Issuing CA', color: 'text-blue-400' },
          'svxreflector_server': { icon: 'bi-hdd-rack', label: 'Server Certificate', color: 'text-green-400' }
        };
        var html = '<div class="space-y-3">';
        certs.forEach(function(cert) {
          var isClient = infraCerts.indexOf(cert.name) === -1;
          var meta = labels[cert.name] || { icon: 'bi-person-badge', label: cert.name, color: 'text-cyan-400' };
          var f = cert.fields;
          var subject = (f.subject || '').replace(/^.*?=/, '');
          var issuer = (f.issuer || '').replace(/^.*?=/, '');
          var notBefore = f.notBefore || '';
          var notAfter = f.notAfter || '';
          var serial = f.serial || '';
          var san = '';
          Object.keys(f).forEach(function(k) {
            if (k.indexOf('Subject Alternative') >= 0 || k.indexOf('subjectAltName') >= 0) san = f[k];
          });
          // Check if cert might be in the SAN fields value
          if (!san) {
            Object.keys(f).forEach(function(k) {
              if (k.indexOf('DNS:') >= 0 || k.indexOf('IP Address:') >= 0) san = k + (f[k] ? ' ' + f[k] : '');
            });
          }

          var revokeBtn = isClient ?
            '<button type="button" class="ml-auto p-1.5 rounded-md text-red-400 hover:text-red-300 hover:bg-ghborder2 cursor-pointer" onclick="revokeCert(\'' + esc(cert.name) + '\', this)" title="Revoke certificate">' +
              '<i class="bi bi-trash3"></i>' +
            '</button>' : '';
          html += '<div class="border border-gray-700 rounded-lg p-4" id="cert-row-' + esc(cert.name) + '">' +
            '<div class="flex items-center gap-2 mb-3">' +
              '<i class="bi ' + meta.icon + ' ' + meta.color + '"></i>' +
              '<span class="font-semibold text-gray-200">' + esc(meta.label) + '</span>' +
              '<span class="text-xs text-ghdim font-mono">(' + esc(cert.name) + ')</span>' +
              revokeBtn +
            '</div>' +
            '<div class="grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-1 text-xs">' +
              '<div><span class="text-ghmuted">Subject:</span> <span class="text-gray-300 font-mono">' + esc(subject) + '</span></div>' +
              '<div><span class="text-ghmuted">Issuer:</span> <span class="text-gray-300 font-mono">' + esc(issuer) + '</span></div>' +
              '<div><span class="text-ghmuted">Valid from:</span> <span class="text-gray-300">' + esc(notBefore) + '</span></div>' +
              '<div><span class="text-ghmuted">Valid until:</span> <span class="text-gray-300">' + esc(notAfter) + '</span></div>' +
              '<div class="md:col-span-2"><span class="text-ghmuted">Serial:</span> <span class="text-gray-300 font-mono text-xs">' + esc(serial) + '</span></div>' +
              (san ? '<div class="md:col-span-2"><span class="text-ghmuted">SAN:</span> <span class="text-gray-300 font-mono text-xs">' + esc(san) + '</span></div>' : '') +
            '</div>' +
          '</div>';
        });
        html += '</div>';
        content.innerHTML = html;
      }
