%html{lang: "en"}
  :javascript
    (function(){var t=localStorage.getItem('theme')||'auto';var r=(t==='auto'?(window.matchMedia('(prefers-color-scheme:light)').matches?'light':'auto'):t);document.documentElement.setAttribute('data-theme',r);})();
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title SVXReflector · Reflector Config
    = csrf_meta_tags
    %script{src: "/vendor/tailwind/tailwind.js"}
    :javascript
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ghbg: '#0d1117',
              ghcard: '#161b22',
              ghborder: '#30363d',
              ghborder2: '#21262d',
              ghtext: '#c9d1d9',
              ghmuted: '#8b949e',
              ghdim: '#6e7681',
            }
          }
        }
      }
    %link{rel: "stylesheet", href: "/vendor/bootstrap-icons/font/bootstrap-icons.min.css"}
    :css
      body { background: #0d1117; }
      .accordion-body { max-height: 0; overflow: hidden; padding-top: 0; padding-bottom: 0; transition: max-height 0.3s ease, padding 0.3s ease; }
      .accordion-body.open { max-height: 5000px; padding-top: 1rem; padding-bottom: 1rem; }
      .accordion-chevron { transition: transform 0.3s ease; }
      .accordion-chevron.open { transform: rotate(180deg); }

  -# Help texts from official svxreflector.conf(5) man page
  - help = {}
  - help["LISTEN_PORT"] = "The TCP and UDP port number to use for network communications. The default is 5300. Make sure to open this port for incoming traffic to the server on both TCP and UDP. Clients do not have to open any ports in their firewalls."
  - help["HTTP_SRV_PORT"] = "Set which port to use for the HTTP server. The HTTP server can be used to fetch reflector status. No port is set by default. Don't expose this port to the public Internet. The built in web server is very simple and could be incompatible with some clients. It has not been audited for security problems so there may be security issues. There is also the risk of some client overwhelming the reflector with requests causing disturbances in the reflector operation. Example: HTTP_SRV_PORT=8080"
  - help["CODECS"] = "A comma separated list of allowed codecs. For the moment only one codec can be specified. Choose from the following codecs: OPUS, SPEEX, GSM, S16 (uncompressed signed 16 bit), RAW (uncompressed 32 bit floats). The default is OPUS and you should have a very good reason for changing this since that codec provide both low bandwidth (~20kbps by default) and very good audio quality."
  - help["ACCEPT_CALLSIGN"] = "A regular expression for verifying that a received login callsign has the correct format. The default is to roughly match standard ham radio callsigns. Example: ACCEPT_CALLSIGN=\"S[A-M]\\d[A-Z]{1,3}(?:-[A-Z0-9]{1,3})?\""
  - help["REJECT_CALLSIGN"] = "A regular expression for rejecting login callsigns. This can be used to block some specific callsigns or even a whole range of callsigns. No callsigns are rejected by default. Example: REJECT_CALLSIGN=\"SM0XYZ|SM1ABC|SM2.*\""
  - help["ACCEPT_CERT_EMAIL"] = "A regular expression for verifying that email addresses in a received certificate signing requests are valid. If unset, which is the default, all email addresses are accepted. If an invalid email address is received from a node it will be disconnected and an error message will be sent to the node."
  - help["SQL_TIMEOUT"] = "Use this configuration variable to set a time in seconds after which a clients audio is blocked if he has been talking for too long. The default is 0 (disabled)."
  - help["SQL_TIMEOUT_BLOCKTIME"] = "If a client has been talking for longer than the time specified in the SQL_TIMEOUT configuration variable he will not be able to talk again until the time in this configuration variable have elapsed. If not specified, the default is one second."
  - help["TG_FOR_V1_CLIENTS"] = "Set which talk group to place protocol version 1 clients in. Without this configuration version 1 clients will not be able to use the reflector since they cannot select a talk group by themselves. Talk groups should normally be configured to start with the ITU-T E.212 Mobile Country Code (MCC) for your country, e.g. 240 for Sweden."
  - help["RANDOM_QSY_RANGE"] = "Specify in which talk group range the reflector server should select random talk groups used when using the QSY functionality. The range is specified using two colon separated values. The first one is the lower limit and the second value is the number of talk groups in the range. As an example, if set to 1239900:100 QSY talk groups will be selected from the range 1239900 to 1239999. The recommended lower range to use is <MCC>9900 where MCC is the ITU-T E.212 Mobile Country Code for your country."
  - help["TIMESTAMP_FORMAT"] = "This variable specifies the format of the timestamp that is written in front of each row in the log file. The format string is in the same format as specified in the strftime(3) manual page. The default is \"%c\" which is described as: \"the preferred date and time representation for the current locale\". Example: TIMESTAMP_FORMAT=\"%d %b %Y %H:%M:%S\" would give a timestamp looking something like: \"29 Nov 2005 22:31:59\"."
  - help["COMMAND_PTY"] = "Configure a path for a pseudo tty device to send runtime commands to the svxreflector. Example: COMMAND_PTY=/dev/shm/reflector_ctrl. To change a config variable: echo CFG GLOBAL SQL_TIMEOUT_BLOCKTIME 60 > /dev/shm/reflector_ctrl. To sign a client certificate: echo CA SIGN callsign > /dev/shm/reflector_ctrl."
  - help["CFG_DIR"] = "Specify the path to a directory that contain additional configuration files. If a relative path is specified, the path will be relative to the directory where the main configuration file is at. All files in the specified directory will be read as additional configuration. Filenames starting with a dot are ignored."
  - help["CERT_PKI_DIR"] = "The path to the directory containing PKI (Public Key Infrastructure) files. If a relative path is given, the value of the build time variable SVX_LOCAL_STATE_DIR (e.g. /var/lib/svxlink/) will be prepended. Default: pki/"
  - help["CERT_CA_KEYS_DIR"] = "The path to the directory containing private key files. If a relative path is given, the value of the CERT_PKI_DIR variable will be prepended. Default: private/"
  - help["CERT_CA_PENDING_CSRS_DIR"] = "The path to the directory containing unsigned CSR files. If a relative path is given, the value of the CERT_PKI_DIR variable will be prepended. Default: pending_csrs/"
  - help["CERT_CA_CSRS_DIR"] = "The path to the directory containing signed CSR files. If a relative path is given, the value of the CERT_PKI_DIR variable will be prepended. Default: csrs/"
  - help["CERT_CA_CERTS_DIR"] = "The path to the directory containing signed certificate files. If a relative path is given, the value of the CERT_PKI_DIR variable will be prepended. Default: certs/"
  - help["CERT_CA_HOOK"] = "Set to a path for an external application that is run on CA events like when a CSR is received or when a certificate is signed. The following environment variables will be set up before running the external application: CA_OP (set to PENDING_CSR_CREATE, PENDING_CSR_UPDATE or CSR_SIGNED), CA_CSR_PEM (CSR data in PEM format, not set for CSR_SIGNED), CA_CRT_PEM (Certificate data in PEM format, only for CSR_SIGNED)."
  - help["COMMON_NAME"] = "The common name (CN) used in the subject of the certificate."
  - help["ORG_UNIT"] = "The organizational unit (OU) used in the subject of the certificate. Example: ORG_UNIT=\"VHF/UHF-sektionen\""
  - help["ORG"] = "The organization name (O) used in the subject of the certificate. Example: ORG=SSA"
  - help["LOCALITY"] = "The locality name (L) used in the subject of the certificate. Example: LOCALITY=Boden"
  - help["STATE"] = "The name of the state or province (ST) used in the subject of the certificate. Example: STATE=Norrbotten"
  - help["COUNTRY"] = "The ISO country code (C) used in the subject of the certificate. Example: COUNTRY=SE"
  - help["EMAIL_ADDRESS"] = "The email address that can be used to get in contact with the owner of the certificate. Example: EMAIL_ADDRESS=sysop@svxlink.example.org"
  - help["SUBJECT_ALT_NAME"] = "A comma separated list of subject alternative names. Example: SUBJECT_ALT_NAME=DNS:public-hostname.example.org,IP:172.17.1.42"
  - help["ALLOW"] = "A regular expression that must match the whole callsign of the nodes that try to select this talkgroup. The regular expression standard used is the same as for ECMAScript with the exception that the backslash special patterns (e.g. \\s, \\d etc) must be expressed with double backslash notation. An example that match most Swedish callsigns and a specific Norwegian one is \"S[A-M]\\\\d.*|LA8PV\"."
  - help["AUTO_QSY_AFTER"] = "Set this to the number of seconds after which an automatic QSY to a random talkgroup is requested. This is typically used to keep call channels and wide area channels clear so that stations does not dwell there for too long. Auto QSY is only triggered directly after a talker stop event. The default is that auto QSY is disabled (AUTO_QSY_AFTER=0)."
  - help["SHOW_ACTIVITY"] = "If set to 0, do not indicate in the HTTP status message when the talkgroup is in use by a node. Default is 1 = show activity."
  - help["ALLOW_MONITOR"] = "A regular expression that must match the callsign of nodes allowed to monitor this talkgroup. Uses the same regex format as ALLOW."
  - help["LOCAL_PREFIX"] = "GeuReflector: A comma-separated list of TG number prefixes that this reflector owns. Talkgroups whose number starts with one of these prefixes belong to this reflector. Example: LOCAL_PREFIX=1 means this reflector owns TGs 1, 10, 100, 1234, etc."
  - help["CLUSTER_TGS"] = "GeuReflector: A comma-separated list of TG numbers that should be broadcast to ALL trunk peers regardless of prefix ownership. These are network-wide channels (like BrandMeister nationwide). Must not overlap with any LOCAL_PREFIX or REMOTE_PREFIX. Example: CLUSTER_TGS=222,2221,91"

  %body.text-ghtext
    = render 'shared/navbar', active: 'admin'

    -# Confirm delete modal
    #confirm-modal.fixed.inset-0.z-50.items-center.justify-center.hidden{style: "background: rgba(0,0,0,0.6)"}
      .bg-ghcard.border.border-gray-600.rounded-lg.p-5.max-w-sm.w-full.mx-4.shadow-xl
        .flex.items-center.gap-3.mb-3
          .w-10.h-10.rounded-full.flex.items-center.justify-center.shrink-0{class: "bg-red-500/15"}
            %i.bi.bi-exclamation-triangle.text-red-400
          %h6.text-base.font-semibold.text-gray-100 Remove this item?
        %p.text-sm.text-gray-400.mb-4 This can't be undone. You'll need to re-add it manually.
        .flex.justify-end.gap-2
          %button#confirm-cancel.px-3.py-1.5.rounded-md.border.border-gray-600.text-sm.text-gray-300.hover:text-gray-100.cursor-pointer{type: "button"} Cancel
          %button#confirm-delete.px-3.py-1.5.rounded-md.bg-red-600.hover:bg-red-700.text-sm.text-white.font-semibold.cursor-pointer{type: "button"}
            %i.bi.bi-trash3.mr-1
            Delete

    -# Generic danger confirm modal
    #danger-modal.fixed.inset-0.z-50.items-center.justify-center.hidden{style: "background: rgba(0,0,0,0.6)"}
      .bg-ghcard.border.border-gray-600.rounded-lg.p-5.max-w-sm.w-full.mx-4.shadow-xl
        .flex.items-center.gap-3.mb-3
          .w-10.h-10.rounded-full.flex.items-center.justify-center.shrink-0{class: "bg-red-500/15"}
            %i.bi.bi-exclamation-triangle.text-red-400
          %h6.text-base.font-semibold.text-gray-100#danger-title Action
        %p.text-sm.text-gray-400.mb-4#danger-body Are you sure?
        .flex.justify-end.gap-2
          %button#danger-cancel.px-3.py-1.5.rounded-md.border.border-gray-600.text-sm.text-gray-300.hover:text-gray-100.cursor-pointer{type: "button"} Cancel
          %button#danger-confirm.px-3.py-1.5.rounded-md.bg-red-600.hover:bg-red-700.text-sm.text-white.font-semibold.cursor-pointer{type: "button"}
            %i.bi.bi-trash3.mr-1
            %span#danger-confirm-label Confirm

    -# Backup browser modal
    #backup-modal.fixed.inset-0.z-50.items-center.justify-center.hidden{style: "background: rgba(0,0,0,0.6)"}
      .bg-ghcard.border.border-gray-600.rounded-lg.max-w-3xl.w-full.mx-4.shadow-xl.flex.flex-col{style: "max-height: 85vh"}
        .flex.items-center.justify-between.px-5.py-4.border-b.border-ghborder.shrink-0
          %h6.text-base.font-semibold.text-gray-100
            %i.bi.bi-clock-history.mr-2
            Configuration Backups
          %button.text-gray-400.hover:text-gray-200.cursor-pointer{type: "button", onclick: "closeBackups()"}
            %i.bi.bi-x-lg
        .flex.flex-1.overflow-hidden
          -# Backup list (left panel)
          #backup-list.border-r.border-ghborder.overflow-y-auto.shrink-0{style: "width: 220px"}
            .px-3.py-3.text-sm.text-ghmuted#backup-list-inner
              %span.text-ghdim Loading…
          -# Backup content (right panel)
          #backup-content.flex-1.overflow-y-auto.p-4
            %pre.text-xs.font-mono.text-gray-300.whitespace-pre-wrap#backup-content-pre
              %span.text-ghdim Select a backup to inspect

    -# CSR inspect modal
    #csr-modal.fixed.inset-0.z-50.items-center.justify-center.hidden{style: "background: rgba(0,0,0,0.6)"}
      .bg-ghcard.border.border-gray-600.rounded-lg.max-w-2xl.w-full.mx-4.shadow-xl.flex.flex-col{style: "max-height: 80vh"}
        .flex.items-center.justify-between.px-5.py-4.border-b.border-ghborder.shrink-0
          %h6.text-base.font-semibold.text-gray-100
            %i.bi.bi-file-earmark-lock.mr-2
            %span#csr-modal-title CSR Details
          %button.text-gray-400.hover:text-gray-200.cursor-pointer{type: "button", onclick: "closeCsrModal()"}
            %i.bi.bi-x-lg
        .flex-1.overflow-y-auto.p-5
          %pre.text-xs.font-mono.text-gray-300.whitespace-pre-wrap#csr-modal-body
            %span.text-ghdim Loading…

    -# Help popup modal
    #help-modal.fixed.inset-0.z-50.items-center.justify-center.hidden{style: "background: rgba(0,0,0,0.6)"}
      .bg-ghcard.border.border-gray-600.rounded-lg.p-5.max-w-md.w-full.mx-4.shadow-xl
        .flex.items-center.justify-between.mb-3
          %h6.text-base.font-semibold.text-gray-100#help-modal-title
          %button.text-gray-400.hover:text-gray-200.cursor-pointer{type: "button", onclick: "closeHelp()"}
            %i.bi.bi-x-lg
        %p.text-sm.text-gray-300.leading-relaxed#help-modal-body

    .max-w-3xl.mx-auto.px-4.pb-12
      .flex.items-center.justify-between.mb-6
        %h4.text-xl.font-semibold.text-gray-100
          %i.bi.bi-broadcast.mr-2
          Reflector

      - if flash[:notice]
        %div.p-2.rounded.border.border-green-700.text-green-400.text-sm.mb-4.flex.items-center.justify-between{class: "bg-green-900/30", id: "flash-notice"}
          %span= flash[:notice]
          %button.text-green-400.hover:text-green-200.cursor-pointer{type: "button", onclick: "this.parentElement.remove()"}
            %i.bi.bi-x

      -# ── Tab bar ──
      .flex.border-b.border-gray-600.mb-6
        %button.tab-btn.px-4.py-2.text-sm.font-semibold.border-b-2.cursor-pointer{type: "button", id: "tab-config", onclick: "switchTab('config')", class: "border-blue-500 text-blue-400"}
          %i.bi.bi-gear.mr-1
          Configuration
        %button.tab-btn.px-4.py-2.text-sm.font-semibold.border-b-2.cursor-pointer{type: "button", id: "tab-nodeblock", onclick: "switchTab('nodeblock')", class: "border-transparent text-gray-400 hover:text-gray-200"}
          %i.bi.bi-mic-mute.mr-1
          Node Block
        %button.tab-btn.px-4.py-2.text-sm.font-semibold.border-b-2.cursor-pointer{type: "button", id: "tab-certfiles", onclick: "switchTab('certfiles')", class: "border-transparent text-gray-400 hover:text-gray-200"}
          %i.bi.bi-file-earmark-lock.mr-1
          Certificate Files

      <div id="panel-config">
      = form_with url: admin_reflector_path, method: :patch, local: true do |f|

        -# ── 1. Global Settings ──
        .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
          .px-4.py-3.border-b.border-gray-600.flex.items-center.justify-between.cursor-pointer{onclick: "toggleSection('global')"}
            %h5.text-lg.font-semibold.text-gray-100
              %i.bi.bi-globe.mr-2
              Global Settings
            %i.bi.bi-chevron-down.accordion-chevron.text-gray-400{id: "chevron-global"}
          .accordion-body.px-4{id: "body-global"}
            %h6.text-sm.font-semibold.text-gray-400.mb-3.mt-1 Core
            .grid.grid-cols-1.md:grid-cols-2.gap-4.mb-4
              - %w[LISTEN_PORT HTTP_SRV_PORT CODECS].each do |key|
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1
                    = key
                    - if help[key]
                      %button.ml-1.text-gray-500.hover:text-blue-400.cursor-pointer{type: "button", onclick: "showHelp('#{key}')", title: "Help"}
                        %i.bi.bi-question-circle{style: "font-size: 0.75rem"}
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[global][#{key}]", value: @config.global[key]}

            %h6.text-sm.font-semibold.text-gray-400.mb-3 Access Control
            .grid.grid-cols-1.md:grid-cols-2.gap-4.mb-4
              - %w[ACCEPT_CALLSIGN REJECT_CALLSIGN ACCEPT_CERT_EMAIL].each do |key|
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1
                    = key
                    - if help[key]
                      %button.ml-1.text-gray-500.hover:text-blue-400.cursor-pointer{type: "button", onclick: "showHelp('#{key}')", title: "Help"}
                        %i.bi.bi-question-circle{style: "font-size: 0.75rem"}
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[global][#{key}]", value: @config.global[key]}

            %h6.text-sm.font-semibold.text-gray-400.mb-3 Timeouts
            .grid.grid-cols-1.md:grid-cols-2.gap-4.mb-4
              - %w[SQL_TIMEOUT SQL_TIMEOUT_BLOCKTIME].each do |key|
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1
                    = key
                    - if help[key]
                      %button.ml-1.text-gray-500.hover:text-blue-400.cursor-pointer{type: "button", onclick: "showHelp('#{key}')", title: "Help"}
                        %i.bi.bi-question-circle{style: "font-size: 0.75rem"}
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[global][#{key}]", value: @config.global[key]}

            %h6.text-sm.font-semibold.text-gray-400.mb-3 Advanced
            .grid.grid-cols-1.md:grid-cols-2.gap-4.mb-4
              - %w[TG_FOR_V1_CLIENTS RANDOM_QSY_RANGE TIMESTAMP_FORMAT COMMAND_PTY CFG_DIR].each do |key|
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1
                    = key
                    - if help[key]
                      %button.ml-1.text-gray-500.hover:text-blue-400.cursor-pointer{type: "button", onclick: "showHelp('#{key}')", title: "Help"}
                        %i.bi.bi-question-circle{style: "font-size: 0.75rem"}
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[global][#{key}]", value: @config.global[key]}

            %h6.text-sm.font-semibold.text-gray-400.mb-3 PKI Paths
            .grid.grid-cols-1.md:grid-cols-2.gap-4
              - %w[CERT_PKI_DIR CERT_CA_KEYS_DIR CERT_CA_PENDING_CSRS_DIR CERT_CA_CSRS_DIR CERT_CA_CERTS_DIR CERT_CA_HOOK].each do |key|
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1
                    = key
                    - if help[key]
                      %button.ml-1.text-gray-500.hover:text-blue-400.cursor-pointer{type: "button", onclick: "showHelp('#{key}')", title: "Help"}
                        %i.bi.bi-question-circle{style: "font-size: 0.75rem"}
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[global][#{key}]", value: @config.global[key]}

        -# ── 1b. Clustering / Trunking (collapsed) ──
        - is_satellite = @config.global['SATELLITE_OF'].present?
        .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
          .px-4.py-3.border-b.border-gray-600.flex.items-center.justify-between.cursor-pointer{onclick: "toggleSection('trunking')"}
            %h5.text-lg.font-semibold.text-gray-100
              %i.bi.bi-diagram-3.mr-2
              Clustering / Trunking
              %span.text-sm.font-normal.text-ghmuted.ml-2 GeuReflector
            .flex.items-center.gap-2
              %button.text-sm.px-3.py-1.rounded-md.border.border-gray-600.text-gray-600.cursor-not-allowed.opacity-50{type: "button", id: "btn-trunking", disabled: true, onclick: "event.stopPropagation(); addTrunkPeer()"}
                %i.bi.bi-plus.mr-1
                Add Trunk Peer
              %i.bi.bi-chevron-down.accordion-chevron.text-gray-400{id: "chevron-trunking"}
          .accordion-body.px-4{id: "body-trunking"}

            -# ── Mode selector ──
            %input{type: "hidden", name: "config[trunk_mode]", value: (is_satellite ? "satellite" : "reflector"), id: "trunk-mode-input"}
            .mb-4
              %label.block.text-sm.font-semibold.text-gray-400.mb-2 This reflector operates as:
              .inline-flex.rounded-lg.border.border-gray-600.overflow-hidden
                %button.px-4.py-2.text-sm.font-semibold.cursor-pointer.transition-colors{type: "button", id: "mode-btn-reflector", class: (is_satellite ? "text-gray-400 hover:text-gray-200" : "bg-blue-600 text-white"), onclick: "setTrunkMode('reflector')"}
                  %i.bi.bi-broadcast-pin.mr-1
                  Reflector
                %button.px-4.py-2.text-sm.font-semibold.cursor-pointer.transition-colors.border-l.border-gray-600{type: "button", id: "mode-btn-satellite", class: (is_satellite ? "bg-purple-600 text-white" : "text-gray-400 hover:text-gray-200"), onclick: "setTrunkMode('satellite')"}
                  %i.bi.bi-broadcast.mr-1
                  Satellite

            -# ════════════════════════════════════════════════════════════════
            -# REFLECTOR MODE sections
            -# ════════════════════════════════════════════════════════════════
            #trunk-mode-reflector{class: (is_satellite ? 'hidden' : nil)}
              .p-2.rounded.border.text-xs.mb-4{class: "border-blue-700/50 text-blue-400 bg-blue-900/20"}
                %i.bi.bi-info-circle.mr-1
                Reflector mode: this instance owns talkgroups and can trunk with other reflectors. Configure your local TG prefix, cluster TGs, trunk peers, and optionally accept satellite connections.

              %h6.text-sm.font-semibold.text-gray-400.mb-3 TG Ownership
              .grid.grid-cols-1.md:grid-cols-2.gap-4.mb-4
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1
                    LOCAL_PREFIX
                    %button.ml-1.text-gray-500.hover:text-blue-400.cursor-pointer{type: "button", onclick: "showHelp('LOCAL_PREFIX')", title: "Help"}
                      %i.bi.bi-question-circle{style: "font-size: 0.75rem"}
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[global][LOCAL_PREFIX]", value: @config.global['LOCAL_PREFIX'], placeholder: "e.g. 1,24"}
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1
                    CLUSTER_TGS
                    %button.ml-1.text-gray-500.hover:text-blue-400.cursor-pointer{type: "button", onclick: "showHelp('CLUSTER_TGS')", title: "Help"}
                      %i.bi.bi-question-circle{style: "font-size: 0.75rem"}
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[global][CLUSTER_TGS]", value: @config.global['CLUSTER_TGS'], placeholder: "e.g. 222,2221,91"}

              %h6.text-sm.font-semibold.text-gray-400.mb-3 Trunk Peers
              #trunk-peers.space-y-4
                - @config.trunks.keys.sort.each do |trunk_name|
                  - trunk = @config.trunks[trunk_name]
                  .trunk-peer.border.border-gray-700.rounded-lg.p-4.relative
                    %button.absolute.top-2.right-2.text-red-400.hover:text-red-300.cursor-pointer{type: "button", onclick: "confirmRemove(this, '.trunk-peer')"}
                      %i.bi.bi-x-lg
                    .grid.grid-cols-1.md:grid-cols-2.gap-3
                      .col-span-1
                        %label.block.text-sm.text-gray-500.mb-1 Section Name
                        %input.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[trunk_names][]", value: trunk_name, placeholder: "TRUNK_2"}
                      .col-span-1
                        %label.block.text-sm.text-gray-500.mb-1 HOST
                        %input.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[trunk_hosts][]", value: trunk['HOST']}
                      .col-span-1
                        %label.block.text-sm.text-gray-500.mb-1 PORT
                        %input.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[trunk_ports][]", value: (trunk['PORT'] || '5302')}
                      .col-span-1
                        %label.block.text-sm.text-gray-500.mb-1 SECRET
                        %input.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[trunk_secrets][]", value: trunk['SECRET']}
                      .col-span-2
                        %label.block.text-sm.text-gray-500.mb-1 REMOTE_PREFIX (comma-separated)
                        %input.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[trunk_remote_prefixes][]", value: trunk['REMOTE_PREFIX'], placeholder: "2,3"}

              %h6.text-sm.font-semibold.text-gray-400.mb-3.mt-4 Accept Satellite Connections
              .p-2.rounded.border.text-xs.mb-3{class: "border-gray-700 text-ghmuted bg-ghbg"}
                %i.bi.bi-info-circle.mr-1
                Optional. Configure a listener so satellite instances can connect to this reflector.
              .grid.grid-cols-1.md:grid-cols-2.gap-4.mb-4
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1 LISTEN_PORT
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[satellite][LISTEN_PORT]", value: @config.satellite['LISTEN_PORT'], placeholder: "5303"}
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1 SECRET
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[satellite][SECRET]", value: @config.satellite['SECRET']}

            -# ════════════════════════════════════════════════════════════════
            -# SATELLITE MODE sections
            -# ════════════════════════════════════════════════════════════════
            #trunk-mode-satellite{class: (is_satellite ? nil : 'hidden')}
              .p-2.rounded.border.text-xs.mb-4{class: "border-purple-700/50 text-purple-300 bg-purple-900/20"}
                %i.bi.bi-info-circle.mr-1
                Satellite mode: this instance connects to a parent reflector and relays traffic. It does not own talkgroups, manage trunk peers, or accept satellite connections. Only configure the parent connection below.

              %h6.text-sm.font-semibold.text-gray-400.mb-3 Parent Reflector Connection
              .grid.grid-cols-1.md:grid-cols-2.gap-4.mb-4
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1 SATELLITE_OF (parent host)
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[global][SATELLITE_OF]", value: @config.global['SATELLITE_OF'], placeholder: "reflector-01.example.com", id: "satellite-of-input"}
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1 SATELLITE_PORT
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[global][SATELLITE_PORT]", value: (@config.global['SATELLITE_PORT'] || '5303')}
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1 SATELLITE_SECRET
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[global][SATELLITE_SECRET]", value: @config.global['SATELLITE_SECRET']}
                .mb-1
                  %label.block.text-sm.text-gray-500.mb-1 SATELLITE_ID
                  %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[global][SATELLITE_ID]", value: @config.global['SATELLITE_ID']}

        -# ── 2. Certificates (collapsed) ──
        .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
          .px-4.py-3.border-b.border-gray-600.flex.items-center.justify-between.cursor-pointer{onclick: "toggleSection('certs')"}
            %h5.text-lg.font-semibold.text-gray-100
              %i.bi.bi-shield-lock.mr-2
              Certificates
              - if @has_certs
                %i.bi.bi-lock-fill.text-yellow-400.text-sm.ml-2
            %i.bi.bi-chevron-down.accordion-chevron.text-gray-400{id: "chevron-certs"}
          .accordion-body.px-4{id: "body-certs"}
            - if @has_certs
              .p-3.rounded.border.text-sm.mb-4.flex.items-center.gap-2{class: "border-yellow-700/50 text-yellow-400 bg-yellow-900/20"}
                %i.bi.bi-lock-fill
                Certificates are already generated. To modify these fields, reset PKI from the
                %strong Certificate Files
                tab first.
            - cert_fields = %w[COMMON_NAME ORG_UNIT ORG LOCALITY STATE COUNTRY EMAIL_ADDRESS SUBJECT_ALT_NAME]
            - [["ROOT_CA", :root_ca, @config.root_ca], ["ISSUING_CA", :issuing_ca, @config.issuing_ca], ["SERVER_CERT", :server_cert, @config.server_cert]].each do |label, param_key, data|
              %h6.text-sm.font-semibold.text-gray-400.mb-3.mt-4= label
              .grid.grid-cols-1.md:grid-cols-2.gap-4.mb-2
                - cert_fields.each do |key|
                  .mb-1
                    %label.block.text-sm.text-gray-500.mb-1
                      = key
                      - if help[key]
                        %button.ml-1.text-gray-500.hover:text-blue-400.cursor-pointer{type: "button", onclick: "showHelp('#{key}')", title: "Help"}
                          %i.bi.bi-question-circle{style: "font-size: 0.75rem"}
                    %input.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[#{param_key}][#{key}]", value: data[key], disabled: @has_certs}

        -# ── 3. Users (collapsed) ──
        .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
          .px-4.py-3.border-b.border-gray-600.flex.items-center.justify-between.cursor-pointer{onclick: "toggleSection('users')"}
            %h5.text-lg.font-semibold.text-gray-100
              %i.bi.bi-people.mr-2
              Users
            .flex.items-center.gap-2
              %button.text-sm.px-3.py-1.rounded-md.border.border-gray-600.text-gray-600.cursor-not-allowed.opacity-50{type: "button", id: "btn-users", disabled: true, onclick: "event.stopPropagation(); addUserRow()"}
                %i.bi.bi-plus.mr-1
                Add
              %i.bi.bi-chevron-down.accordion-chevron.text-gray-400{id: "chevron-users"}
          .accordion-body.px-4{id: "body-users"}
            %table.w-full.text-sm
              %thead
                %tr.text-gray-500.text-left
                  %th.pb-2.pr-2 Callsign
                  %th.pb-2.pr-2 Password Group
                  %th.pb-2.w-10
              %tbody#users-tbody
                - @config.users.each do |callsign, group|
                  %tr.border-t.border-gray-700
                    %td.py-2.pr-2
                      %input.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[user_callsigns][]", value: callsign}
                    %td.py-2.pr-2
                      %select.user-group-select.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", name: "config[user_groups][]", data: { selected: group }}
                    %td.py-2.text-center
                      %button.text-red-400.hover:text-red-300.cursor-pointer{type: "button", onclick: "confirmRemove(this, 'tr')"}
                        %i.bi.bi-x-lg

        -# ── 4. Passwords (collapsed) ──
        .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
          .px-4.py-3.border-b.border-gray-600.flex.items-center.justify-between.cursor-pointer{onclick: "toggleSection('passwords')"}
            %h5.text-lg.font-semibold.text-gray-100
              %i.bi.bi-key.mr-2
              Passwords
            .flex.items-center.gap-2
              %button.text-sm.px-3.py-1.rounded-md.border.border-gray-600.text-gray-600.cursor-not-allowed.opacity-50{type: "button", id: "btn-passwords", disabled: true, onclick: "event.stopPropagation(); addPasswordRow()"}
                %i.bi.bi-plus.mr-1
                Add
              %i.bi.bi-chevron-down.accordion-chevron.text-gray-400{id: "chevron-passwords"}
          .accordion-body.px-4{id: "body-passwords"}
            %table.w-full.text-sm
              %thead
                %tr.text-gray-500.text-left
                  %th.pb-2.pr-2 Group Name
                  %th.pb-2.pr-2 Password
                  %th.pb-2.w-10
              %tbody#passwords-tbody
                - @config.passwords.each do |name, password|
                  %tr.border-t.border-gray-700
                    %td.py-2.pr-2
                      %input.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[password_names][]", value: name}
                    %td.py-2.pr-2
                      %input.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[password_values][]", value: password}
                    %td.py-2.text-center
                      %button.text-red-400.hover:text-red-300.cursor-pointer{type: "button", onclick: "confirmRemove(this, 'tr')"}
                        %i.bi.bi-x-lg

        -# ── 5. Talkgroup Rules (collapsed) ──
        .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
          .px-4.py-3.border-b.border-gray-600.flex.items-center.justify-between.cursor-pointer{onclick: "toggleSection('tg')"}
            %h5.text-lg.font-semibold.text-gray-100
              %i.bi.bi-collection.mr-2
              Talkgroup Rules
            .flex.items-center.gap-2
              %button.text-sm.px-3.py-1.rounded-md.border.border-gray-600.text-gray-600.cursor-not-allowed.opacity-50{type: "button", id: "btn-tg", disabled: true, onclick: "event.stopPropagation(); addTgRule()"}
                %i.bi.bi-plus.mr-1
                Add TG Rule
              %i.bi.bi-chevron-down.accordion-chevron.text-gray-400{id: "chevron-tg"}
          .accordion-body.px-4{id: "body-tg"}
            #tg-rules.space-y-4
              - @config.tg_rules.keys.sort.each do |tg_num|
                - rules = @config.tg_rules[tg_num]
                .tg-rule.border.border-gray-700.rounded-lg.p-4.relative
                  %button.absolute.top-2.right-2.text-red-400.hover:text-red-300.cursor-pointer{type: "button", onclick: "confirmRemove(this, '.tg-rule')"}
                    %i.bi.bi-x-lg
                  .grid.grid-cols-1.md:grid-cols-2.gap-3
                    .col-span-1
                      %label.block.text-sm.text-gray-500.mb-1 TG Number
                      %input.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "number", name: "config[tg_numbers][]", value: tg_num, min: 1}
                    .col-span-1
                      %label.block.text-sm.text-gray-500.mb-1
                        ALLOW (regex)
                        %button.ml-1.text-gray-500.hover:text-blue-400.cursor-pointer{type: "button", onclick: "showHelp('ALLOW')", title: "Help"}
                          %i.bi.bi-question-circle{style: "font-size: 0.75rem"}
                      %input.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[tg_allows][]", value: rules["ALLOW"], placeholder: "^.*$"}
                    .col-span-1
                      %label.block.text-sm.text-gray-500.mb-1
                        AUTO_QSY_AFTER (seconds)
                        %button.ml-1.text-gray-500.hover:text-blue-400.cursor-pointer{type: "button", onclick: "showHelp('AUTO_QSY_AFTER')", title: "Help"}
                          %i.bi.bi-question-circle{style: "font-size: 0.75rem"}
                      %input.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "number", name: "config[tg_auto_qsys][]", value: rules["AUTO_QSY_AFTER"]}
                    .col-span-1
                      %label.block.text-sm.text-gray-500.mb-1
                        SHOW_ACTIVITY
                        %button.ml-1.text-gray-500.hover:text-blue-400.cursor-pointer{type: "button", onclick: "showHelp('SHOW_ACTIVITY')", title: "Help"}
                          %i.bi.bi-question-circle{style: "font-size: 0.75rem"}
                      %select.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", name: "config[tg_show_activities][]"}
                        %option{value: "", selected: rules["SHOW_ACTIVITY"].blank?} (not set)
                        %option{value: "1", selected: rules["SHOW_ACTIVITY"] == "1"} Yes
                        %option{value: "0", selected: rules["SHOW_ACTIVITY"] == "0"} No
                    .col-span-1
                      %label.block.text-sm.text-gray-500.mb-1
                        ALLOW_MONITOR (regex)
                        %button.ml-1.text-gray-500.hover:text-blue-400.cursor-pointer{type: "button", onclick: "showHelp('ALLOW_MONITOR')", title: "Help"}
                          %i.bi.bi-question-circle{style: "font-size: 0.75rem"}
                      %input.w-full.px-2.py-1.rounded.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", name: "config[tg_allow_monitors][]", value: rules["ALLOW_MONITOR"], placeholder: "^.*$"}

        -# ── Save ──
        .flex.gap-2
          = f.submit "Save configuration & Restart SvxReflector", class: "px-4 py-2 rounded-md bg-blue-600 hover:bg-blue-700 text-white font-semibold cursor-pointer"
          %button.px-4.py-2.rounded-md.border.border-gray-600.text-gray-400.hover:text-gray-200.cursor-pointer{type: "button", onclick: "openBackups()"}
            %i.bi.bi-clock-history.mr-1
            Backups
          = link_to "Back", admin_users_path, class: "px-4 py-2 rounded-md border border-gray-600 text-gray-400 hover:text-gray-200"

      </div>
      <div id="panel-nodeblock" style="display:none">
      -# ── Node Block (runtime, outside the form) ──
      .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
        .px-4.py-3.border-b.border-gray-600.flex.items-center.justify-between.cursor-pointer{onclick: "toggleSection('nodeblock')"}
          %h5.text-lg.font-semibold.text-gray-100
            %i.bi.bi-mic-mute.mr-2
            Node Block
            %span.text-sm.font-normal.text-ghmuted.ml-2 Temporarily mute a node
          %i.bi.bi-chevron-down.accordion-chevron.text-gray-400{id: "chevron-nodeblock"}
        .accordion-body.px-4{id: "body-nodeblock"}
          %p.text-xs.text-ghmuted.mb-3
            Block a node from transmitting for a set duration. The node can still listen but cannot talk.
            The block resets each time the node tries to transmit. Set to 0 seconds to unblock.
          .flex.flex-wrap.items-end.gap-3
            .flex-1{style: "min-width: 160px"}
              %label.block.text-sm.text-gray-500.mb-1 Callsign
              %input#block-callsign.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]", type: "text", placeholder: "e.g. SM0ABC-1"}
            .flex-1{style: "min-width: 140px"}
              %label.block.text-sm.text-gray-500.mb-1 Duration
              %select#block-duration.w-full.px-3.py-2.rounded-md.border.border-gray-600.text-sm{class: "bg-[#0d1117]"}
                %option{value: "0"} Unblock (0s)
                %option{value: "60"} 1 minute
                %option{value: "300", selected: true} 5 minutes
                %option{value: "600"} 10 minutes
                %option{value: "1800"} 30 minutes
                %option{value: "3600"} 1 hour
            %button#block-btn.px-4.py-2.rounded-md.bg-orange-600.hover:bg-orange-700.text-white.font-semibold.cursor-pointer.text-sm{type: "button", onclick: "blockNode()"}
              %i.bi.bi-mic-mute.mr-1
              Block
          #block-result.mt-3.text-sm

      </div>
      <div id="panel-certfiles" style="display:none">
      -# ── Pending Certificates ──
      .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
        .px-4.py-3.border-b.border-gray-600.flex.items-center.justify-between.cursor-pointer{onclick: "toggleSection('csrs')"}
          %h5.text-lg.font-semibold.text-gray-100
            %i.bi.bi-shield-check.mr-2
            Pending Certificates
            %span.text-sm.font-normal.text-ghmuted.ml-2#csr-count
          .flex.items-center.gap-2
            %button.text-sm.px-3.py-1.rounded-md.border.border-gray-600.text-gray-600.cursor-not-allowed.opacity-50{type: "button", id: "btn-csrs", disabled: true, onclick: "event.stopPropagation(); loadCsrs()"}
              %i.bi.bi-arrow-clockwise.mr-1
              Refresh
            %i.bi.bi-chevron-down.accordion-chevron.text-gray-400{id: "chevron-csrs"}
        .accordion-body.px-4{id: "body-csrs"}
          #csrs-content.text-sm.text-ghmuted
            %span.text-ghdim Click Refresh to load pending certificate requests.

      -# ── Our Certificates ──
      .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
        .px-4.py-3.border-b.border-gray-600.flex.items-center.justify-between.cursor-pointer{onclick: "toggleSection('ourcerts')"}
          %h5.text-lg.font-semibold.text-gray-100
            %i.bi.bi-award.mr-2
            Our Certificates
          .flex.items-center.gap-2
            %button.text-sm.px-3.py-1.rounded-md.border.border-red-800.text-gray-600.cursor-not-allowed.opacity-50{type: "button", id: "btn-reset-pki", disabled: true, onclick: "event.stopPropagation(); resetPki()"}
              %i.bi.bi-trash3.mr-1
              Reset PKI
            %a.text-sm.px-3.py-1.rounded-md.border.border-gray-600.text-gray-600.cursor-not-allowed.opacity-50{id: "btn-ourcerts", href: "#{export_ca_bundle_admin_reflector_path}", onclick: "event.stopPropagation()", style: "pointer-events:none"}
              %i.bi.bi-download.mr-1
              Export CA Bundle
            %i.bi.bi-chevron-down.accordion-chevron.text-gray-400{id: "chevron-ourcerts"}
        .accordion-body.px-4{id: "body-ourcerts"}
          #ourcerts-content.text-sm.text-ghmuted
            %span.text-ghdim Loading…
      </div>

    :javascript
      function switchTab(tab) {
        ['config', 'nodeblock', 'certfiles'].forEach(function(t) {
          document.getElementById('panel-' + t).style.display = t === tab ? '' : 'none';
        });
        document.querySelectorAll('.tab-btn').forEach(function(btn) {
          var active = btn.id === 'tab-' + tab;
          btn.classList.toggle('border-blue-500', active);
          btn.classList.toggle('text-blue-400', active);
          btn.classList.toggle('border-transparent', !active);
          btn.classList.toggle('text-gray-400', !active);
        });
        if (tab === 'nodeblock') {
          var nbBody = document.getElementById('body-nodeblock');
          if (!nbBody.classList.contains('open')) toggleSection('nodeblock');
        }
        if (tab === 'certfiles') {
          var csrBody = document.getElementById('body-csrs');
          if (!csrBody.classList.contains('open')) toggleSection('csrs');
          var ourBody = document.getElementById('body-ourcerts');
          if (!ourBody.classList.contains('open')) toggleSection('ourcerts');
        }
      }

      var HELP_TEXTS = #{help.to_json};

      function openModal(id) { var m = document.getElementById(id); m.classList.remove('hidden'); m.classList.add('flex'); }
      function closeModal(id) { var m = document.getElementById(id); m.classList.add('hidden'); m.classList.remove('flex'); }

      function showHelp(key) {
        document.getElementById('help-modal-title').textContent = key;
        document.getElementById('help-modal-body').textContent = HELP_TEXTS[key] || 'No description available.';
        openModal('help-modal');
      }
      function closeHelp() {
        closeModal('help-modal');
      }
      document.getElementById('help-modal').addEventListener('click', function(e) {
        if (e.target === this) closeHelp();
      });

      (function() {
        var flash = document.getElementById('flash-notice');
        if (flash) setTimeout(function() { flash.style.transition = 'opacity 0.5s'; flash.style.opacity = '0'; setTimeout(function() { flash.remove(); }, 500); }, 5000);
      })();

      var _confirmTarget = null;
      function confirmRemove(btn, selector) {
        _confirmTarget = btn.closest(selector);
        openModal('confirm-modal');
      }
      document.getElementById('confirm-delete').addEventListener('click', function() {
        if (_confirmTarget) _confirmTarget.remove();
        _confirmTarget = null;
        closeModal('confirm-modal');
        syncGroupSelects();
      });
      document.getElementById('confirm-cancel').addEventListener('click', function() {
        _confirmTarget = null;
        closeModal('confirm-modal');
      });
      document.getElementById('confirm-modal').addEventListener('click', function(e) {
        if (e.target === this) { _confirmTarget = null; closeModal('confirm-modal'); }
      });

      function toggleSection(id) {
        var body = document.getElementById('body-' + id);
        var chevron = document.getElementById('chevron-' + id);
        body.classList.toggle('open');
        chevron.classList.toggle('open');
        var btn = document.getElementById('btn-' + id);
        if (btn) {
          var open = body.classList.contains('open');
          btn.disabled = !open;
          btn.classList.toggle('opacity-50', !open);
          btn.classList.toggle('cursor-not-allowed', !open);
          btn.classList.toggle('text-gray-600', !open);
          btn.classList.toggle('cursor-pointer', open);
          btn.classList.toggle('text-gray-400', open);
          btn.classList.toggle('hover:text-gray-200', open);
        }
        if (id === 'csrs' && body.classList.contains('open')) loadCsrs();
        if (id === 'ourcerts' && body.classList.contains('open')) loadOurCerts();
        if (id === 'ourcerts') {
          var isOpen = body.classList.contains('open');
          // Export button (link)
          var exportBtn = document.getElementById('btn-ourcerts');
          if (exportBtn) {
            exportBtn.style.pointerEvents = isOpen ? 'auto' : 'none';
            exportBtn.classList.toggle('opacity-50', !isOpen);
            exportBtn.classList.toggle('cursor-not-allowed', !isOpen);
            exportBtn.classList.toggle('text-gray-600', !isOpen);
            exportBtn.classList.toggle('cursor-pointer', isOpen);
            exportBtn.classList.toggle('text-gray-400', isOpen);
            exportBtn.classList.toggle('hover:text-gray-200', isOpen);
          }
          // Reset PKI button
          var resetBtn = document.getElementById('btn-reset-pki');
          if (resetBtn) {
            resetBtn.disabled = !isOpen;
            resetBtn.classList.toggle('opacity-50', !isOpen);
            resetBtn.classList.toggle('cursor-not-allowed', !isOpen);
            resetBtn.classList.toggle('text-gray-600', !isOpen);
            resetBtn.classList.toggle('cursor-pointer', isOpen);
            resetBtn.classList.toggle('text-red-400', isOpen);
            resetBtn.classList.toggle('hover:text-red-300', isOpen);
          }
        }
      }

      function getPasswordGroups() {
        var groups = [];
        document.querySelectorAll('#passwords-tbody input[name="config[password_names][]"]').forEach(function(el) {
          var v = el.value.trim();
          if (v) groups.push(v);
        });
        return groups;
      }

      function syncGroupSelects() {
        var groups = getPasswordGroups();
        document.querySelectorAll('.user-group-select').forEach(function(sel) {
          var current = sel.value || sel.dataset.selected || '';
          sel.innerHTML = '';
          groups.forEach(function(g) {
            var opt = document.createElement('option');
            opt.value = g;
            opt.textContent = g;
            if (g === current) opt.selected = true;
            sel.appendChild(opt);
          });
          delete sel.dataset.selected;
        });
      }

      document.getElementById('passwords-tbody').addEventListener('input', function(e) {
        if (e.target.name === 'config[password_names][]') syncGroupSelects();
      });

      syncGroupSelects();

