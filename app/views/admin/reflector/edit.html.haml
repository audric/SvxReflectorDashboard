      }

      function addTgRule() {
        var container = document.getElementById('tg-rules');
        var div = document.createElement('div');
        div.className = 'tg-rule border border-gray-700 rounded-lg p-4 relative';
        div.innerHTML = '<button type="button" class="absolute top-2 right-2 text-red-400 hover:text-red-300 cursor-pointer" onclick="this.closest(\'.tg-rule\').remove()"><i class="bi bi-x-lg"></i></button>' +
          '<div class="grid grid-cols-1 md:grid-cols-2 gap-3">' +
            '<div class="col-span-1"><label class="block text-sm text-gray-500 mb-1">TG Number</label><input class="w-full px-2 py-1 rounded border border-gray-600 text-sm bg-[#0d1117]" type="number" name="config[tg_numbers][]" min="1" placeholder="1"></div>' +
            '<div class="col-span-1"><label class="block text-sm text-gray-500 mb-1">ALLOW (regex) <button type="button" class="ml-1 text-gray-500 hover:text-blue-400 cursor-pointer" onclick="showHelp(\'ALLOW\')" title="Help"><i class="bi bi-question-circle" style="font-size:0.75rem"></i></button></label><input class="w-full px-2 py-1 rounded border border-gray-600 text-sm bg-[#0d1117]" type="text" name="config[tg_allows][]" placeholder="^.*$"></div>' +
            '<div class="col-span-1"><label class="block text-sm text-gray-500 mb-1">AUTO_QSY_AFTER (seconds) <button type="button" class="ml-1 text-gray-500 hover:text-blue-400 cursor-pointer" onclick="showHelp(\'AUTO_QSY_AFTER\')" title="Help"><i class="bi bi-question-circle" style="font-size:0.75rem"></i></button></label><input class="w-full px-2 py-1 rounded border border-gray-600 text-sm bg-[#0d1117]" type="number" name="config[tg_auto_qsys][]"></div>' +
            '<div class="col-span-1"><label class="block text-sm text-gray-500 mb-1">SHOW_ACTIVITY <button type="button" class="ml-1 text-gray-500 hover:text-blue-400 cursor-pointer" onclick="showHelp(\'SHOW_ACTIVITY\')" title="Help"><i class="bi bi-question-circle" style="font-size:0.75rem"></i></button></label><select class="w-full px-2 py-1 rounded border border-gray-600 text-sm bg-[#0d1117]" name="config[tg_show_activities][]"><option value="">(not set)</option><option value="1">Yes</option><option value="0">No</option></select></div>' +
            '<div class="col-span-1"><label class="block text-sm text-gray-500 mb-1">ALLOW_MONITOR (regex) <button type="button" class="ml-1 text-gray-500 hover:text-blue-400 cursor-pointer" onclick="showHelp(\'ALLOW_MONITOR\')" title="Help"><i class="bi bi-question-circle" style="font-size:0.75rem"></i></button></label><input class="w-full px-2 py-1 rounded border border-gray-600 text-sm bg-[#0d1117]" type="text" name="config[tg_allow_monitors][]" placeholder="^.*$"></div>' +
          '</div>';
        container.appendChild(div);
        var body = document.getElementById('body-tg');
        if (!body.classList.contains('open')) toggleSection('tg');
      }
