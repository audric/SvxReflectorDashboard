%html{lang: "en"}
  :javascript
    (function(){var t=localStorage.getItem('theme')||'auto';var r=(t==='auto'?(window.matchMedia('(prefers-color-scheme:light)').matches?'light':'auto'):t);document.documentElement.setAttribute('data-theme',r);})();
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title SVXReflector · Edit User
    %script{src: "/vendor/tailwind/tailwind.js"}
    :javascript
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ghbg: '#0d1117',
              ghcard: '#161b22',
              ghborder: '#30363d',
              ghborder2: '#21262d',
              ghtext: '#c9d1d9',
              ghmuted: '#8b949e',
              ghdim: '#6e7681',
            }
          }
        }
      }
    %link{rel: "stylesheet", href: "/vendor/bootstrap-icons/font/bootstrap-icons.min.css"}
    :css
      body { background: #0d1117; }

  %body.text-ghtext
    = render 'shared/navbar', active: 'admin'

    .max-w-lg.mx-auto.px-4
      .rounded-lg.border.border-gray-600.bg-ghcard
        .px-4.py-3.border-b.border-gray-600
          %h5.text-lg.font-semibold.text-gray-100
            %i.bi.bi-pencil-square.mr-2
            Edit #{@user.callsign}
        .p-4
          = render 'form', user: @user
