!!!
%html{lang: "en"}
  :javascript
    (function(){var t=localStorage.getItem('theme')||'auto';var r=(t==='auto'?(window.matchMedia('(prefers-color-scheme:light)').matches?'light':'auto'):t);document.documentElement.setAttribute('data-theme',r);})();
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title= "SVXReflector #{@reflector_host} · Web Users"
    %script{src: "/vendor/tailwind/tailwind.js"}
    :javascript
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ghbg: '#0d1117',
              ghcard: '#161b22',
              ghborder: '#30363d',
              ghborder2: '#21262d',
              ghtext: '#c9d1d9',
              ghmuted: '#8b949e',
              ghdim: '#6e7681',
            }
          }
        }
      }
    %link{rel: "stylesheet", href: "/vendor/bootstrap-icons/font/bootstrap-icons.min.css"}
    = csrf_meta_tags
    :css
      body { background: #0d1117; }
      .admin-table th { font-size: .73rem; text-transform: uppercase; letter-spacing: .05em; color: #6e7681; border-color: #21262d; }
      .admin-table td { font-size: .85rem; border-color: #21262d; vertical-align: middle; }

  %body.text-ghtext
    = render 'shared/navbar', active: 'admin'

    #confirm-modal.fixed.inset-0.z-50.items-center.justify-center.hidden{style: "background: rgba(0,0,0,0.6)"}
      .bg-ghcard.border.border-gray-600.rounded-lg.p-5.max-w-sm.w-full.mx-4.shadow-xl
        .flex.items-center.gap-3.mb-3
          .w-10.h-10.rounded-full.flex.items-center.justify-center.shrink-0{class: "bg-red-500/15"}
            %i.bi.bi-exclamation-triangle.text-red-400
          %h6.text-base.font-semibold.text-gray-100#confirm-title Delete this user?
        %p.text-sm.text-gray-400.mb-4 This action cannot be undone.
        .flex.justify-end.gap-2
          %button#confirm-cancel.px-3.py-1.5.rounded-md.border.border-gray-600.text-sm.text-gray-300.hover:text-gray-100.cursor-pointer{type: "button"} Cancel
          %button#confirm-delete.px-3.py-1.5.rounded-md.bg-red-600.hover:bg-red-700.text-sm.text-white.font-semibold.cursor-pointer{type: "button"}
            %i.bi.bi-trash3.mr-1
            Delete

    .max-w-7xl.mx-auto.px-4.pb-12
      .flex.items-center.justify-between.mb-6
        %h4.text-xl.font-semibold.text-gray-100
          %i.bi.bi-people.mr-2
          Web Users
        = link_to new_admin_user_path, class: "inline-block text-sm px-3 py-1.5 rounded-md bg-blue-600 hover:bg-blue-700 text-white font-semibold" do
          %i.bi.bi-plus-lg.mr-1
          New User

      - if flash[:notice]
        %div.p-2.rounded.border.border-green-700.text-green-400.text-sm.mb-4.flex.items-center.justify-between{class: "bg-green-900/30", id: "flash-notice"}
          %span= flash[:notice]
          %button.text-green-400.hover:text-green-200.cursor-pointer{type: "button", onclick: "this.parentElement.remove()"}
            %i.bi.bi-x
      - if flash[:alert]
        %div.p-2.rounded.border.border-red-700.text-red-400.text-sm.mb-4.flex.items-center.justify-between{class: "bg-red-900/30", id: "flash-alert"}
          %span= flash[:alert]
          %button.text-red-400.hover:text-red-200.cursor-pointer{type: "button", onclick: "this.parentElement.remove()"}
            %i.bi.bi-x

      .overflow-x-auto
        %table.w-full.text-left.admin-table
          %thead
            %tr.border-b.border-ghborder2
              %th.py-2.px-3 Callsign
              %th.py-2 Name
              %th.py-2 Email
              %th.py-2 Mobile
              %th.py-2 Telegram
              %th.py-2 Role
              %th.py-2 Refl. Admin
              %th.py-2 Monitor
              %th.py-2 TX
              %th.py-2 Status
              %th.py-2 Last Login
              %th.py-2.text-right.pr-3 Actions
          %tbody
            - @users.each do |user|
              %tr.border-b.border-ghborder2.hover:bg-ghcard
                %td.py-2.px-3.font-mono.font-bold= user.callsign
                %td.py-2= user.name
                %td.py-2
                  - if user.email.present?
                    %a.text-cyan-400.hover:underline{href: "mailto:#{user.email}"}= user.email
                %td.py-2= user.mobile
                %td.py-2
                  - if user.telegram.present?
                    %span.text-cyan-400= user.telegram
                %td.py-2
                  - if user.admin?
                    %span.inline-block.px-2.py-0.5.text-xs.rounded-full.bg-yellow-600.text-yellow-100 admin
                  - else
                    %span.inline-block.px-2.py-0.5.text-xs.rounded-full.bg-gray-600.text-gray-200 user
                %td.py-2
                  - if user.reflector_admin?
                    %i.bi.bi-broadcast.text-yellow-400{title: "Reflector admin"}
                %td.py-2
                  - if user.can_monitor?
                    %i.bi.bi-headphones.text-green-400{title: "Can monitor"}
                %td.py-2
                  - if user.can_transmit?
                    %i.bi.bi-mic-fill.text-green-400{title: "Can transmit"}
                %td.py-2
                  - if user.approved?
                    %span.inline-block.px-2.py-0.5.text-xs.rounded-full.bg-green-700.text-green-100 approved
                  - else
                    %span.inline-block.px-2.py-0.5.text-xs.rounded-full.bg-orange-600.text-orange-100 pending
                %td.py-2.text-sm.text-ghmuted
                  - if user.last_sign_in_at.present?
                    %span{title: user.last_sign_in_at.strftime("%Y-%m-%d %H:%M:%S UTC")}= time_ago_in_words(user.last_sign_in_at) + " ago"
                  - else
                    %span.text-ghdim never
                %td.py-2.text-right.pr-3
                  .inline-flex.gap-1.justify-end
                    - unless user.approved?
                      = button_to approve_admin_user_path(user), method: :patch, class: "inline-block text-sm px-2 py-1 rounded border border-green-700 text-green-400 hover:text-green-300", form_class: "inline" do
                        %i.bi.bi-check-lg
                    = link_to edit_admin_user_path(user), class: "inline-block text-sm px-2 py-1 rounded border border-gray-600 text-gray-400 hover:text-gray-200" do
                      %i.bi.bi-pencil
                    - unless user == current_user
                      %button.inline-block.text-sm.px-2.py-1.rounded.border.border-red-700.text-red-400.hover:text-red-300.cursor-pointer{type: "button", onclick: "confirmDelete('#{user.callsign}', '#{admin_user_path(user)}')"}
                        %i.bi.bi-trash

    :javascript
      (function() {
        ['flash-notice', 'flash-alert'].forEach(function(id) {
          var el = document.getElementById(id);
          if (el) setTimeout(function() { el.style.transition = 'opacity 0.5s'; el.style.opacity = '0'; setTimeout(function() { el.remove(); }, 500); }, 5000);
        });
      })();

      var _deleteUrl = null;
      function confirmDelete(name, url) {
        _deleteUrl = url;
        document.getElementById('confirm-title').textContent = 'Delete user "' + name + '"?';
        document.getElementById('confirm-modal').style.display = 'flex';
      }
      document.getElementById('confirm-delete').addEventListener('click', function() {
        if (!_deleteUrl) return;
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = _deleteUrl;
        var method = document.createElement('input');
        method.type = 'hidden'; method.name = '_method'; method.value = 'delete';
        form.appendChild(method);
        var token = document.querySelector('meta[name="csrf-token"]');
        if (token) {
          var csrf = document.createElement('input');
          csrf.type = 'hidden'; csrf.name = 'authenticity_token'; csrf.value = token.content;
          form.appendChild(csrf);
        }
        document.body.appendChild(form);
        form.submit();
      });
      document.getElementById('confirm-cancel').addEventListener('click', function() {
        _deleteUrl = null;
        document.getElementById('confirm-modal').style.display = 'none';
      });
      document.getElementById('confirm-modal').addEventListener('click', function(e) {
        if (e.target === this) { _deleteUrl = null; this.style.display = 'none'; }
      });
