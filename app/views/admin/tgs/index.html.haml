!!!
%html{lang: "en"}
  :javascript
    (function(){var t=localStorage.getItem('theme');if(t==='light')document.documentElement.classList.add('light-theme');})();
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title SVXReflector · Talkgroups
    %script{src: "/vendor/tailwind/tailwind.js"}
    :javascript
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ghbg: '#0d1117',
              ghcard: '#161b22',
              ghborder: '#30363d',
              ghborder2: '#21262d',
              ghtext: '#c9d1d9',
              ghmuted: '#8b949e',
              ghdim: '#6e7681',
            }
          }
        }
      }
    %link{rel: "stylesheet", href: "/vendor/bootstrap-icons/font/bootstrap-icons.min.css"}
    :css
      body { background: #0d1117; }
      .admin-table th { font-size: .73rem; text-transform: uppercase; letter-spacing: .05em; color: #6e7681; border-color: #21262d; }
      .admin-table td { font-size: .85rem; border-color: #21262d; vertical-align: middle; }

  %body.text-ghtext
    = render 'shared/navbar', active: 'admin'

    .max-w-5xl.mx-auto.px-4
      .flex.justify-between.items-center.mb-4
        %h5.text-lg.font-semibold.text-gray-100
          %i.bi.bi-collection.mr-2
          Talkgroups
        = link_to new_admin_tg_path, class: "inline-block text-sm px-3 py-1.5 rounded-md bg-blue-600 hover:bg-blue-700 text-white font-semibold" do
          %i.bi.bi-plus-lg.mr-1
          New TG

      - if flash[:notice]
        %div.p-2.rounded.border.border-green-700.text-green-400.text-sm.mb-4{class: "bg-green-900/30", id: "flash-notice"}= flash[:notice]
      - if flash[:alert]
        %div.p-2.rounded.border.border-red-700.text-red-400.text-sm.mb-4{class: "bg-red-900/30", id: "flash-alert"}= flash[:alert]

      - if @tgs.empty?
        .text-center.text-ghmuted.py-8
          %i.bi.bi-collection.text-2xl.block.mb-2
          No talkgroups defined yet.
      - else
        .overflow-x-auto
          %table.w-full.text-left.admin-table
            %thead
              %tr.border-b.border-ghborder2
                %th.py-2.px-3 TG
                %th.py-2 Name
                %th.py-2 Description
                %th.py-2.text-right.pr-3 Actions
            %tbody
              - @tgs.each do |tg|
                %tr.border-b.border-ghborder2.hover:bg-ghcard
                  %td.py-2.px-3.font-mono.font-bold= tg.tg
                  %td.py-2= tg.name
                  %td.py-2.text-ghmuted.text-sm.truncate{style: "max-width:400px;"}= tg.description
                  %td.py-2.text-right.pr-3
                    .inline-flex.gap-1.justify-end
                      = link_to edit_admin_tg_path(tg), class: "inline-block text-sm px-2 py-1 rounded border border-gray-600 text-gray-400 hover:text-gray-200" do
                        %i.bi.bi-pencil
                      = button_to admin_tg_path(tg), method: :delete, class: "inline-block text-sm px-2 py-1 rounded border border-red-700 text-red-400 hover:text-red-300", form_class: "inline", form: { data: { turbo_confirm: "Delete TG #{tg.tg}?" } } do
                        %i.bi.bi-trash
