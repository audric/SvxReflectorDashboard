= form_with model: [:admin, node_class], local: true do |f|
  - if node_class.errors.any?
    %div.p-2.rounded.border.border-red-700.text-red-400.text-sm.mb-4{class: "bg-red-900/30"}
      %ul.mb-0.list-disc.pl-4
        - node_class.errors.full_messages.each do |msg|
          %li= msg

  .mb-4
    = f.label :name, "Name", class: "block text-sm text-gray-500 mb-1"
    = f.text_field :name, class: "w-full px-3 py-2 rounded-md border border-gray-600 bg-[#0d1117] text-gray-100 focus:outline-none focus:border-blue-500"

  .flex.gap-2
    = f.submit (node_class.persisted? ? "Update Class" : "Create Class"), class: "px-4 py-2 rounded-md bg-blue-600 hover:bg-blue-700 text-white font-semibold cursor-pointer"
    = link_to "Cancel", admin_node_classes_path, class: "px-4 py-2 rounded-md border border-gray-600 text-gray-400 hover:text-gray-200"
