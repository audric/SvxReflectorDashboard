%html{lang: "en"}
  :javascript
    (function(){var t=localStorage.getItem('theme')||'auto';var r=(t==='auto'?(window.matchMedia('(prefers-color-scheme:light)').matches?'light':'auto'):t);document.documentElement.setAttribute('data-theme',r);})();
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title SVXReflector · New Bridge
    %script{src: "/vendor/tailwind/tailwind.js"}
    :javascript
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ghbg: '#0d1117',
              ghcard: '#161b22',
              ghborder: '#30363d',
              ghborder2: '#21262d',
              ghtext: '#c9d1d9',
              ghmuted: '#8b949e',
              ghdim: '#6e7681',
            }
          }
        }
      }
    %link{rel: "stylesheet", href: "/vendor/bootstrap-icons/font/bootstrap-icons.min.css"}
    :css
      body { background: #0d1117; }

  %body.text-ghtext
    = render 'shared/navbar', active: 'admin'

    .max-w-3xl.mx-auto.px-4.pb-12
      - if @bridge.echolink?
        = render 'form_echolink'
      - elsif @bridge.xlx?
        = render 'form_xlx'
      - elsif @bridge.dmr?
        = render 'form_dmr'
      - elsif @bridge.ysf?
        = render 'form_ysf'
      - elsif @bridge.allstar?
        = render 'form_allstar'
      - else
        = render 'form'
