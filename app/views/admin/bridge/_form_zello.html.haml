- if @bridge.errors.any?
  .p-3.rounded.border.border-red-700.text-red-400.text-sm.mb-4{class: "bg-red-900/30"}
    %p.font-semibold.mb-1= "#{@bridge.errors.count} error(s):"
    %ul.list-disc.ml-4
      - @bridge.errors.full_messages.each do |msg|
        %li= msg

= form_with model: [:admin, @bridge], local: true do |f|
  = f.hidden_field :bridge_type, value: "zello"

  -# ── Name ──
  .rounded-lg.border.border-gray-600.bg-ghcard.mb-4.p-4
    %label.block.text-sm.font-semibold.text-gray-400.mb-2 Bridge Name
    = f.text_field :name, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. Zello IW1GEU"
    - if @bridge.persisted?
      #name-warn.p-2.rounded.border.text-sm.mt-2.items-center.gap-2.hidden{class: "border-yellow-700/50 text-yellow-400 bg-yellow-900/20"}
        %i.bi.bi-exclamation-triangle.mr-1
        Changing the name will recreate the container.

  -# ── Zello Account ──
  .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
    .px-4.py-3.border-b.border-gray-600
      %h5.text-lg.font-semibold.text-gray-100
        %i.bi.bi-phone.mr-2
        Zello Account
    .px-4.py-4
      .grid.grid-cols-1.md:grid-cols-2.gap-4
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 USERNAME
          = f.text_field :zello_username, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "Zello username"
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 PASSWORD
          = f.password_field :zello_password, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "Zello password", value: @bridge.zello_password
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 CHANNEL
          = f.text_field :zello_channel, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. My Channel"
          %p.text-xs.text-ghmuted.mt-1 Zello channel to bridge audio to/from
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 CHANNEL PASSWORD
          = f.password_field :zello_channel_password, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "Leave empty if none", value: @bridge.zello_channel_password
          %p.text-xs.text-ghmuted.mt-1 Password for the Zello channel (optional)
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 ISSUER ID
          = f.text_field :zello_issuer_id, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "From developers.zello.com"
          %p.text-xs.text-ghmuted.mt-1
            Get credentials from
            %a.text-blue-400.hover:underline{href: "https://developers.zello.com/keys", target: "_blank"} developers.zello.com

      .mt-2
        %label.block.text-sm.text-gray-500.mb-1 PRIVATE KEY (PEM)
        = f.text_area :zello_private_key, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext font-mono", rows: 6, placeholder: "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----", style: "resize: vertical"
        %p.text-xs.text-ghmuted.mt-1 RS256 private key for JWT authentication. Paste the full PEM content.

  -# ── Node Info ──
  .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
    .px-4.py-3.border-b.border-gray-600
      %h5.text-lg.font-semibold.text-gray-100
        %i.bi.bi-info-circle.mr-2
        Node Info
    .px-4.py-4
      .grid.grid-cols-1.md:grid-cols-2.gap-4
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 NODE_LOCATION
          = f.text_field :node_location, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. Milan, Italy"
          %p.text-xs.text-ghmuted.mt-1 Defaults to bridge name if empty.
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 SYSOP
          = f.text_field :sysop, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. F1ABC"

  -# ── Local Reflector ──
  .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
    .px-4.py-3.border-b.border-gray-600
      %h5.text-lg.font-semibold.text-gray-100
        %i.bi.bi-broadcast.mr-2
        Local SVXReflector
    .px-4.py-4
      .grid.grid-cols-1.md:grid-cols-2.gap-4
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 HOST
          = f.text_field :local_host, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "svxreflector"
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 PORT
          = f.number_field :local_port, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "5300"
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 CALLSIGN
          = f.text_field :local_callsign, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. F4ABC-ZELLO"
          %p.text-xs.text-ghmuted.mt-1 Callsign for the bridge on the local reflector
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 AUTH_KEY
          = f.text_field :local_auth_key, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "Shared secret"
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 TALKGROUP
          = f.number_field :local_default_tg, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "1"
          %p.text-xs.text-ghmuted.mt-1 TG to bridge to the Zello channel

  -# ── Save ──
  .flex.items-center.justify-between
    = link_to admin_bridges_path, class: "px-4 py-2 rounded-md border border-gray-600 text-sm text-gray-300 hover:text-gray-100" do
      %i.bi.bi-arrow-left.mr-1
      Cancel
    = f.submit(@bridge.persisted? ? "Update Bridge" : "Create Bridge", class: "px-4 py-2 rounded-md bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold cursor-pointer")

- if @bridge.persisted?
  :javascript
    (function() {
      var inp = document.querySelector('input[name="bridge[name]"]');
      if (!inp) return;
      var orig = inp.dataset.original;
      inp.addEventListener('input', function() {
        document.getElementById('name-warn').classList.toggle('hidden', inp.value === orig);
      });
    })();
