!!!
%html{lang: "en"}
  :javascript
    (function(){var t=localStorage.getItem('theme')||'auto';var r=(t==='auto'?(window.matchMedia('(prefers-color-scheme:light)').matches?'light':'auto'):t);document.documentElement.setAttribute('data-theme',r);})();
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title SVXReflector · Bridges
    = csrf_meta_tags
    %script{src: "/vendor/tailwind/tailwind.js"}
    :javascript
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ghbg: '#0d1117',
              ghcard: '#161b22',
              ghborder: '#30363d',
              ghborder2: '#21262d',
              ghtext: '#c9d1d9',
              ghmuted: '#8b949e',
              ghdim: '#6e7681',
            }
          }
        }
      }
    %link{rel: "stylesheet", href: "/vendor/bootstrap-icons/font/bootstrap-icons.min.css"}
    :css
      body { background: #0d1117; }
      .bridge-filter-btn.active { background: #1f3a5f; color: #79c0ff; }

  %body.text-ghtext
    = render 'shared/navbar', active: 'admin'

    -# Confirm delete modal
    #confirm-modal.fixed.inset-0.z-50.items-center.justify-center.hidden{style: "background: rgba(0,0,0,0.6)"}
      .bg-ghcard.border.border-gray-600.rounded-lg.p-5.max-w-sm.w-full.mx-4.shadow-xl
        .flex.items-center.gap-3.mb-3
          .w-10.h-10.rounded-full.flex.items-center.justify-center.shrink-0{class: "bg-red-500/15"}
            %i.bi.bi-exclamation-triangle.text-red-400
          %h6.text-base.font-semibold.text-gray-100#confirm-title Delete this bridge?
        %p.text-sm.text-gray-400.mb-4 This will stop the container and remove all configuration. This can't be undone.
        .flex.justify-end.gap-2
          %button#confirm-cancel.px-3.py-1.5.rounded-md.border.border-gray-600.text-sm.text-gray-300.hover:text-gray-100.cursor-pointer{type: "button"} Cancel
          %button#confirm-delete.px-3.py-1.5.rounded-md.bg-red-600.hover:bg-red-700.text-sm.text-white.font-semibold.cursor-pointer{type: "button"}
            %i.bi.bi-trash3.mr-1
            Delete

    .max-w-7xl.mx-auto.px-4.pb-12
      - if flash[:notice]
        %div.p-2.rounded.border.border-green-700.text-green-400.text-sm.mb-4.flex.items-center.justify-between{class: "bg-green-900/30", id: "flash-notice"}
          %span= flash[:notice]
          %button.text-green-400.hover:text-green-200.cursor-pointer{type: "button", onclick: "this.parentElement.remove()"}
            %i.bi.bi-x

      .flex.items-center.justify-between.mb-6
        %h4.text-xl.font-semibold.text-gray-100
          %i.bi.bi-diagram-3.mr-2
          Bridges
        .relative.inline-block{id: "new-bridge-dropdown"}
          %button.px-3.py-2.rounded-md.bg-blue-600.hover:bg-blue-700.text-white.text-sm.font-semibold.cursor-pointer.flex.items-center.gap-1{type: "button", onclick: "toggleNewMenu()"}
            %i.bi.bi-plus.mr-1
            New Bridge
            %i.bi.bi-chevron-down{style: "font-size: 0.6rem"}
          - bridge_meta = {'reflector' => ['bi-diagram-3', 'Reflector'], 'echolink' => ['bi-headset', 'EchoLink'], 'xlx' => ['bi-globe', 'XLX'], 'dmr' => ['bi-broadcast-pin', 'DMR'], 'ysf' => ['bi-soundwave', 'YSF'], 'allstar' => ['bi-telephone', 'AllStar'], 'zello' => ['bi-phone', 'Zello']}
          #new-menu.absolute.right-0.mt-1.w-48.rounded-md.border.border-gray-600.bg-ghcard.shadow-xl.z-50.hidden
            - Bridge::BRIDGE_TYPES.each_with_index do |bt, i|
              - icon, label = bridge_meta[bt] || ['bi-link-45deg', bt.titleize]
              - rounded = i == 0 ? 'rounded-t-md' : (i == Bridge::BRIDGE_TYPES.size - 1 ? 'rounded-b-md' : '')
              = link_to new_admin_bridge_path(type: bt), class: "flex items-center gap-2 px-4 py-2 text-sm text-gray-300 hover:bg-ghborder2 #{rounded}" do
                %i.bi{class: icon}
                = "#{label} Bridge"

      - counts = @bridges.group_by(&:bridge_type).transform_values(&:size)
      - visible_types = (Bridge::BRIDGE_TYPES | counts.keys) & Bridge::ALL_BRIDGE_TYPES
      .inline-flex.rounded.border.border-ghborder.overflow-hidden.mb-4#bridge-filters
        %button.bridge-filter-btn.px-3.py-1.5.text-sm.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors{type: "button", "data-filter" => "all"}
          All
          %span.ml-1.text-xs.opacity-70= @bridges.size
        - visible_types.each do |bt|
          - icon, label = bridge_meta[bt] || ['bi-link-45deg', bt.titleize]
          %button.bridge-filter-btn.px-3.py-1.5.text-sm.text-ghmuted.hover:text-gray-200.cursor-pointer.transition-colors.border-l.border-ghborder{type: "button", "data-filter" => bt}
            %i.bi{class: "#{icon} mr-1"}
            = label
            %span.ml-1.text-xs.opacity-70= counts[bt] || 0

      - if @bridges.empty?
        .rounded-lg.border.border-gray-600.bg-ghcard.p-8.text-center
          %i.bi.bi-diagram-3.text-3xl.text-ghdim.block.mb-2
          %p.text-ghmuted No bridges configured yet.
          %p.text-sm.text-ghdim.mt-1 Create a bridge to connect this reflector to another.

      - else
        .space-y-3
          - @bridges.each do |bridge|
            - status = @container_statuses[bridge.id]
            - running = status == "running"
            .rounded-lg.border.border-gray-600.bg-ghcard.p-4{"data-bridge-type" => bridge.bridge_type}
              .flex.items-start.justify-between
                .flex-1
                  .flex.items-center.gap-3.mb-2
                    %h5.text-base.font-semibold.text-gray-100= bridge.name
                    - if bridge.echolink?
                      %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-purple-900.text-purple-400.border.border-purple-700
                        %i.bi.bi-headset{style: "font-size: 0.6rem"}
                        EchoLink
                    - elsif bridge.xlx?
                      %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-emerald-900.text-emerald-400.border.border-emerald-700
                        %i.bi.bi-globe{style: "font-size: 0.6rem"}
                        XLX
                    - elsif bridge.dmr?
                      %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-amber-900.text-amber-400.border.border-amber-700
                        %i.bi.bi-broadcast-pin{style: "font-size: 0.6rem"}
                        DMR
                    - elsif bridge.ysf?
                      %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-cyan-900.text-cyan-400.border.border-cyan-700
                        %i.bi.bi-soundwave{style: "font-size: 0.6rem"}
                        YSF
                    - elsif bridge.allstar?
                      %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-teal-900.text-teal-400.border.border-teal-700
                        %i.bi.bi-telephone{style: "font-size: 0.6rem"}
                        AllStar
                    - else
                      %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-blue-900.text-blue-400.border.border-blue-700
                        %i.bi.bi-diagram-3{style: "font-size: 0.6rem"}
                        Reflector
                    - if bridge.enabled?
                      - if running
                        %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-green-900.text-green-400.border.border-green-700
                          %i.bi.bi-circle-fill{style: "font-size: 0.4rem"}
                          Running
                      - elsif status == "exited" || status == "dead"
                        %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-red-900.text-red-400.border.border-red-700
                          %i.bi.bi-circle-fill{style: "font-size: 0.4rem"}
                          Exited
                      - elsif status == "created" || status == "restarting"
                        %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-yellow-900.text-yellow-400.border.border-yellow-700
                          %i.bi.bi-circle-fill{style: "font-size: 0.4rem"}
                          Starting
                      - else
                        %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-red-900.text-red-400.border.border-red-700
                          %i.bi.bi-circle-fill{style: "font-size: 0.4rem"}
                          Not found
                    - else
                      %span.inline-flex.items-center.gap-1.px-2.py-0.5.rounded-full.text-xs.font-medium.bg-gray-800.text-gray-500.border.border-gray-700
                        %i.bi.bi-circle-fill{style: "font-size: 0.4rem"}
                        Stopped

                  .text-sm
                    - if bridge.echolink?
                      .flex.items-center.gap-2
                        %span.text-ghmuted EchoLink:
                        %span.text-gray-300.font-mono= bridge.echolink_callsign
                      .flex.items-center.gap-2
                        %span.text-ghmuted Reflector:
                        %span.text-gray-300.font-mono= "#{bridge.local_callsign}@#{bridge.local_host}:#{bridge.local_port} TG#{bridge.local_default_tg}"
                      - if bridge.sysop.present?
                        .flex.items-center.gap-2
                          %span.text-ghmuted Sysop:
                          %span.text-gray-300= bridge.sysop
                    - elsif bridge.xlx?
                      .flex.items-center.gap-2
                        %span.text-ghmuted XLX:
                        %span.text-gray-300.font-mono= "#{bridge.xlx_host}:#{bridge.xlx_port || 30051} Module #{bridge.xlx_module}"
                      .flex.items-center.gap-2
                        %span.text-ghmuted Reflector:
                        %span.text-gray-300.font-mono= "#{bridge.local_callsign}@#{bridge.local_host}:#{bridge.local_port} TG#{bridge.local_default_tg}"
                    - elsif bridge.dmr?
                      .flex.items-center.gap-2
                        %span.text-ghmuted DMR:
                        %span.text-gray-300.font-mono= "#{bridge.dmr_host}:#{bridge.dmr_port || 62030} TG#{bridge.dmr_talkgroup} TS#{bridge.dmr_timeslot}"
                      .flex.items-center.gap-2
                        %span.text-ghmuted DMR ID:
                        %span.text-gray-300.font-mono= bridge.dmr_id
                      .flex.items-center.gap-2
                        %span.text-ghmuted Reflector:
                        %span.text-gray-300.font-mono= "#{bridge.local_callsign}@#{bridge.local_host}:#{bridge.local_port} TG#{bridge.local_default_tg}"
                    - elsif bridge.ysf?
                      .flex.items-center.gap-2
                        %span.text-ghmuted YSF:
                        %span.text-gray-300.font-mono= "#{bridge.ysf_host}:#{bridge.ysf_port || 42000}"
                      - if bridge.ysf_callsign.present?
                        .flex.items-center.gap-2
                          %span.text-ghmuted Callsign:
                          %span.text-gray-300.font-mono= bridge.ysf_callsign
                      .flex.items-center.gap-2
                        %span.text-ghmuted Reflector:
                        %span.text-gray-300.font-mono= "#{bridge.local_callsign}@#{bridge.local_host}:#{bridge.local_port} TG#{bridge.local_default_tg}"
                    - elsif bridge.allstar?
                      .flex.items-center.gap-2
                        %span.text-ghmuted AllStar:
                        %span.text-gray-300.font-mono= "Node #{bridge.allstar_node} @ #{bridge.allstar_server}:#{bridge.allstar_port || 4569}"
                      .flex.items-center.gap-2
                        %span.text-ghmuted Reflector:
                        %span.text-gray-300.font-mono= "#{bridge.local_callsign}@#{bridge.local_host}:#{bridge.local_port} TG#{bridge.local_default_tg}"
                    - elsif bridge.zello?
                      .flex.items-center.gap-2
                        %span.text-ghmuted Zello:
                        %span.text-gray-300.font-mono= "#{bridge.zello_username} @ #{bridge.zello_channel}"
                      .flex.items-center.gap-2
                        %span.text-ghmuted Reflector:
                        %span.text-gray-300.font-mono= "#{bridge.local_callsign}@#{bridge.local_host}:#{bridge.local_port} TG#{bridge.local_default_tg}"
                    - else
                      .flex.items-center.gap-2
                        %span.text-ghmuted Local:
                        %span.text-gray-300.font-mono= "#{bridge.local_callsign}@#{bridge.local_host}:#{bridge.local_port}"
                      .flex.items-center.gap-2
                        %span.text-ghmuted Remote:
                        %span.text-gray-300.font-mono= "#{bridge.remote_callsign}@#{bridge.remote_host}:#{bridge.remote_port}"
                      - if bridge.sysop.present?
                        .flex.items-center.gap-2
                          %span.text-ghmuted Sysop:
                          %span.text-gray-300= bridge.sysop
                      .flex.items-center.gap-2.mt-1
                        %span.text-ghmuted Mappings:
                        - bridge.bridge_tg_mappings.each do |m|
                          %span.inline-block.px-2.py-0.5.text-xs.font-mono.rounded.border.border-ghborder2.text-gray-300= "#{m.local_tg} \u2194 #{m.remote_tg}"

                - last_lines = @container_last_lines[bridge.id]
                - if last_lines.present?
                  - has_error = last_lines.include?('error') || last_lines.include?('Error') || last_lines.include?('failed') || last_lines.include?('denied')
                  .mt-2.rounded-md.border.px-3.py-2.font-mono.text-xs.overflow-x-auto{class: has_error ? "border-red-800 bg-red-950/30 text-red-300" : "border-gray-700 bg-[#0d1117] text-gray-500", style: "max-height:5rem; white-space:pre-wrap; word-break:break-all"}
                    = last_lines.strip

                .flex.items-center.gap-2.ml-4
                  = link_to edit_admin_bridge_path(bridge), class: "p-2 rounded-md text-gray-400 hover:text-gray-200 hover:bg-ghborder2", title: "Edit" do
                    %i.bi.bi-pencil
                  %button.p-2.rounded-md.text-gray-400.hover:text-gray-200.hover:bg-ghborder2.cursor-pointer{type: "button", title: "Backups", onclick: "openBackups('#{backups_admin_bridge_path(bridge)}', '#{j bridge.name}')"}
                    %i.bi.bi-clock-history
                  - if bridge.enabled? && status
                    %button.p-2.rounded-md.text-gray-400.hover:text-gray-200.hover:bg-ghborder2.cursor-pointer{type: "button", title: "Logs", onclick: "openLogs('#{logs_admin_bridge_path(bridge)}', '#{j bridge.name}')"}
                      %i.bi.bi-terminal
                  - show_stop = bridge.enabled? && running
                  = button_to toggle_admin_bridge_path(bridge), method: :patch, class: "p-2 rounded-md hover:bg-ghborder2 cursor-pointer #{show_stop ? 'text-yellow-400 hover:text-yellow-300' : 'text-green-400 hover:text-green-300'}", title: show_stop ? "Stop" : "Start" do
                    %i.bi{class: show_stop ? "bi-stop-fill" : "bi-play-fill"}
                  - if running
                    %button.p-2.rounded-md.text-gray-600.cursor-not-allowed{type: "button", title: "Stop the bridge before deleting", disabled: true}
                      %i.bi.bi-trash3
                  - else
                    %button.p-2.rounded-md.text-red-400.hover:text-red-300.hover:bg-ghborder2.cursor-pointer{type: "button", title: "Delete", onclick: "confirmDelete('#{j bridge.name}', '#{admin_bridge_path(bridge)}')"}
                      %i.bi.bi-trash3

    -# Logs modal
    #logs-modal.fixed.inset-0.z-50.items-center.justify-center.hidden{style: "background: rgba(0,0,0,0.6)"}
      .bg-ghcard.border.border-gray-600.rounded-lg.max-w-4xl.w-full.mx-4.shadow-xl.flex.flex-col{style: "max-height: 85vh"}
        .flex.items-center.justify-between.px-5.py-4.border-b.border-ghborder.shrink-0
          %h6.text-base.font-semibold.text-gray-100#logs-modal-title
            %i.bi.bi-terminal.mr-2
            Container Logs
          .flex.items-center.gap-2
            %button.px-3.py-1.rounded-md.border.border-gray-600.text-xs.text-gray-400.hover:text-gray-200.cursor-pointer{type: "button", onclick: "refreshLogs()", title: "Refresh"}
              %i.bi.bi-arrow-clockwise.mr-1
              Refresh
            %button.text-gray-400.hover:text-gray-200.cursor-pointer{type: "button", onclick: "closeLogs()"}
              %i.bi.bi-x-lg
        .flex-1.overflow-auto.p-4
          %pre.text-xs.font-mono.text-gray-300.whitespace-pre-wrap#logs-modal-content
            %span.text-ghdim Loading...

    -# Backup browser modal
    #backup-modal.fixed.inset-0.z-50.items-center.justify-center.hidden{style: "background: rgba(0,0,0,0.6)"}
      .bg-ghcard.border.border-gray-600.rounded-lg.max-w-3xl.w-full.mx-4.shadow-xl.flex.flex-col{style: "max-height: 85vh"}
        .flex.items-center.justify-between.px-5.py-4.border-b.border-ghborder.shrink-0
          %h6.text-base.font-semibold.text-gray-100#backup-modal-title
            %i.bi.bi-clock-history.mr-2
            Configuration Backups
          %button.text-gray-400.hover:text-gray-200.cursor-pointer{type: "button", onclick: "closeBackups()"}
            %i.bi.bi-x-lg
        .flex.flex-1.overflow-hidden
          #backup-list.border-r.border-ghborder.overflow-y-auto.shrink-0{style: "width: 220px"}
            .px-3.py-3.text-sm.text-ghmuted#backup-list-inner
              %span.text-ghdim Select a bridge to view backups
          #backup-content.flex-1.overflow-y-auto.p-4
            %pre.text-xs.font-mono.text-gray-300.whitespace-pre-wrap#backup-content-pre
              %span.text-ghdim Select a backup to inspect

    :javascript
      (function() {
        var flash = document.getElementById('flash-notice');
        if (flash) setTimeout(function() { flash.style.transition = 'opacity 0.5s'; flash.style.opacity = '0'; setTimeout(function() { flash.remove(); }, 500); }, 5000);
      })();

      function toggleNewMenu() {
        document.getElementById('new-menu').classList.toggle('hidden');
      }
      document.addEventListener('click', function(e) {
        var dd = document.getElementById('new-bridge-dropdown');
        if (dd && !dd.contains(e.target)) document.getElementById('new-menu').classList.add('hidden');
      });

      var _deleteUrl = null;
      function confirmDelete(name, url) {
        _deleteUrl = url;
        document.getElementById('confirm-title').textContent = 'Delete bridge "' + name + '"?';
        document.getElementById('confirm-modal').style.display = 'flex';
      }
      document.getElementById('confirm-delete').addEventListener('click', function() {
        if (!_deleteUrl) return;
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = _deleteUrl;
        var method = document.createElement('input');
        method.type = 'hidden';
        method.name = '_method';
        method.value = 'delete';
        form.appendChild(method);
        var token = document.querySelector('meta[name="csrf-token"]');
        if (token) {
          var csrf = document.createElement('input');
          csrf.type = 'hidden';
          csrf.name = 'authenticity_token';
          csrf.value = token.content;
          form.appendChild(csrf);
        }
        document.body.appendChild(form);
        form.submit();
      });
      document.getElementById('confirm-cancel').addEventListener('click', function() {
        _deleteUrl = null;
        document.getElementById('confirm-modal').style.display = 'none';
      });
      document.getElementById('confirm-modal').addEventListener('click', function(e) {
        if (e.target === this) { _deleteUrl = null; this.style.display = 'none'; }
      });

      // ── Logs modal ──
      var _logsUrl = null;
      function openLogs(url, name) {
        _logsUrl = url;
        var modal = document.getElementById('logs-modal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.getElementById('logs-modal-title').innerHTML = '<i class="bi bi-terminal mr-2"></i>Logs \u2014 ' + name;
        refreshLogs();
      }
      function closeLogs() {
        var modal = document.getElementById('logs-modal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        _logsUrl = null;
      }
      function refreshLogs() {
        if (!_logsUrl) return;
        var content = document.getElementById('logs-modal-content');
        content.innerHTML = '<span class="text-ghdim">Loading...</span>';
        fetch(_logsUrl + '?tail=200')
          .then(function(r) { return r.json(); })
          .then(function(data) {
            var text = (data.logs || 'No logs available').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            // Highlight errors in red
            text = text.replace(/(.*(?:error|Error|failed|denied|fatal|FATAL|panic).*)$/gm, '<span class="text-red-400">$1</span>');
            content.innerHTML = text;
            content.scrollTop = content.scrollHeight;
          })
          .catch(function() { content.innerHTML = '<span class="text-red-400">Failed to load logs</span>'; });
      }
      document.getElementById('logs-modal').addEventListener('click', function(e) {
        if (e.target === this) closeLogs();
      });

      var _backupCache = {};
      function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
      function openBackups(url, name) {
        var modal = document.getElementById('backup-modal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.getElementById('backup-modal-title').textContent = 'Backups \u2014 ' + name;
        var listEl = document.getElementById('backup-list-inner');
        document.getElementById('backup-content-pre').innerHTML = '<span class="text-ghdim">Select a backup to inspect</span>';
        if (_backupCache[url]) { renderBackupList(_backupCache[url]); return; }
        listEl.innerHTML = '<span class="text-ghdim">Loading\u2026</span>';
        fetch(url)
          .then(function(r) { return r.json(); })
          .then(function(data) { _backupCache[url] = data; renderBackupList(data); })
          .catch(function() { listEl.innerHTML = '<span class="text-red-400">Failed to load backups</span>'; });
      }
      function closeBackups() {
        var modal = document.getElementById('backup-modal');
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
      document.getElementById('backup-modal').addEventListener('click', function(e) {
        if (e.target === this) closeBackups();
      });
      function renderBackupList(backups) {
        var list = document.getElementById('backup-list-inner');
        if (!backups.length) { list.innerHTML = '<span class="text-ghdim">No backups available</span>'; return; }
        list.innerHTML = '';
        backups.forEach(function(b, i) {
          var btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'w-full text-left px-3 py-2 rounded-md text-sm hover:bg-ghborder2 cursor-pointer transition-colors text-gray-300 backup-item';
          btn.innerHTML = '<div class="font-mono text-xs">' + esc(b.label) + '</div><div class="text-xs text-ghdim mt-0.5">' + b.files.length + ' file' + (b.files.length === 1 ? '' : 's') + '</div>';
          btn.addEventListener('click', function() {
            document.querySelectorAll('.backup-item').forEach(function(el) { el.classList.remove('bg-ghborder2', 'text-gray-100'); });
            btn.classList.add('bg-ghborder2', 'text-gray-100');
            var html = '';
            b.files.forEach(function(f, j) {
              if (j > 0) html += '\n';
              html += '\u2500\u2500 ' + esc(f.name) + ' \u2500\u2500\n' + esc(f.content) + '\n';
            });
            document.getElementById('backup-content-pre').textContent = '';
            document.getElementById('backup-content-pre').innerHTML = html;
          });
          list.appendChild(btn);
          if (i === 0) btn.click();
        });
      }

      (function() {
        var filterBtns = document.querySelectorAll('.bridge-filter-btn');
        var current = 'all';
        function applyFilter() {
          filterBtns.forEach(function(b) { b.classList.toggle('active', b.dataset.filter === current); });
          document.querySelectorAll('[data-bridge-type]').forEach(function(card) {
            card.style.display = (current === 'all' || card.dataset.bridgeType === current) ? '' : 'none';
          });
        }
        applyFilter();
        filterBtns.forEach(function(btn) {
          btn.addEventListener('click', function() {
            current = btn.dataset.filter;
            applyFilter();
          });
        });
      })();
