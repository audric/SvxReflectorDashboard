- if @bridge.errors.any?
  .p-3.rounded.border.border-red-700.text-red-400.text-sm.mb-4{class: "bg-red-900/30"}
    %p.font-semibold.mb-1= "#{@bridge.errors.count} error(s):"
    %ul.list-disc.ml-4
      - @bridge.errors.full_messages.each do |msg|
        %li= msg

= form_with model: [:admin, @bridge], local: true do |f|
  = f.hidden_field :bridge_type, value: "sip"

  -# ── Name ──
  .rounded-lg.border.border-gray-600.bg-ghcard.mb-4.p-4
    %label.block.text-sm.font-semibold.text-gray-400.mb-2 Bridge Name
    = f.text_field :name, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. HamsOverIP"
    - if @bridge.persisted?
      #name-warn.p-2.rounded.border.text-sm.mt-2.items-center.gap-2.hidden{class: "border-yellow-700/50 text-yellow-400 bg-yellow-900/20"}
        %i.bi.bi-exclamation-triangle.mr-1
        Changing the name will recreate the container.

  -# ── SIP Server ──
  .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
    .px-4.py-3.border-b.border-gray-600
      %h5.text-lg.font-semibold.text-gray-100
        %i.bi.bi-headset-vr.mr-2
        SIP Server
    .px-4.py-4
      .grid.grid-cols-1.md:grid-cols-2.gap-4
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 USERNAME
          = f.text_field :sip_username, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. 100123"
          %p.text-xs.text-ghmuted.mt-1 SIP registration username
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 PASSWORD
          = f.text_field :sip_password, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "SIP secret"
          %p.text-xs.text-ghmuted.mt-1 SIP registration password
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 SERVER
          = f.text_field :sip_server, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. pbx.hamsoverip.com"
          %p.text-xs.text-ghmuted.mt-1 SIP server hostname or IP
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 PORT
          = f.number_field :sip_port, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "5060"
          %p.text-xs.text-ghmuted.mt-1 SIP port (default 5060)
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 CALLER ID
          = f.text_field :sip_caller_id, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. SVXLink Bridge"
          %p.text-xs.text-ghmuted.mt-1 Display name for outbound calls (optional)
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 TRANSPORT
          = f.select :sip_transport, [["UDP", "udp"], ["TCP", "tcp"], ["TLS", "tls"]], {}, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext"
          %p.text-xs.text-ghmuted.mt-1 SIP transport protocol

  -# ── Call Settings ──
  .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
    .px-4.py-3.border-b.border-gray-600
      %h5.text-lg.font-semibold.text-gray-100
        %i.bi.bi-telephone-forward.mr-2
        Call Settings
    .px-4.py-4
      .grid.grid-cols-1.md:grid-cols-2.gap-4
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 EXTENSION
          = f.text_field :sip_extension, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. 1000"
          %p.text-xs.text-ghmuted.mt-1 Extension/number to dial for outbound calls
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 MODE
          = f.select :sip_mode, [["Persistent (always connected)", "persistent"], ["On-demand (call on activity)", "on_demand"], ["Listen-only (answer incoming only)", "listen_only"]], {}, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext"
          %p.text-xs.text-ghmuted.mt-1 Persistent keeps the call up; on-demand dials when someone talks; listen-only answers incoming calls only
        #idle-timeout-field.mb-1
          %label.block.text-sm.text-gray-500.mb-1 IDLE TIMEOUT
          = f.number_field :sip_idle_timeout, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "30", min: 5
          %p.text-xs.text-ghmuted.mt-1 Seconds of silence before hanging up (on-demand only)
      .mt-4
        %label.block.text-sm.text-gray-500.mb-1 CODECS
        = f.text_field :sip_codecs, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "opus,g722,gsm,ulaw,alaw"
        %p.text-xs.text-ghmuted.mt-1 Comma-separated codec preference order

  -# ── Post-Connect DTMF ──
  .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
    .px-4.py-3.border-b.border-gray-600
      %h5.text-lg.font-semibold.text-gray-100
        %i.bi.bi-grid-3x3-gap.mr-2
        Post-Connect DTMF
    .px-4.py-4
      .grid.grid-cols-1.md:grid-cols-2.gap-4
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 DTMF DIGITS
          = f.text_field :sip_dtmf, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. 1234#"
          %p.text-xs.text-ghmuted.mt-1 DTMF digits to send after call connects (optional)
        #dtmf-delay-field.mb-1
          %label.block.text-sm.text-gray-500.mb-1 DTMF DELAY
          = f.number_field :sip_dtmf_delay, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "2000", min: 500
          %p.text-xs.text-ghmuted.mt-1 Milliseconds to wait before sending DTMF after connect

  -# ── Incoming Call PIN ──
  .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
    .px-4.py-3.border-b.border-gray-600
      %h5.text-lg.font-semibold.text-gray-100
        %i.bi.bi-shield-lock.mr-2
        Incoming Call PIN
    .px-4.py-4
      .grid.grid-cols-1.md:grid-cols-2.gap-4
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 PIN CODE
          = f.text_field :sip_pin, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. 1234"
          %p.text-xs.text-ghmuted.mt-1 Callers must dial this PIN to hear the TG (leave empty to disable)
        #pin-timeout-field.mb-1
          %label.block.text-sm.text-gray-500.mb-1 PIN TIMEOUT (s)
          = f.number_field :sip_pin_timeout, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "10", min: 3, max: 60
          %p.text-xs.text-ghmuted.mt-1 Seconds the caller has to enter the PIN before being hung up

  -# ── Advanced ──
  .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
    .px-4.py-3.border-b.border-gray-600
      %h5.text-lg.font-semibold.text-gray-100
        %i.bi.bi-gear.mr-2
        Advanced
    .px-4.py-4
      .grid.grid-cols-1.md:grid-cols-2.gap-4
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 PJSIP LOG LEVEL
          = f.number_field :sip_log_level, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "1", min: 0, max: 6
          %p.text-xs.text-ghmuted.mt-1 PJSIP internal log verbosity (0=off, 6=trace)

  -# ── node_info.json ──
  .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
    .px-4.py-3.border-b.border-gray-600
      %h5.text-lg.font-semibold.text-gray-100
        %i.bi.bi-info-circle.mr-2
        node_info.json
    .px-4.py-4
      .grid.grid-cols-1.md:grid-cols-2.gap-4
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 NODE_LOCATION
          = f.text_field :node_location, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. Milan, Italy (shown on dashboard)"
          %p.text-xs.text-ghmuted.mt-1 Defaults to bridge name if empty.
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 SYSOP
          = f.text_field :sysop, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. F1ABC"

  -# ── Local Reflector ──
  .rounded-lg.border.border-gray-600.bg-ghcard.mb-4
    .px-4.py-3.border-b.border-gray-600
      %h5.text-lg.font-semibold.text-gray-100
        %i.bi.bi-broadcast.mr-2
        Local SVXReflector
    .px-4.py-4
      .grid.grid-cols-1.md:grid-cols-2.gap-4
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 HOST
          = f.text_field :local_host, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "svxreflector"
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 PORT
          = f.number_field :local_port, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "5300"
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 CALLSIGN
          = f.text_field :local_callsign, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "e.g. F4ABC-SIP"
          %p.text-xs.text-ghmuted.mt-1 Callsign for the bridge on the local reflector
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 AUTH_KEY
          = f.text_field :local_auth_key, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "Shared secret"
        .mb-1
          %label.block.text-sm.text-gray-500.mb-1 TALKGROUP
          = f.number_field :local_default_tg, class: "w-full px-3 py-2 rounded-md border border-gray-600 text-sm bg-[#0d1117] text-ghtext", placeholder: "1"
          %p.text-xs.text-ghmuted.mt-1 TG to bridge to the SIP endpoint

  -# ── Audio AGC ──
  = render 'form_agc', f: f

  -# Help popup modal
  #help-modal.fixed.inset-0.z-50.items-center.justify-center.hidden{style: "background: rgba(0,0,0,0.6)"}
    .bg-ghcard.border.border-gray-600.rounded-lg.p-5.max-w-md.w-full.mx-4.shadow-xl
      .flex.items-center.justify-between.mb-3
        %h6.text-base.font-semibold.text-gray-100#help-modal-title
        %button.text-gray-400.hover:text-gray-200.cursor-pointer{type: "button", onclick: "closeHelp()"}
          %i.bi.bi-x-lg
      %p.text-sm.text-gray-300.leading-relaxed#help-modal-body

  -# ── Save ──
  .flex.items-center.justify-between
    = link_to admin_bridges_path, class: "px-4 py-2 rounded-md border border-gray-600 text-sm text-gray-300 hover:text-gray-100" do
      %i.bi.bi-arrow-left.mr-1
      Cancel
    = f.submit(@bridge.persisted? ? "Update Bridge" : "Create Bridge", class: "px-4 py-2 rounded-md bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold cursor-pointer")

:css
  .accordion-body { max-height: 0; overflow: hidden; padding-top: 0; padding-bottom: 0; transition: max-height 0.3s ease, padding 0.3s ease; }
  .accordion-body.open { max-height: 5000px; padding-top: 1rem; padding-bottom: 1rem; }
  .accordion-chevron { transition: transform 0.3s ease; }
  .accordion-chevron.open { transform: rotate(180deg); }

:javascript
  function openModal(id) { var m = document.getElementById(id); m.classList.remove('hidden'); m.classList.add('flex'); }
  function closeModal(id) { var m = document.getElementById(id); m.classList.add('hidden'); m.classList.remove('flex'); }

  function showHelp(key) {
    document.getElementById('help-modal-title').textContent = key;
    document.getElementById('help-modal-body').textContent = (typeof HELP_TEXTS !== 'undefined' && HELP_TEXTS[key]) || 'No description available.';
    openModal('help-modal');
  }
  function closeHelp() { closeModal('help-modal'); }
  document.getElementById('help-modal').addEventListener('click', function(e) { if (e.target === this) closeHelp(); });

  function toggleSection(id) {
    var body = document.getElementById('body-' + id);
    var chevron = document.getElementById('chevron-' + id);
    body.classList.toggle('open');
    chevron.classList.toggle('open');
  }

  (function() {
    var modeSelect = document.querySelector('select[name="bridge[sip_mode]"]');
    var idleField = document.getElementById('idle-timeout-field');
    function updateIdleVisibility() {
      if (!modeSelect || !idleField) return;
      idleField.style.display = modeSelect.value === 'on_demand' ? '' : 'none';
    }
    if (modeSelect) {
      modeSelect.addEventListener('change', updateIdleVisibility);
      updateIdleVisibility();
    }
  })();

  (function() {
    var dtmfInput = document.querySelector('input[name="bridge[sip_dtmf]"]');
    var dtmfDelayField = document.getElementById('dtmf-delay-field');
    function updateDtmfDelayVisibility() {
      if (!dtmfInput || !dtmfDelayField) return;
      dtmfDelayField.style.display = dtmfInput.value.trim() !== '' ? '' : 'none';
    }
    if (dtmfInput) {
      dtmfInput.addEventListener('input', updateDtmfDelayVisibility);
      updateDtmfDelayVisibility();
    }
  })();

  (function() {
    var pinInput = document.querySelector('input[name="bridge[sip_pin]"]');
    var pinTimeoutField = document.getElementById('pin-timeout-field');
    function updatePinVisibility() {
      if (!pinInput || !pinTimeoutField) return;
      pinTimeoutField.style.display = pinInput.value.trim() !== '' ? '' : 'none';
    }
    if (pinInput) {
      pinInput.addEventListener('input', updatePinVisibility);
      updatePinVisibility();
    }
  })();

- if @bridge.persisted?
  :javascript
    (function() {
      var inp = document.querySelector('input[name="bridge[name]"]');
      if (!inp) return;
      var orig = inp.dataset.original;
      inp.addEventListener('input', function() {
        document.getElementById('name-warn').classList.toggle('hidden', inp.value === orig);
      });
    })();
