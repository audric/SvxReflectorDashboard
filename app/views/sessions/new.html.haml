!!!
%html{lang: "en"}
  %head
    %meta{charset: "UTF-8"}
    %meta{name: "viewport", content: "width=device-width, initial-scale=1"}
    %title SVXReflector · Login
    %script{src: "https://cdn.tailwindcss.com"}
    :javascript
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ghbg: '#0d1117',
              ghcard: '#161b22',
              ghborder: '#30363d',
              ghborder2: '#21262d',
              ghtext: '#c9d1d9',
              ghmuted: '#8b949e',
              ghdim: '#6e7681',
            }
          }
        }
      }
    %link{rel: "stylesheet", href: "https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"}
    :css
      body { background: #0d1117; }
      input:-webkit-autofill,
      input:-webkit-autofill:hover,
      input:-webkit-autofill:focus {
        -webkit-text-fill-color: #c9d1d9;
        -webkit-box-shadow: 0 0 0 1000px #0d1117 inset;
        transition: background-color 5000s ease-in-out 0s;
      }

  %body.text-ghtext
    = render 'shared/navbar', active: 'login'

    .max-w-md.mx-auto.mt-10.md:mt-14.px-4.pb-8

      -# Header
      .text-center.mb-6
        .inline-flex.items-center.justify-center.w-12.h-12.rounded-full.border.border-ghborder.bg-ghcard.mb-3
          %i.bi.bi-key.text-blue-400.text-xl
        %h1.text-xl.font-semibold.text-gray-100 Sign in to your account
        %p.text-sm.text-ghmuted.mt-1 SVXReflector Dashboard

      -# Flash messages
      - if flash[:notice]
        .rounded-md.border.border-green-800.text-sm.mb-5.px-4.py-3{class: "bg-green-900/20 text-green-400"}
          %i.bi.bi-check-circle.mr-1
          = flash[:notice]
      - if flash[:alert]
        .rounded-md.border.border-red-800.text-sm.mb-5.px-4.py-3{class: "bg-red-900/20 text-red-400"}
          %i.bi.bi-exclamation-triangle.mr-1
          = flash[:alert]

      = form_with url: login_path, method: :post, local: true do |f|

        .rounded-md.border.border-ghborder.bg-ghcard.mb-4
          .p-4.md:p-5
            .mb-4
              %label.block.text-sm.text-gray-400.mb-1{for: "callsign"} Callsign
              = f.text_field :callsign, class: "w-full px-3 py-2 rounded-md border border-ghborder bg-ghbg text-gray-100 placeholder-ghdim focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 transition", autofocus: true, autocapitalize: "characters"
            .mb-1
              %label.block.text-sm.text-gray-400.mb-1{for: "password"} Password
              = f.password_field :password, class: "w-full px-3 py-2 rounded-md border border-ghborder bg-ghbg text-gray-100 placeholder-ghdim focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 transition"

        = f.submit "Sign in", class: "w-full px-4 py-2 rounded-md bg-blue-600 hover:bg-blue-500 text-white font-semibold cursor-pointer transition text-sm"

      -# Footer link
      .text-center.mt-4.text-sm.text-ghdim
        Don't have an account?
        %a.text-blue-400.hover:text-blue-300.ml-1{href: register_path} Register
