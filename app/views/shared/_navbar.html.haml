-# ── Mobile / tablet top bar (visible below lg) ──────────────────────
%nav.sticky.top-0.z-50.bg-ghcard.border-b.border-ghborder.mb-4.py-2.lg:hidden
  .flex.items-center.justify-between.flex-wrap.px-4
    %span.font-bold.text-gray-100.flex.items-center.gap-2
      %i.bi.bi-broadcast-pin.text-green-500
      SVXReflector
      - if local_assigns.fetch(:ws_indicator, false)
        %span.flex.items-center.gap-1
          %span.js-ws-dot.ws-dot.ws-connecting
          %span.js-ws-label.text-gray-500.text-sm Connecting…
      %span.text-gray-100.text-sm.font-mono= @reflector_host

    %button.text-gray-400.md:hidden{type: "button", onclick: "document.getElementById('mainNav').classList.toggle('hidden')"}
      %i.bi.bi-list.text-xl

    #mainNav.hidden.w-full.md:flex.md:w-auto.md:items-center.md:gap-3.mt-2.md:mt-0
      .flex.flex-col.gap-2.mb-2.md:flex-row.md:gap-4.md:mb-0
        %a.text-base.md:text-sm{class: (active == 'dashboard' ? 'text-gray-100' : 'text-gray-500 hover:text-gray-300'), href: root_path}
          %i.bi.bi-grid.mr-1
          Dashboard
        %a.text-base.md:text-sm{class: (active == 'stats' ? 'text-gray-100' : 'text-gray-500 hover:text-gray-300'), href: stats_path}
          %i.bi.bi-bar-chart-line.mr-1
          Stats
        %a.text-base.md:text-sm{class: (active == 'tg' ? 'text-gray-100' : 'text-gray-500 hover:text-gray-300'), href: tg_path}
          %i.bi.bi-collection.mr-1
          TG
        %a.text-base.md:text-sm{class: (active == 'map' ? 'text-gray-100' : 'text-gray-500 hover:text-gray-300'), href: map_path}
          %i.bi.bi-map.mr-1
          Map

      .flex.items-center.gap-3
        - if logged_in?
          .relative
            %button.flex.items-center.gap-2.px-2.py-1.rounded.cursor-pointer.hover:bg-ghborder2{type: "button", onclick: "document.getElementById('userMenu').classList.toggle('hidden')"}
              .w-7.h-7.rounded-full.bg-ghborder.flex.items-center.justify-center.text-ghmuted
                %i.bi.bi-person-fill.text-sm
              %span.text-sm.text-gray-200.font-mono= current_user.callsign
              %i.bi.bi-chevron-down.text-gray-500.text-xs
            #userMenu.hidden.absolute.right-0.mt-1.w-48.rounded-lg.border.border-ghborder.bg-ghcard.shadow-lg.z-50.py-1
              - if current_user.admin?
                = link_to admin_users_path, class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-300 hover:bg-ghborder2" do
                  %i.bi.bi-people
                  Users
                = link_to edit_admin_settings_path, class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-300 hover:bg-ghborder2" do
                  %i.bi.bi-gear
                  Settings
                - if current_user.reflector_admin?
                  = link_to edit_admin_reflector_path, class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-300 hover:bg-ghborder2" do
                    %i.bi.bi-broadcast
                    Reflector
                .border-t.border-ghborder2.my-1
              = button_to logout_path, method: :delete, class: "flex items-center gap-2 px-3 py-2 text-sm text-red-400 hover:bg-ghborder2 w-full" do
                %i.bi.bi-box-arrow-right
                Logout
        - else
          = link_to register_path, class: "text-sm text-gray-500 hover:text-gray-300" do
            %i.bi.bi-person-plus.mr-1
            Register
          = link_to login_path, class: "text-sm text-gray-500 hover:text-gray-300" do
            %i.bi.bi-box-arrow-in-right.mr-1
            Login

-# ── Desktop sidebar (visible at lg+) ───────────────────────────────
%aside.hidden.lg:flex.lg:flex-col.fixed.top-0.left-0.bottom-0.w-56.bg-ghcard.border-r.border-ghborder.z-50
  .px-4.py-4.border-b.border-ghborder
    .flex.items-center.gap-2
      %i.bi.bi-broadcast-pin.text-green-500.text-lg
      %span.font-bold.text-gray-100 SVXReflector
    - if @reflector_host.present?
      .text-sm.font-mono.text-ghmuted.mt-1.truncate= @reflector_host
    - if local_assigns.fetch(:ws_indicator, false)
      .flex.items-center.gap-1.mt-2
        %span.js-ws-dot.ws-dot.ws-connecting
        %span.js-ws-label.text-gray-500.text-sm Connecting…

  %nav.flex-1.px-3.py-4.overflow-y-auto
    .space-y-1
      - [['dashboard', 'bi-grid', 'Dashboard', root_path], ['stats', 'bi-bar-chart-line', 'Stats', stats_path], ['tg', 'bi-collection', 'TG', tg_path], ['map', 'bi-map', 'Map', map_path]].each do |key, icon, label, path|
        %a.flex.items-center.gap-3.px-3.py-2.rounded-md.text-sm.transition-colors{class: (active == key ? 'bg-ghborder2 text-gray-100' : 'text-ghmuted hover:bg-ghborder2 hover:text-gray-300'), href: path}
          %i.bi{class: icon}
          = label

    - if logged_in? && current_user.admin?
      .mt-6.pt-4.border-t.border-ghborder
        .text-xs.uppercase.tracking-wider.text-ghdim.px-3.mb-2 Admin
        .space-y-1
          - admin_links = [['bi-people', 'Users', admin_users_path], ['bi-gear', 'Settings', edit_admin_settings_path]]
          - admin_links << ['bi-broadcast', 'Reflector', edit_admin_reflector_path] if current_user.reflector_admin?
          - admin_links.each do |icon, label, path|
            %a.flex.items-center.gap-3.px-3.py-2.rounded-md.text-sm.transition-colors{class: (request.path.start_with?(path) ? 'bg-ghborder2 text-gray-100' : 'text-ghmuted hover:bg-ghborder2 hover:text-gray-300'), href: path}
              %i.bi{class: icon}
              = label

  -# ── Audio player (visible only to users with monitor permission + auth key) ──
  - if logged_in? && current_user.can_monitor? && current_user.reflector_auth_key.present?
    - audio_tgs = (@nodes || {}).values.flat_map { |n| [n['tg'].to_i] + Array(n['monitoredTGs']).map(&:to_i) }.select { |t| t > 0 }.uniq.sort
    .border-t.border-ghborder.px-3.py-3#audio-player-sidebar{"data-initial-tgs" => audio_tgs.join(','), "data-callsign" => "#{current_user.callsign.upcase}-WEB", "data-auth-key" => current_user.reflector_auth_key.to_s, "data-sysop" => current_user.name.to_s}
      .flex.items-center.gap-1.mb-2
        %i.bi.bi-headphones.text-ghdim.text-xs
        %span.text-xs.uppercase.tracking-wider.text-ghdim Tune In
        %span#audio-dot-sidebar.hidden
          %span.ws-dot.ws-connected{style: "width:6px;height:6px;animation:blink .8s ease-in-out infinite;margin-left:4px;"}
      .space-y-2
        %select#audio-tg-select.w-full.text-xs.bg-ghbg.text-gray-300.border.border-ghborder.rounded.px-2.py-1.cursor-pointer{style: "outline:none;"}
          %option{value: ""} Select TG...
        .flex.items-center.gap-2
          %button#audio-play-btn.flex.items-center.justify-center.w-7.h-7.rounded-full.bg-ghborder2.text-gray-300.hover:text-green-400.transition-colors.cursor-pointer{type: "button", title: "Play / Stop"}
            %i.bi.bi-play-fill.text-xs
          - if current_user.can_transmit?
            %button#audio-ptt-btn.hidden.flex.items-center.justify-center.w-7.h-7.rounded-full.bg-ghborder2.text-gray-300.hover:text-red-400.transition-colors.cursor-pointer{type: "button", title: "Push to Talk"}
              %i.bi.bi-mic-fill.text-xs
          %input#audio-volume.flex-1{type: "range", min: "0", max: "100", value: "70", style: "accent-color:#3fb950;height:4px;cursor:pointer;"}

  .border-t.border-ghborder.px-3.py-3
    - if logged_in?
      .flex.items-center.gap-2.px-2.py-1
        .w-7.h-7.rounded-full.bg-ghborder.flex.items-center.justify-center.text-ghmuted
          %i.bi.bi-person-fill.text-sm
        %span.text-sm.text-gray-200.font-mono.truncate= current_user.callsign
      = button_to logout_path, method: :delete, class: "flex items-center gap-2 px-3 py-2 mt-1 rounded-md text-sm text-red-400 hover:bg-ghborder2 w-full" do
        %i.bi.bi-box-arrow-right
        Logout
    - else
      = link_to register_path, class: "flex items-center gap-2 px-3 py-2 rounded-md text-sm text-ghmuted hover:bg-ghborder2 hover:text-gray-300" do
        %i.bi.bi-person-plus
        Register
      = link_to login_path, class: "flex items-center gap-2 px-3 py-2 rounded-md text-sm text-ghmuted hover:bg-ghborder2 hover:text-gray-300" do
        %i.bi.bi-box-arrow-in-right
        Login

-# ── Mobile audio bar (fixed bottom, below lg) ──
- if logged_in? && current_user.can_monitor? && current_user.reflector_auth_key.present?
  #audio-bar-mobile.fixed.bottom-0.left-0.right-0.z-50.bg-ghcard.border-t.border-ghborder.px-4.py-2.lg:hidden.hidden
    .flex.items-center.gap-3
      %button#audio-play-btn-mobile.flex.items-center.justify-center.w-8.h-8.rounded-full.bg-ghborder2.text-gray-300.hover:text-green-400.transition-colors.cursor-pointer{type: "button"}
        %i.bi.bi-play-fill
      - if current_user.can_transmit?
        %button#audio-ptt-btn-mobile.hidden.flex.items-center.justify-center.w-8.h-8.rounded-full.bg-ghborder2.text-gray-300.hover:text-red-400.transition-colors.cursor-pointer{type: "button"}
          %i.bi.bi-mic-fill
      %select#audio-tg-select-mobile.text-xs.bg-ghbg.text-gray-300.border.border-ghborder.rounded.px-2.py-1.cursor-pointer{style: "outline:none;flex:0 0 auto;"}
        %option{value: ""} TG...
      %input#audio-volume-mobile.flex-1{type: "range", min: "0", max: "100", value: "70", style: "accent-color:#3fb950;height:4px;cursor:pointer;"}
      %span#audio-dot-mobile.hidden
        %span.ws-dot.ws-connected{style: "width:6px;height:6px;animation:blink .8s ease-in-out infinite;"}

:css
  @media (min-width: 1024px) {
    body { padding-left: 14rem; padding-top: 1rem; }
  }
:javascript
  document.addEventListener('click', function(e) {
    var menu = document.getElementById('userMenu');
    if (menu && !menu.parentElement.contains(e.target)) menu.classList.add('hidden');
  });

  // Close page-level WebSockets when Turbo navigates away
  document.addEventListener('turbo:before-cache', function() {
    if (window._pageWs) {
      window._pageWs.onclose = null;
      window._pageWs.close();
      window._pageWs = null;
    }
  });

  /* ── Audio Player (Tune In) ─────────────────────────────────────── */
  (function() {
    // Tear down any previous instance (Turbo re-executes scripts)
    if (window._audioStop) { window._audioStop(); }

    var audioCtx = null;
    var gainNode = null;
    var audioWs = null;
    var playing = false;
    var currentTG = 0;
    var decoder = null;
    var pcmBuffer = [];
    var bufferMaxSamples = 48000 * 2;
    var scriptNode = null;
    var sampleRate = 48000;
    var timestamp = 0;

    // DOM refs (sidebar)
    var tgSelect = document.getElementById('audio-tg-select');
    var playBtn = document.getElementById('audio-play-btn');
    var volumeSlider = document.getElementById('audio-volume');
    var dotSidebar = document.getElementById('audio-dot-sidebar');

    // DOM refs (PTT)
    var pttBtn = document.getElementById('audio-ptt-btn');
    var pttBtnMobile = document.getElementById('audio-ptt-btn-mobile');
    var hasPTT = typeof AudioEncoder !== 'undefined' && window.isSecureContext;

    // DOM refs (mobile)
    var tgSelectMobile = document.getElementById('audio-tg-select-mobile');
    var playBtnMobile = document.getElementById('audio-play-btn-mobile');
    var volumeMobile = document.getElementById('audio-volume-mobile');
    var dotMobile = document.getElementById('audio-dot-mobile');
    var mobileBar = document.getElementById('audio-bar-mobile');

    // ── Persist state across page loads ──
    function saveState() {
      try {
        sessionStorage.setItem('_audio', JSON.stringify({
          playing: playing, tg: currentTG,
          vol: volumeSlider ? volumeSlider.value : (volumeMobile ? volumeMobile.value : 70)
        }));
      } catch(e) {}
    }
    function loadState() {
      try { return JSON.parse(sessionStorage.getItem('_audio') || '{}'); } catch(e) { return {}; }
    }
    function clearState() {
      try { sessionStorage.removeItem('_audio'); } catch(e) {}
    }

    function syncTgSelects(source) {
      var val = source.value;
      if (source === tgSelect && tgSelectMobile) tgSelectMobile.value = val;
      if (source === tgSelectMobile && tgSelect) tgSelect.value = val;
    }

    function updateTgOptions(nodes) {
      if (!nodes) return;
      var tgs = {};
      for (var cs in nodes) {
        var n = nodes[cs];
        var tg = parseInt(n.tg || n.TG || 0);
        if (tg > 0) tgs[tg] = true;
        var monitored = n.monitoredTGs || [];
        for (var i = 0; i < monitored.length; i++) {
          var mt = parseInt(monitored[i]);
          if (mt > 0) tgs[mt] = true;
        }
      }
      var sorted = Object.keys(tgs).map(Number).sort(function(a,b){ return a-b; });
      setTgOptions(sorted);
    }

    function populateInitialTgs() {
      var el = document.getElementById('audio-player-sidebar');
      if (!el) return;
      var raw = el.getAttribute('data-initial-tgs');
      if (!raw) return;
      var tgs = raw.split(',').map(Number).filter(function(t) { return t > 0; });
      if (tgs.length === 0) return;
      setTgOptions(tgs);
    }

    function setTgOptions(sorted) {
      var saved = loadState();
      [tgSelect, tgSelectMobile].forEach(function(sel) {
        if (!sel) return;
        var cur = sel.value || (saved.tg ? String(saved.tg) : '');
        while (sel.options.length > 1) sel.remove(1);
        sorted.forEach(function(tg) {
          var opt = document.createElement('option');
          opt.value = tg;
          opt.textContent = 'TG ' + tg;
          sel.appendChild(opt);
        });
        if (cur) sel.value = cur;
      });
    }

    window.audioPlayerUpdateTgs = updateTgOptions;

    // TX callsign and auth key from data attributes
    var txCallsign = (function() {
      var el = document.getElementById('audio-player-sidebar');
      return el ? (el.getAttribute('data-callsign') || '') : '';
    })();
    var txAuthKey = (function() {
      var el = document.getElementById('audio-player-sidebar');
      return el ? (el.getAttribute('data-auth-key') || '') : '';
    })();
    var txSysop = (function() {
      var el = document.getElementById('audio-player-sidebar');
      return el ? (el.getAttribute('data-sysop') || '') : '';
    })();

    // Parse browser name + version from userAgent
    var browserSW = '', browserSWVer = '';
    (function() {
      var ua = navigator.userAgent;
      var m;
      if ((m = ua.match(/(?:Edg|Edge)\/([\d.]+)/))) { browserSW = 'Edge'; browserSWVer = m[1]; }
      else if ((m = ua.match(/OPR\/([\d.]+)/))) { browserSW = 'Opera'; browserSWVer = m[1]; }
      else if ((m = ua.match(/Chrome\/([\d.]+)/))) { browserSW = 'Chrome'; browserSWVer = m[1]; }
      else if ((m = ua.match(/Firefox\/([\d.]+)/))) { browserSW = 'Firefox'; browserSWVer = m[1]; }
      else if ((m = ua.match(/Version\/([\d.]+).*Safari/))) { browserSW = 'Safari'; browserSWVer = m[1]; }
    })();

    // Eagerly request geolocation — cached for when user clicks Play
    var geoLocation = '';
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition(
        function(pos) { geoLocation = pos.coords.latitude.toFixed(2) + ', ' + pos.coords.longitude.toFixed(2); },
        function() {},
        { timeout: 10000, maximumAge: 300000 }
      );
    }

    if (mobileBar) mobileBar.classList.remove('hidden');

    function setPlaying(state) {
      playing = state;
      var icon = state ? 'bi-stop-fill' : 'bi-play-fill';
      [playBtn, playBtnMobile].forEach(function(btn) {
        if (!btn) return;
        var i = btn.querySelector('i');
        if (i) { i.className = 'bi ' + icon + ' text-xs'; }
        if (state) btn.classList.add('text-green-400');
        else btn.classList.remove('text-green-400');
      });
      // Show/hide PTT button when playing and AudioEncoder is available
      [pttBtn, pttBtnMobile].forEach(function(btn) {
        if (!btn) return;
        if (state && hasPTT) btn.classList.remove('hidden');
        else btn.classList.add('hidden');
      });
    }

    // ── PTT (Push-to-Talk) ──
    var pttActive = false;
    var micStream = null;
    var micReader = null;
    var txEncoder = null;
    var txTimestamp = 0;

    // Snapshot the identifier at subscribe time so it never changes mid-session
    // (geoLocation resolves async and would cause a mismatch).
    var subscribedIdentifier = null;

    function buildIdentifier() {
      return JSON.stringify({ channel: 'AudioChannel', tg: currentTG, callsign: txCallsign, auth_key: txAuthKey, sw: browserSW, sw_ver: browserSWVer, node_class: 'bridge', node_location: geoLocation, sysop: txSysop });
    }

    function acSend(action, data) {
      if (!audioWs || audioWs.readyState !== WebSocket.OPEN || !subscribedIdentifier) return;
      var msg = Object.assign({ action: action }, data || {});
      audioWs.send(JSON.stringify({
        command: 'message',
        identifier: subscribedIdentifier,
        data: JSON.stringify(msg)
      }));
    }

    function pttStart() {
      if (pttActive || !playing || !audioWs) return;
      pttActive = true;

      // Visual feedback — red
      [pttBtn, pttBtnMobile].forEach(function(btn) {
        if (!btn) return;
        btn.classList.add('text-red-400', 'bg-red-900/40');
      });

      acSend('ptt_start', { tg: currentTG, callsign: txCallsign });

      navigator.mediaDevices.getUserMedia({
        audio: { echoCancellation: true, noiseSuppression: true, channelCount: 1 }
      }).then(function(stream) {
        if (!pttActive) { stream.getTracks().forEach(function(t) { t.stop(); }); return; }
        micStream = stream;

        txTimestamp = 0;
        txEncoder = new AudioEncoder({
          output: function(chunk) {
            var buf = new ArrayBuffer(chunk.byteLength);
            var u8 = new Uint8Array(buf);
            chunk.copyTo(u8);
            var binary = '';
            for (var i = 0; i < u8.length; i++) binary += String.fromCharCode(u8[i]);
            var b64 = btoa(binary);
            acSend('tx_audio', { audio: b64, callsign: txCallsign });
          },
          error: function(e) { console.error('TX AudioEncoder error:', e); }
        });
        txEncoder.configure({
          codec: 'opus',
          sampleRate: 48000,
          numberOfChannels: 1,
          bitrate: 24000
        });

        // Use MediaStreamTrackProcessor (Chromium) or ScriptProcessorNode fallback (Firefox)
        var track = stream.getAudioTracks()[0];
        if (typeof MediaStreamTrackProcessor !== 'undefined') {
          var trackProcessor = new MediaStreamTrackProcessor({ track: track });
          micReader = trackProcessor.readable.getReader();
          (function readLoop() {
            micReader.read().then(function(result) {
              if (result.done || !pttActive) { result.value && result.value.close(); return; }
              if (txEncoder && txEncoder.state !== 'closed') {
                txEncoder.encode(result.value);
              }
              result.value.close();
              readLoop();
            }).catch(function() {});
          })();
        } else {
          // Fallback: ScriptProcessorNode captures PCM, wraps in AudioData for the encoder
          var micCtx = new AudioContext({ sampleRate: 48000 });
          var micSource = micCtx.createMediaStreamSource(stream);
          var micProcessor = micCtx.createScriptProcessor(4096, 1, 0);
          micSource.connect(micProcessor);
          micProcessor.connect(micCtx.destination);
          micProcessor.onaudioprocess = function(ev) {
            if (!pttActive || !txEncoder || txEncoder.state === 'closed') return;
            var input = ev.inputBuffer.getChannelData(0);
            var copy = new Float32Array(input.length);
            copy.set(input);
            var ad = new AudioData({
              format: 'f32',
              sampleRate: 48000,
              numberOfFrames: copy.length,
              numberOfChannels: 1,
              timestamp: txTimestamp,
              data: copy
            });
            txEncoder.encode(ad);
            ad.close();
            txTimestamp += Math.round(copy.length / 48000 * 1000000);
          };
          // Store refs for cleanup
          micReader = { cancel: function() {
            micProcessor.disconnect();
            micSource.disconnect();
            micCtx.close();
          }};
        }
      }).catch(function(e) {
        console.error('Mic access error:', e);
        pttStop();
        alert('Mic error: ' + (e.name || '') + ' — ' + (e.message || e));
      });
    }

    function pttStop() {
      if (!pttActive) return;
      pttActive = false;

      // Restore button appearance
      [pttBtn, pttBtnMobile].forEach(function(btn) {
        if (!btn) return;
        btn.classList.remove('text-red-400', 'bg-red-900/40');
      });

      if (micReader) { try { micReader.cancel(); } catch(e) {} micReader = null; }
      if (txEncoder) { try { txEncoder.close(); } catch(e) {} txEncoder = null; }
      if (micStream) { micStream.getTracks().forEach(function(t) { t.stop(); }); micStream = null; }

      acSend('ptt_stop', { tg: currentTG, callsign: txCallsign });
    }

    function showAudioDot(show) {
      [dotSidebar, dotMobile].forEach(function(d) {
        if (!d) return;
        if (show) d.classList.remove('hidden');
        else d.classList.add('hidden');
      });
    }

    function startAudio(tgOverride) {
      var tg = tgOverride || parseInt(tgSelect ? tgSelect.value : (tgSelectMobile ? tgSelectMobile.value : 0));
      if (!tg || tg <= 0) return;
      currentTG = tg;

      // Sync dropdown to match
      [tgSelect, tgSelectMobile].forEach(function(sel) { if (sel) sel.value = tg; });

      audioCtx = new (window.AudioContext || window.webkitAudioContext)({ sampleRate: sampleRate });
      gainNode = audioCtx.createGain();
      var vol = volumeSlider ? volumeSlider.value : (volumeMobile ? volumeMobile.value : 70);
      gainNode.gain.value = vol / 100;
      gainNode.connect(audioCtx.destination);

      pcmBuffer = [];
      scriptNode = audioCtx.createScriptProcessor(4096, 1, 1);
      scriptNode.onaudioprocess = function(e) {
        var output = e.outputBuffer.getChannelData(0);
        for (var i = 0; i < output.length; i++) {
          if (pcmBuffer.length > 0) {
            output[i] = pcmBuffer.shift();
          } else {
            output[i] = 0;
          }
        }
        showAudioDot(pcmBuffer.length > 0);
      };
      scriptNode.connect(gainNode);

      timestamp = 0;
      if (typeof AudioDecoder !== 'undefined') {
        decoder = new AudioDecoder({
          output: function(audioData) {
            var samples = new Float32Array(audioData.numberOfFrames);
            audioData.copyTo(samples, { planeIndex: 0 });
            for (var i = 0; i < samples.length; i++) {
              if (pcmBuffer.length < bufferMaxSamples) {
                pcmBuffer.push(samples[i]);
              }
            }
            audioData.close();
          },
          error: function(e) { console.error('AudioDecoder error:', e); }
        });
        decoder.configure({ codec: 'opus', sampleRate: sampleRate, numberOfChannels: 1 });
      }

      var proto = location.protocol === 'https:' ? 'wss' : 'ws';
      audioWs = new WebSocket(proto + '://' + location.host + '/cable');

      audioWs.onopen = function() {
        subscribedIdentifier = buildIdentifier();
        audioWs.send(JSON.stringify({
          command: 'subscribe',
          identifier: subscribedIdentifier
        }));
      };

      audioWs.onmessage = function(ev) {
        var envelope = JSON.parse(ev.data);
        if (!envelope.message) return;
        var msg = envelope.message;
        if (msg.audio && decoder) {
          try {
            var raw = atob(msg.audio);
            var buf = new Uint8Array(raw.length);
            for (var i = 0; i < raw.length; i++) buf[i] = raw.charCodeAt(i);
            var chunk = new EncodedAudioChunk({ type: 'key', timestamp: timestamp, data: buf });
            decoder.decode(chunk);
            timestamp += 20000;
          } catch(e) { console.error('Decode error:', e); }
        }
      };

      audioWs.onclose = function() {
        pttStop();
        if (playing) { setTimeout(function() { if (playing) startAudio(currentTG); }, 3000); }
      };

      setPlaying(true);
      saveState();
    }

    function stopAudio() {
      pttStop();
      setPlaying(false);
      showAudioDot(false);
      clearState();

      subscribedIdentifier = null;
      if (audioWs) { audioWs.onclose = null; audioWs.close(); audioWs = null; }
      if (decoder) { try { decoder.close(); } catch(e) {} decoder = null; }
      if (scriptNode) { scriptNode.disconnect(); scriptNode = null; }
      if (gainNode) { gainNode.disconnect(); gainNode = null; }
      if (audioCtx) { audioCtx.close(); audioCtx = null; }
      pcmBuffer = [];
    }

    // Expose stop so next script execution can tear down cleanly
    window._audioStop = stopAudio;

    function toggleAudio() {
      if (playing) stopAudio();
      else startAudio();
    }

    if (playBtn) playBtn.addEventListener('click', toggleAudio);
    if (playBtnMobile) playBtnMobile.addEventListener('click', toggleAudio);

    // PTT button events (hold to talk)
    // Release is tracked at the document level so moving the cursor off
    // the small button while holding doesn't cancel the transmission.
    function pttDown(e) { e.preventDefault(); pttStart(); }
    function pttUp() {
      if (!pttActive) return;
      pttStop();
    }
    [pttBtn, pttBtnMobile].forEach(function(btn) {
      if (!btn) return;
      btn.addEventListener('mousedown', pttDown);
      btn.addEventListener('touchstart', pttDown);
    });
    document.addEventListener('mouseup', pttUp);
    document.addEventListener('touchend', pttUp);
    document.addEventListener('touchcancel', pttUp);

    if (tgSelect) tgSelect.addEventListener('change', function() {
      syncTgSelects(tgSelect);
      if (playing) { stopAudio(); startAudio(); }
    });
    if (tgSelectMobile) tgSelectMobile.addEventListener('change', function() {
      syncTgSelects(tgSelectMobile);
      if (playing) { stopAudio(); startAudio(); }
    });

    function setVolume(val) {
      if (gainNode) gainNode.gain.value = val / 100;
      if (volumeSlider) volumeSlider.value = val;
      if (volumeMobile) volumeMobile.value = val;
      if (playing) saveState();
    }
    if (volumeSlider) volumeSlider.addEventListener('input', function() { setVolume(this.value); });
    if (volumeMobile) volumeMobile.addEventListener('input', function() { setVolume(this.value); });

    // Populate TGs, restore saved selection, auto-resume
    populateInitialTgs();
    var saved = loadState();
    if (saved.tg) {
      [tgSelect, tgSelectMobile].forEach(function(sel) { if (sel) sel.value = saved.tg; });
    }
    if (saved.vol) {
      if (volumeSlider) volumeSlider.value = saved.vol;
      if (volumeMobile) volumeMobile.value = saved.vol;
    }
    if (saved.playing && saved.tg) {
      startAudio(saved.tg);
    }
  })();
