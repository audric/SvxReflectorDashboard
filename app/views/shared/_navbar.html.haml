-# ── Mobile / tablet top bar (visible below lg) ──────────────────────
%nav.sticky.top-0.z-50.bg-ghcard.border-b.border-ghborder.mb-4.py-2.lg:hidden
  .flex.items-center.justify-between.flex-wrap.px-4
    %span.font-bold.text-gray-100.flex.items-center.gap-2
      %i.bi.bi-broadcast-pin.text-green-500
      SVXReflector
      - if local_assigns.fetch(:ws_indicator, false)
        %span.flex.items-center.gap-1
          %span.js-ws-dot.ws-dot.ws-connecting
          %span.js-ws-label.text-gray-500.text-sm Connecting…
      %span.text-gray-100.text-sm.font-mono= @reflector_host

    %button.text-gray-400.md:hidden{type: "button", onclick: "document.getElementById('mainNav').classList.toggle('hidden')"}
      %i.bi.bi-list.text-xl

    #mainNav.hidden.w-full.md:flex.md:w-auto.md:items-center.md:gap-3.mt-2.md:mt-0
      .flex.flex-col.gap-2.mb-2.md:flex-row.md:gap-4.md:mb-0
        %a.text-base.md:text-sm{class: (active == 'dashboard' ? 'text-gray-100' : 'text-gray-500 hover:text-gray-300'), href: root_path}
          %i.bi.bi-grid.mr-1
          Dashboard
        %a.text-base.md:text-sm{class: (active == 'stats' ? 'text-gray-100' : 'text-gray-500 hover:text-gray-300'), href: stats_path}
          %i.bi.bi-bar-chart-line.mr-1
          Stats
        %a.text-base.md:text-sm{class: (active == 'tg' ? 'text-gray-100' : 'text-gray-500 hover:text-gray-300'), href: tg_path}
          %i.bi.bi-collection.mr-1
          TG
        %a.text-base.md:text-sm{class: (active == 'map' ? 'text-gray-100' : 'text-gray-500 hover:text-gray-300'), href: map_path}
          %i.bi.bi-map.mr-1
          Map

      .flex.items-center.gap-3
        - if logged_in?
          .relative
            %button.flex.items-center.gap-2.px-2.py-1.rounded.cursor-pointer.hover:bg-ghborder2{type: "button", onclick: "document.getElementById('userMenu').classList.toggle('hidden')"}
              .w-7.h-7.rounded-full.bg-ghborder.flex.items-center.justify-center.text-ghmuted
                %i.bi.bi-person-fill.text-sm
              %span.text-sm.text-gray-200.font-mono= current_user.callsign
              %i.bi.bi-chevron-down.text-gray-500.text-xs
            #userMenu.hidden.absolute.right-0.mt-1.w-48.rounded-lg.border.border-ghborder.bg-ghcard.shadow-lg.z-50.py-1
              - if current_user.admin?
                = link_to admin_users_path, class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-300 hover:bg-ghborder2" do
                  %i.bi.bi-people
                  Users
                = link_to admin_nodes_path, class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-300 hover:bg-ghborder2" do
                  %i.bi.bi-hdd-rack
                  Nodes
                = link_to admin_node_classes_path, class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-300 hover:bg-ghborder2" do
                  %i.bi.bi-diagram-3
                  Classes
                = link_to admin_talkgroups_path, class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-300 hover:bg-ghborder2" do
                  %i.bi.bi-chat-dots
                  Talkgroups
                = link_to admin_ctcss_tones_path, class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-300 hover:bg-ghborder2" do
                  %i.bi.bi-soundwave
                  CTCSS Tones
                = link_to edit_admin_settings_path, class: "flex items-center gap-2 px-3 py-2 text-sm text-gray-300 hover:bg-ghborder2" do
                  %i.bi.bi-gear
                  Settings
                .border-t.border-ghborder2.my-1
              = button_to logout_path, method: :delete, class: "flex items-center gap-2 px-3 py-2 text-sm text-red-400 hover:bg-ghborder2 w-full" do
                %i.bi.bi-box-arrow-right
                Logout
        - else
          = link_to register_path, class: "text-sm text-gray-500 hover:text-gray-300" do
            %i.bi.bi-person-plus.mr-1
            Register
          = link_to login_path, class: "text-sm text-gray-500 hover:text-gray-300" do
            %i.bi.bi-box-arrow-in-right.mr-1
            Login

-# ── Desktop sidebar (visible at lg+) ───────────────────────────────
%aside.hidden.lg:flex.lg:flex-col.fixed.top-0.left-0.bottom-0.w-56.bg-ghcard.border-r.border-ghborder.z-50
  .px-4.py-4.border-b.border-ghborder
    .flex.items-center.gap-2
      %i.bi.bi-broadcast-pin.text-green-500.text-lg
      %span.font-bold.text-gray-100 SVXReflector
    - if @reflector_host.present?
      .text-sm.font-mono.text-ghmuted.mt-1.truncate= @reflector_host
    - if local_assigns.fetch(:ws_indicator, false)
      .flex.items-center.gap-1.mt-2
        %span.js-ws-dot.ws-dot.ws-connecting
        %span.js-ws-label.text-gray-500.text-sm Connecting…

  %nav.flex-1.px-3.py-4.overflow-y-auto
    .space-y-1
      - [['dashboard', 'bi-grid', 'Dashboard', root_path], ['stats', 'bi-bar-chart-line', 'Stats', stats_path], ['tg', 'bi-collection', 'TG', tg_path], ['map', 'bi-map', 'Map', map_path]].each do |key, icon, label, path|
        %a.flex.items-center.gap-3.px-3.py-2.rounded-md.text-sm.transition-colors{class: (active == key ? 'bg-ghborder2 text-gray-100' : 'text-ghmuted hover:bg-ghborder2 hover:text-gray-300'), href: path}
          %i.bi{class: icon}
          = label

    - if logged_in? && current_user.admin?
      .mt-6.pt-4.border-t.border-ghborder
        .text-xs.uppercase.tracking-wider.text-ghdim.px-3.mb-2 Admin
        .space-y-1
          - [['bi-people', 'Users', admin_users_path], ['bi-hdd-rack', 'Nodes', admin_nodes_path], ['bi-diagram-3', 'Classes', admin_node_classes_path], ['bi-chat-dots', 'Talkgroups', admin_talkgroups_path], ['bi-soundwave', 'CTCSS', admin_ctcss_tones_path], ['bi-gear', 'Settings', edit_admin_settings_path]].each do |icon, label, path|
            %a.flex.items-center.gap-3.px-3.py-2.rounded-md.text-sm.transition-colors{class: (request.path.start_with?(path) ? 'bg-ghborder2 text-gray-100' : 'text-ghmuted hover:bg-ghborder2 hover:text-gray-300'), href: path}
              %i.bi{class: icon}
              = label

  .border-t.border-ghborder.px-3.py-3
    - if logged_in?
      .flex.items-center.gap-2.px-2.py-1
        .w-7.h-7.rounded-full.bg-ghborder.flex.items-center.justify-center.text-ghmuted
          %i.bi.bi-person-fill.text-sm
        %span.text-sm.text-gray-200.font-mono.truncate= current_user.callsign
      = button_to logout_path, method: :delete, class: "flex items-center gap-2 px-3 py-2 mt-1 rounded-md text-sm text-red-400 hover:bg-ghborder2 w-full" do
        %i.bi.bi-box-arrow-right
        Logout
    - else
      = link_to register_path, class: "flex items-center gap-2 px-3 py-2 rounded-md text-sm text-ghmuted hover:bg-ghborder2 hover:text-gray-300" do
        %i.bi.bi-person-plus
        Register
      = link_to login_path, class: "flex items-center gap-2 px-3 py-2 rounded-md text-sm text-ghmuted hover:bg-ghborder2 hover:text-gray-300" do
        %i.bi.bi-box-arrow-in-right
        Login

:css
  @media (min-width: 1024px) {
    body { padding-left: 14rem; }
  }
:javascript
  document.addEventListener('click', function(e) {
    var menu = document.getElementById('userMenu');
    if (menu && !menu.parentElement.contains(e.target)) menu.classList.add('hidden');
  });
